<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <style>
    .balance-badge { font-size: 1.5rem; font-weight: 700; color: #0284c7; }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <h1 class="mb-1">Support the Museum</h1>
      <p class="text-muted mb-4">Donate to the Naval Archive using your wallet balance. Don't have an account? <a href="/payment-account">Create one here</a>.</p>

      <div class="row">
        <div class="col-lg-6">

          <!-- Load account -->
          <div class="card mb-3" id="acctLoadCard">
            <div class="card-body">
              <label class="form-label fw-semibold">Payment Account API Key</label>
              <div class="d-flex gap-2">
                <input type="text" id="acctKeyInput" class="form-control font-monospace" placeholder="sk_live_..." autocomplete="off">
                <button class="btn btn-modern" type="button" onclick="loadAcct()">Load</button>
              </div>
              <div id="acctLoadResult" class="mt-2"></div>
            </div>
          </div>

          <!-- Account dashboard -->
          <div id="acctDashboard" style="display:none;">
            <div class="card mb-3">
              <div class="card-body text-center py-3">
                <div class="text-muted small mb-1">Account Balance</div>
                <div class="balance-badge" id="acctBalance">$0.00</div>
                <div class="text-muted small" id="acctLabel"></div>
              </div>
            </div>
            <div class="card">
              <div class="card-body">
                <div class="mb-3">
                  <label class="form-label fw-semibold">Amount (USD)</label>
                  <input type="number" id="acctAmount" class="form-control" value="25" min="0.01" step="0.01">
                </div>
                <div class="mb-3">
                  <label class="form-label fw-semibold">Description</label>
                  <input type="text" id="acctDesc" class="form-control" value="Museum donation">
                </div>
                <button class="btn btn-modern w-100" type="button" onclick="payFromAccount()">Donate from Balance</button>
                <div id="acctPayResult" class="mt-2"></div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let acctApiKey = localStorage.getItem('paymentAccountKey') || '';
    if (acctApiKey) document.getElementById('acctKeyInput').value = acctApiKey;

    async function loadAcct() {
      const key = document.getElementById('acctKeyInput').value.trim();
      if (!key) return;
      const el = document.getElementById('acctLoadResult');
      el.innerHTML = '<span class="text-muted small">Loading...</span>';
      try {
        const res = await fetch('/api/accounts/me', { headers: { 'X-API-Key': key } });
        const data = await res.json();
        if (!res.ok) { el.innerHTML = '<div class="alert alert-danger py-2 small">' + (data.error || 'Invalid key') + '</div>'; return; }
        acctApiKey = key;
        localStorage.setItem('paymentAccountKey', key);
        localStorage.setItem('paymentAccountName', data.name || '');
        el.innerHTML = '<div class="alert alert-success py-2 small">&#10003; Loaded: ' + data.name + '</div>';
        document.getElementById('acctBalance').textContent = '$' + (data.balance || 0).toFixed(2);
        document.getElementById('acctLabel').textContent = (data.name || '') + (data.accountId ? '  ·  ' + data.accountId : '');
        document.getElementById('acctDashboard').style.display = '';
      } catch (err) {
        el.innerHTML = '<div class="alert alert-danger py-2 small">Account service unavailable</div>';
      }
    }

    async function payFromAccount() {
      const amount = parseFloat(document.getElementById('acctAmount').value);
      const description = document.getElementById('acctDesc').value || 'Museum donation';
      const el = document.getElementById('acctPayResult');
      if (!amount || amount <= 0) { el.innerHTML = '<div class="text-danger small">Enter a valid amount</div>'; return; }
      if (!acctApiKey) { el.innerHTML = '<div class="text-danger small">Load your API key first</div>'; return; }
      el.innerHTML = '<span class="text-muted small">Processing...</span>';
      try {
        const res = await fetch('/api/payments/simulate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-API-Key': acctApiKey },
          body: JSON.stringify({ amount, currency: 'USD', description })
        });
        const data = await res.json();
        if (res.status === 402) {
          el.innerHTML = '<div class="alert alert-danger py-2 small">Insufficient funds — top up on Payment Account page first.</div>';
          return;
        }
        if (!res.ok) {
          el.innerHTML = '<div class="alert alert-danger py-2 small">' + (data.error || 'Payment failed') + '</div>';
          return;
        }
        el.innerHTML = '<div class="alert alert-success py-2 small">&#10003; Donation approved' + (data.transactionId ? ' — ' + data.transactionId : '') + '</div>';
        setTimeout(async function() {
          try {
            const r = await fetch('/api/accounts/me', { headers: { 'X-API-Key': acctApiKey } });
            if (r.ok) { const d = await r.json(); document.getElementById('acctBalance').textContent = '$' + (d.balance || 0).toFixed(2); }
          } catch (_) {}
        }, 1500);
      } catch (err) {
        el.innerHTML = '<div class="alert alert-danger py-2 small">Payment service unavailable</div>';
      }
    }

    if (acctApiKey) loadAcct();
  </script>
</body>
</html>
