<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <h1 class="mb-4">Captains</h1>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-warning"><%= error %></div>
      <% } %>
      <div class="row g-4">
        <% if (captains && captains.length > 0) { %>
          <% captains.forEach(function(c) {
            var entity = toEntity(c, 'captain');
            entity.subtitle = [c.rank, c.serviceYears ? c.serviceYears + ' years service' : '', c.shipCount != null ? c.shipCount + ' ship' + (c.shipCount !== 1 ? 's' : '') + ' commanded' : ''].filter(Boolean).join(' · ');
          %>
            <%- include('partials/entity-card', { entity: entity, showSubtitle: true }) %>
          <% }); %>
        <% } else { %>
          <div class="col-12 text-center text-muted py-5">No captains found.</div>
        <% } %>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
