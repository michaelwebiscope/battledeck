<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <%- include('partials/dynamic-list-filters-head') %>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <%
        var pg = typeof entityTypes !== 'undefined' && entityTypes.pages && entityTypes.pages.gallery ? entityTypes.pages.gallery : {};
        var galleryTitle = pg.title || 'Photo Gallery';
        var galleryDesc = pg.description || 'Archival photographs. Click any image to view full size.';
        var rtc = typeof dynamicListRuntime !== 'undefined' && dynamicListRuntime ? dynamicListRuntime : {};
        var _pgBase = typeof pageBasePath !== 'undefined' ? pageBasePath : rtc.pageBasePath || '/gallery';
        var _dlfNoGallery = '<p class="small text-muted mb-3">Filters are built from <code>/api/ships</code> data shown in the gallery.</p>';
      %>
      <h1 class="mb-4"><%= galleryTitle %></h1>
      <p class="text-muted mb-4"><%= galleryDesc %></p>
      <%- include('partials/dynamic-list-filters', {
        filterConfig: typeof filterConfig !== 'undefined' ? filterConfig : [],
        activeFilters: typeof activeFilters !== 'undefined' ? activeFilters : {},
        persistedFilterOverrides: typeof persistedFilterOverrides !== 'undefined' ? persistedFilterOverrides : {},
        hiddenFilterKeys: typeof hiddenFilterKeys !== 'undefined' ? hiddenFilterKeys : [],
        hiddenFiltersRestoreList: typeof hiddenFiltersRestoreList !== 'undefined' ? hiddenFiltersRestoreList : [],
        dlfRuntimeDefault: Object.assign(
          {
            pageBasePath: '/gallery',
            partialPath: '/gallery/partial',
            summaryAllLabel: 'Showing all gallery images',
            domPrefix: 'galleryDlf',
            resultsPanelId: 'galleryResultsPanel',
            paginationAriaLabel: 'Gallery pagination',
            refreshMode: 'serverPartial',
            adapterName: '',
            adapterOptions: {}
          },
          rtc
        ),
        dlfListId: rtc.listId != null ? String(rtc.listId) : '',
        dlfDomPrefix: 'galleryDlf',
        dlfResultsPanelId: 'galleryResultsPanel',
        dlfSearchPlaceholder: 'Search gallery…',
        dlfFormAction: _pgBase,
        dlfSearchAriaLabel: 'Search gallery',
        dlfSearchInputTitle: 'Search gallery',
        dlfNoFiltersHtml: _dlfNoGallery
      }) %>
      <div id="galleryResultsPanel">
      <%- include('partials/gallery-results-panel') %>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
  <%- include('partials/dynamic-list-filters-scripts') %>
  <%- include('partials/image-lightbox') %>
</body>
</html>
