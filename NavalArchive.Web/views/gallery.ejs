<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <%
        var pg = typeof entityTypes !== 'undefined' && entityTypes.pages && entityTypes.pages.gallery ? entityTypes.pages.gallery : {};
        var galleryTitle = pg.title || 'Photo Gallery';
        var galleryDesc = pg.description || 'Archival photographs. Click any image to view full size.';
        var emptyMsg = pg.emptyMessage || 'No images available. Ensure the API is running.';
      %>
      <h1 class="mb-4"><%= galleryTitle %></h1>
      <p class="text-muted mb-4"><%= galleryDesc %></p>
      <div class="row g-4">
        <% if (ships && ships.length > 0) { %>
          <% ships.forEach(function(ship) {
            var entity = toEntity(ship, 'ship');
            entity.subtitle = [ship.class ? ship.class.type : '', ship.yearCommissioned].filter(Boolean).join(' · ');
          %>
            <%- include('partials/entity-card', { entity: entity, size: 'sm', variant: 'gallery', cols: 'col-md-4 col-lg-3', showSubtitle: true }) %>
          <% }); %>
        <% } else { %>
          <div class="col-12 text-center text-muted py-5"><%= emptyMsg %></div>
        <% } %>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <%- include('partials/image-lightbox') %>
</body>
</html>
