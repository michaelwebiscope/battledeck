<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <%- include('partials/dynamic-list-filters-head') %>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <%
        var rtc = typeof dynamicListRuntime !== 'undefined' && dynamicListRuntime ? dynamicListRuntime : {};
        var _pgBase = typeof pageBasePath !== 'undefined' ? pageBasePath : rtc.pageBasePath || '/logs';
      %>
      <h1 class="mb-4">Daily Logs</h1>
      <p class="text-muted mb-4">Search captain logs sourced from naval battle archives. Click a result row to open the full day log.</p>
      <%- include('partials/dynamic-list-filters', {
        filterConfig: typeof filterConfig !== 'undefined' ? filterConfig : [],
        activeFilters: typeof activeFilters !== 'undefined' ? activeFilters : {},
        persistedFilterOverrides: typeof persistedFilterOverrides !== 'undefined' ? persistedFilterOverrides : {},
        hiddenFilterKeys: typeof hiddenFilterKeys !== 'undefined' ? hiddenFilterKeys : [],
        hiddenFiltersRestoreList: typeof hiddenFiltersRestoreList !== 'undefined' ? hiddenFiltersRestoreList : [],
        dlfRuntimeDefault: Object.assign(
          {
            pageBasePath: '/logs',
            partialPath: '/logs/partial',
            summaryAllLabel: 'Showing all logs',
            domPrefix: 'logsDlf',
            resultsPanelId: 'logsResultsPanel',
            paginationAriaLabel: 'Logs pagination',
            refreshMode: 'serverPartial',
            adapterName: '',
            adapterOptions: {}
          },
          rtc
        ),
        dlfListId: rtc.listId != null ? String(rtc.listId) : '',
        dlfDomPrefix: 'logsDlf',
        dlfResultsPanelId: 'logsResultsPanel',
        dlfSearchPlaceholder: 'Search logs by ship, date, source, or entry...',
        dlfFormAction: _pgBase,
        dlfSearchAriaLabel: 'Search logs filters',
        dlfSearchInputTitle: 'Logs filter search'
      }) %>
      <div id="logsResultsPanel">
        <%- include('partials/logs-results-panel') %>
      </div>

      <div class="modal fade" id="dayLogModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="dayLogModalTitle">Full Day Log</h5>
              <button type="button" class="btn btn-outline-light btn-sm me-2" id="dayLogCopyBtn" title="Copy to clipboard">Copy</button>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <p class="text-muted small mb-2" id="dayLogSource"></p>
              <div id="dayLogEntries" class="font-monospace small"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
  <%- include('partials/dynamic-list-filters-scripts') %>
  <script>
    (function() {
      function escapeHtml(s) {
        var div = document.createElement('div');
        div.textContent = s;
        return div.innerHTML;
      }

      function showDayLog(shipName, logDate) {
        var modal = new bootstrap.Modal(document.getElementById('dayLogModal'));
        var titleEl = document.getElementById('dayLogModalTitle');
        var sourceEl = document.getElementById('dayLogSource');
        var entriesEl = document.getElementById('dayLogEntries');
        var copyBtn = document.getElementById('dayLogCopyBtn');
        titleEl.textContent = shipName + ' - ' + logDate;
        sourceEl.textContent = 'Loading...';
        entriesEl.innerHTML = '';
        copyBtn.style.display = 'none';
        modal.show();
        fetch('/logs/day.json?shipName=' + encodeURIComponent(shipName) + '&logDate=' + encodeURIComponent(logDate))
          .then(function(r) { return r.ok ? r.json() : Promise.reject(r.status); })
          .then(function(data) {
            sourceEl.textContent = data.source || '';
            entriesEl.innerHTML = (data.entries || []).map(function(e) {
              return '<p class="mb-2 border-bottom pb-2">' + escapeHtml(e) + '</p>';
            }).join('');
            entriesEl.dataset.copyText = [data.shipName + ' - ' + data.logDate, data.source || '', ''].concat(data.entries || []).join('\n\n');
            copyBtn.style.display = 'inline-block';
          })
          .catch(function() {
            sourceEl.textContent = '';
            entriesEl.innerHTML = '<p class="text-danger">Could not load full day log.</p>';
          });
      }

      document.getElementById('dayLogCopyBtn')?.addEventListener('click', function() {
        var text = document.getElementById('dayLogEntries')?.dataset?.copyText || '';
        if (text && navigator.clipboard?.writeText) {
          navigator.clipboard.writeText(text).then(function() {
            var btn = document.getElementById('dayLogCopyBtn');
            var orig = btn.textContent;
            btn.textContent = 'Copied';
            setTimeout(function() { btn.textContent = orig; }, 1500);
          });
        }
      });

      document.addEventListener('click', function(e) {
        var target = e.target;
        var row = target && target.closest ? target.closest('[data-log-ship][data-log-date]') : null;
        if (!row) return;
        e.preventDefault();
        showDayLog(row.getAttribute('data-log-ship'), row.getAttribute('data-log-date'));
      });
    })();
  </script>
</body>
</html>
