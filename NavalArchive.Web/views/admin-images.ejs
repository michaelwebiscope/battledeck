        var cards = Array.from(grid.querySelectorAll('.edit-card'));
        cards.forEach(function(card) {
          card.draggable = true;
          card.ondragstart = function(e) {
            card.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', (card.dataset.entity || '') + '|' + (card.dataset.id || ''));
          };
          card.ondragend = function() { card.classList.remove('dragging'); };
        });
        grid.ondragover = function(e) {
          e.preventDefault();
          e.dataTransfer.dropEffect = 'move';
          grid.querySelectorAll('.edit-card.drag-over').forEach(function(c) { c.classList.remove('drag-over'); });
          var target = e.target.closest('.edit-card');
          if (target && target.parentNode === grid && !target.classList.contains('dragging')) target.classList.add('drag-over');
        };
        grid.ondragleave = function(e) {
          if (!grid.contains(e.relatedTarget)) grid.querySelectorAll('.edit-card.drag-over').forEach(function(c) { c.classList.remove('drag-over'); });
        };
        grid.ondrop = function(e) {
          e.preventDefault();
          grid.querySelectorAll('.edit-card.drag-over').forEach(function(c) { c.classList.remove('drag-over'); });
          var key = e.dataTransfer.getData('text/plain');
          if (!key) return;
          var parts = key.split('|');
          var fromCard = grid.querySelector('.edit-card[data-entity="' + (parts[0] || '') + '"][data-id="' + (parts[1] || '') + '"]');
          var toCard = e.target.closest('.edit-card');
          if (!fromCard || fromCard.parentNode !== grid) return;
          if (!toCard || toCard.parentNode !== grid) {
            grid.appendChild(fromCard);
            return;
          }
          if (fromCard === toCard) return;
          var cardsNow = Array.from(grid.querySelectorAll('.edit-card'));
          var fromIdx = cardsNow.indexOf(fromCard);
          var toIdx = cardsNow.indexOf(toCard);
          if (fromIdx < 0 || toIdx < 0) return;
          if (fromIdx < toIdx) grid.insertBefore(fromCard, toCard.nextSibling);
          else grid.insertBefore(fromCard, toCard);
        };
      });
    }
    setupDraggableCards();

    var multiEditItems = [];
    var multiEditIdx = 0;
    function showMultiEditItem() {
      if (multiEditItems.length === 0) return;
      var it = multiEditItems[multiEditIdx];
      currentEdit = { entity: it.entity, id: it.id, name: it.name, card: it.card };
      var img = document.getElementById('editCurrentImg');
      img.src = (it.entity === 'ship' ? '/gallery/image/' : '/gallery/captain/') + it.id + '?v=' + Date.now();
      editModalTitle.textContent = 'Edit: ' + it.name + ' (' + (multiEditIdx + 1) + ' of ' + multiEditItems.length + ')';
      document.getElementById('editMultiProgress').textContent = (multiEditIdx + 1) + ' of ' + multiEditItems.length;
      document.getElementById('editPrevBtn').disabled = multiEditIdx === 0;
      document.getElementById('editNextBtn').disabled = multiEditIdx === multiEditItems.length - 1;
    }
    document.getElementById('bulkEditSelectedBtn').onclick = function() {
      var items = getSelectedItems();
      if (items.length === 0) return;
      bulkModeSelection = [];
      multiEditItems = items.slice();
      multiEditIdx = 0;
      document.getElementById('editMultiNav').style.display = multiEditItems.length > 1 ? 'flex' : 'none';
      editImagePane.style.display = 'block';
      editSearchPane.style.display = 'none';
      showMultiEditItem();
      new bootstrap.Modal(editModal).show();
    };
    document.getElementById('editPrevBtn').onclick = function() {
      if (multiEditIdx > 0) { multiEditIdx--; showMultiEditItem(); }
    };
    document.getElementById('editNextBtn').onclick = function() {
      if (multiEditIdx < multiEditItems.length - 1) { multiEditIdx++; showMultiEditItem(); }
    };

    document.getElementById('bulkApplyUrlBtn').onclick = function() {
      var url = (document.getElementById('bulkUrlInput').value || '').trim();
      if (!url) { document.getElementById('bulkStatus').textContent = 'Enter a URL.'; return; }
      if (!/^https?:\/\//i.test(url)) { document.getElementById('bulkStatus').textContent = 'URL must start with http:// or https://'; return; }
      var items = getSelectedItems();
      if (items.length === 0) { document.getElementById('bulkStatus').textContent = 'Select at least one item.'; return; }
      var statusEl = document.getElementById('bulkStatus');
      statusEl.textContent = 'Applying to ' + items.length + ' items...';
      var done = 0, failed = 0;
      function next() {
        if (done + failed >= items.length) {
          statusEl.textContent = 'Done. Updated ' + done + (failed ? ', failed ' + failed : '') + '.';
          document.querySelectorAll('.edit-card.selected .entity-chk').forEach(function(c) { c.checked = false; });
          document.querySelectorAll('.edit-card.selected').forEach(function(c) { c.classList.remove('selected'); });
          updateBulkBar();
          refreshAudit();
          return;
        }
        var it = items[done + failed];
        fetch('/api/images/' + it.entity + '/' + it.id + '/from-url', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ url: url }) })
          .then(function(r) {
            if (!r.ok) return r.json().then(function(j) { throw new Error(j.error || j.message || 'Failed'); });
            return r.json();
          })
          .then(function() {
            done++;
            var thumb = it.card.querySelector('.edit-thumb');
            if (thumb) thumb.src = (it.entity === 'ship' ? '/gallery/image/' : '/gallery/captain/') + it.id + '?v=' + Date.now();
            next();
          })
          .catch(function(e) { failed++; statusEl.textContent = 'Error on ' + it.name + ': ' + e.message; next(); });
      }
      next();
    };

    function buildPopulateRequestBodyForEntity(entity) {
      var collected = collectKeysFromSources();
      var body = Object.assign({}, collected.keys);
      if (Object.keys(collected.customKeys).length > 0) body.customKeys = collected.customKeys;
      var searchPrefixes = <%- JSON.stringify(typeof imageSearchPrefix !== 'undefined' && imageSearchPrefix ? imageSearchPrefix : { ship: 'battleship', captain: 'captain' }) %>;
      body.shipSearchPrefix = searchPrefixes.ship || 'battleship';
      body.captainSearchPrefix = searchPrefixes.captain || 'captain';
      if (imageSources && imageSources.length > 0) body.imageSources = imageSources;
      return body;
    }

    function populateSelectedItems(opts) {
      opts = opts || {};
      var force = opts.force === true;
      var items = getSelectedItems();
      var statusEl = document.getElementById('bulkStatus');
      if (items.length === 0) { if (statusEl) statusEl.textContent = 'Select at least one item.'; return; }
      if (force) {
        var okForce = confirm('Force populate will delete the current cached image(s) first, then repopulate.\n\nThis can overwrite manually-set images. Continue?');
        if (!okForce) return;
      }
      var populateBtn = document.getElementById('bulkPopulateBtn');
      var forceBtn = document.getElementById('bulkForcePopulateBtn');
      if (populateBtn) populateBtn.disabled = true;
      if (forceBtn) forceBtn.disabled = true;
      if (statusEl) statusEl.textContent = (force ? 'Force populating ' : 'Populating ') + items.length + ' items...';
      var ok = 0, failed = 0;
      function finish() {
        if (statusEl) statusEl.textContent = 'Done. ' + (force ? 'Force populated ' : 'Populated ') + ok + (failed ? ', failed ' + failed : '') + '.';
        document.querySelectorAll('.edit-card.selected .entity-chk').forEach(function(c) { c.checked = false; });
        document.querySelectorAll('.edit-card.selected').forEach(function(c) { c.classList.remove('selected'); });
        updateBulkBar();
        refreshAudit();
        if (populateBtn) populateBtn.disabled = false;
        if (forceBtn) forceBtn.disabled = false;
      }
      function setThumb(it) {
        var thumb = it.card && it.card.querySelector('.edit-thumb');
        if (thumb) thumb.src = (it.entity === 'ship' ? '/gallery/image/' : '/gallery/captain/') + it.id + '?v=' + Date.now();
      }
      function parseJsonMaybe(r) {
        return r.text().then(function(t) {
          var data = null;
          try { data = t ? JSON.parse(t) : {}; } catch (_) { data = { raw: t }; }
          return { ok: r.ok, status: r.status, data: data };
        });
      }
      function doPopulate(it) {
        var body = buildPopulateRequestBodyForEntity(it.entity);
        return fetch('/api/images/populate/' + it.entity + '/' + it.id, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        }).then(parseJsonMaybe).then(function(result) {
          if (!result.ok) throw new Error((result.data && (result.data.error || result.data.message || result.data.reason)) || ('HTTP ' + result.status));
          var st = (result.data && (result.data.status || result.data.Status)) || 'ok';
          if (String(st).toLowerCase() !== 'ok') throw new Error((result.data && (result.data.reason || result.data.Reason)) || 'Populate failed');
          return result.data;
        });
      }
      function doForceDelete(it) {
        return fetch('/api/images/' + it.entity + '/' + it.id, { method: 'DELETE' })
          .then(parseJsonMaybe)
          .then(function(result) {
            if (!result.ok && result.status !== 404) {
              throw new Error((result.data && (result.data.error || result.data.message)) || ('HTTP ' + result.status));
            }
            return result.data;
          });
      }
      function next(i) {
        if (i >= items.length) return finish();
        var it = items[i];
        var label = it.name || (it.entity + ' ' + it.id);
        if (statusEl) statusEl.textContent = (force ? 'Force populating ' : 'Populating ') + (i + 1) + '/' + items.length + ': ' + label + '...';
        var p = force
          ? doForceDelete(it).then(function() { return doPopulate(it); })
          : doPopulate(it);
        p.then(function() {
          ok++;
          setThumb(it);
        }).catch(function(e) {
          failed++;
          if (statusEl) statusEl.textContent = 'Error on ' + label + ': ' + e.message;
        }).finally(function() {
          next(i + 1);
        });
      }
      next(0);
    }

    var bulkPopulateBtn = document.getElementById('bulkPopulateBtn');
    if (bulkPopulateBtn) bulkPopulateBtn.onclick = function() { populateSelectedItems({ force: false }); };
    var bulkForcePopulateBtn = document.getElementById('bulkForcePopulateBtn');
    if (bulkForcePopulateBtn) bulkForcePopulateBtn.onclick = function() { populateSelectedItems({ force: true }); };

    document.getElementById('bulkUploadInput').onchange = function() {
      var file = this.files && this.files[0];
      if (!file || !file.type.match(/^image\//)) { document.getElementById('bulkStatus').textContent = 'Select an image file.'; return; }
      var items = getSelectedItems();
      if (items.length === 0) { document.getElementById('bulkStatus').textContent = 'Select at least one item.'; this.value = ''; return; }
      var statusEl = document.getElementById('bulkStatus');
      statusEl.textContent = 'Uploading to ' + items.length + ' items...';
      var done = 0, failed = 0;
      function next() {
        if (done + failed >= items.length) {
          statusEl.textContent = 'Done. Updated ' + done + (failed ? ', failed ' + failed : '') + '.';
          document.querySelectorAll('.edit-card.selected .entity-chk').forEach(function(c) { c.checked = false; });
          document.querySelectorAll('.edit-card.selected').forEach(function(c) { c.classList.remove('selected'); });
          updateBulkBar();
          refreshAudit();
          document.getElementById('bulkUploadInput').value = '';
          return;
        }
        var it = items[done + failed];
        fetch('/api/images/' + it.entity + '/' + it.id + '/upload', { method: 'POST', body: file, headers: { 'Content-Type': file.type || 'image/jpeg' } })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.error) throw new Error(data.error);
            done++;
            var thumb = it.card.querySelector('.edit-thumb');
            if (thumb) thumb.src = (it.entity === 'ship' ? '/gallery/image/' : '/gallery/captain/') + it.id + '?v=' + Date.now();
            next();
          })
          .catch(function(e) { failed++; statusEl.textContent = 'Error on ' + it.name + ': ' + e.message; next(); });
      }
      next();
    };

    document.getElementById('bulkDeselectAll').onclick = function() {
      document.querySelectorAll('.edit-card.selected .entity-chk').forEach(function(c) { c.checked = false; });
      document.querySelectorAll('.edit-card.selected').forEach(function(c) { c.classList.remove('selected'); });
      updateBulkBar();
    };

    function openSearchFrame(url) {
      editSearchFrame.src = url;
      editSearchFrame.onload = function() {
        try {
          editSearchFrame.contentWindow.postMessage({ type: 'imageSources', sources: imageSources }, '*');
        } catch (e) { /* cross-origin */ }
      };
    }

    document.getElementById('bulkSearchBtn').onclick = function() {
      var items = getSelectedItems();
      if (items.length === 0) { document.getElementById('bulkStatus').textContent = 'Select at least one item.'; return; }
      bulkModeSelection = items.slice();
      var first = items[0];
      currentEdit = { entity: first.entity, id: first.id, name: first.name, card: first.card };
      editModalTitle.textContent = 'Search image (will apply to ' + items.length + ' selected)';
      editImagePane.style.display = 'none';
      editSearchPane.style.display = 'block';
      var collected = collectKeysFromSources();
      var keys = Object.assign({}, collected.keys, collected.customKeys);
      sessionStorage.setItem('adminImageKeys', JSON.stringify(keys));
      var searchPrefixes = <%- JSON.stringify(typeof imageSearchPrefix !== 'undefined' && imageSearchPrefix ? imageSearchPrefix : { ship: 'battleship', captain: 'captain' }) %>;
      var prefix = searchPrefixes[first.entity] || (first.entity === 'ship' ? 'battleship' : 'captain');
      var q = encodeURIComponent(first.name + ' ' + prefix);
      openSearchFrame('/admin/images/search-frame?entity=' + first.entity + '&id=' + first.id + '&q=' + q);
      new bootstrap.Modal(editModal).show();
    };

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.edit-btn');
      if (!btn) return;
      var card = btn.closest('.edit-card');
      if (!card) return;
      var sel = getSelectedItems();
      if (sel.length > 1 && card.classList.contains('selected')) {
        document.getElementById('bulkEditSelectedBtn').click();
        return;
      }
      bulkModeSelection = [];
      multiEditItems = [];
      document.getElementById('editMultiNav').style.display = 'none';
      currentEdit.entity = card.dataset.entity;
      currentEdit.id = card.dataset.id;
      currentEdit.name = card.dataset.name;
      currentEdit.card = card;
      var img = card.querySelector('.edit-thumb');
      editCurrentImg.src = img.src;
      editModalTitle.textContent = 'Edit: ' + currentEdit.name;
      editImagePane.style.display = 'block';
      editSearchPane.style.display = 'none';
      new bootstrap.Modal(editModal).show();
    });

    var noImagePlaceholder = "data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22120%22%3E%3Crect fill=%22%236c757d%22 width=%22200%22 height=%22120%22/%3E%3Ctext fill=%22%23fff%22 x=%22100%22 y=%2260%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 font-size=%2210%22%3ENo image%3C/text%3E%3C/svg%3E";
    editModal.addEventListener('click', function(e) {
      if (!e.target.closest('#editDeleteBtn')) return;
      var itemsToDelete = multiEditItems.length > 0 ? multiEditItems : (currentEdit.entity && currentEdit.id ? [{ entity: currentEdit.entity, id: currentEdit.id, name: currentEdit.name, card: currentEdit.card }] : []);
      if (itemsToDelete.length === 0) return;
      var msg = itemsToDelete.length > 1
        ? 'Delete cached images for all ' + itemsToDelete.length + ' selected items?'
        : 'Delete cached image for ' + (itemsToDelete[0].name || 'this item') + '?';
      if (!confirm(msg)) return;
      var btn = document.getElementById('editDeleteBtn');
      if (btn) { btn.disabled = true; btn.textContent = 'Deleting...'; }
      var done = 0, failed = 0;
      function deleteNext() {
        if (done + failed >= itemsToDelete.length) {
          var inst = bootstrap.Modal.getInstance(editModal);
          if (inst) inst.hide();
          itemsToDelete.forEach(function(it) {
            if (it.card) {
              var thumb = it.card.querySelector('.edit-thumb');
              if (thumb) thumb.src = noImagePlaceholder;
            }
          });
          document.querySelectorAll('.edit-card.selected .entity-chk').forEach(function(c) { c.checked = false; });
          document.querySelectorAll('.edit-card.selected').forEach(function(c) { c.classList.remove('selected'); });
          updateBulkBar();
          multiEditItems = [];
          editCurrentImg.src = noImagePlaceholder;
          refreshAudit();
          if (btn) { btn.disabled = false; btn.textContent = 'Delete'; }
          return;
        }
        var it = itemsToDelete[done + failed];
        var url = '/api/images/' + it.entity + '/' + it.id;
        fetch(url, { method: 'DELETE' })
          .then(function(r) {
            if (!r.ok) return r.json().then(function(j) { throw new Error(j.error || j.message || 'Delete failed'); });
            return r.json().catch(function() { return {}; });
          })
          .then(function() {
            done++;
            if (it.card) {
              var thumb = it.card.querySelector('.edit-thumb');
              if (thumb) thumb.src = noImagePlaceholder;
            }
            deleteNext();
          })
          .catch(function(err) {
            failed++;
            if (btn) btn.textContent = 'Deleting... (' + done + ' done, ' + failed + ' failed)';
            deleteNext();
          });
      }
      deleteNext();
    });

    document.getElementById('editSearchBackBtn').onclick = function() {
      editSearchFrame.src = 'about:blank';
      editImagePane.style.display = 'block';
      editSearchPane.style.display = 'none';
    };

    document.getElementById('editSearchBtn').onclick = function() {
      if (!currentEdit.entity || !currentEdit.id) return;
      var collected = collectKeysFromSources();
      var keys = Object.assign({}, collected.keys, collected.customKeys);
      sessionStorage.setItem('adminImageKeys', JSON.stringify(keys));
      var searchPrefixes = <%- JSON.stringify(typeof imageSearchPrefix !== 'undefined' && imageSearchPrefix ? imageSearchPrefix : { ship: 'battleship', captain: 'captain' }) %>;
      var prefix = searchPrefixes[currentEdit.entity] || (currentEdit.entity === 'ship' ? 'battleship' : 'captain');
      var q = encodeURIComponent(currentEdit.name + ' ' + prefix);
      openSearchFrame('/admin/images/search-frame?entity=' + currentEdit.entity + '&id=' + currentEdit.id + '&q=' + q);
      editImagePane.style.display = 'none';
      editSearchPane.style.display = 'block';
    };

    function refreshAudit() {
      fetch('/api/images/audit').then(function(r) { return r.json(); })
        .then(function(audit) {
          if (!audit) return;
          function renderEntityBody(ent) {
            if (!ent) return '';
            var html = '<p class="mb-1"><strong>Total:</strong> ' + (ent.total ?? 0) + '</p>';
            html += '<p class="mb-1"><strong>With ImageUrl:</strong> ' + (ent.withImageUrl ?? 0) + '</p>';
            html += '<p class="mb-1"><strong>With ImageData (cached):</strong> ' + (ent.withImageData ?? 0) + '</p>';
            var mu = ent.missingUrl || [];
            if (mu.length > 0) {
              html += '<p class="mb-1 text-warning"><strong>Missing ImageUrl:</strong> ' + mu.length + '</p><ul class="small mb-0">';
              mu.slice(0, 10).forEach(function(m) { html += '<li>' + (m.name || '') + ' (id ' + (m.id || '') + ')</li>'; });
              if (mu.length > 10) html += '<li>... and ' + (mu.length - 10) + ' more</li>';
              html += '</ul>';
            }
            var mc = ent.missingCachedData || [];
            if (mc.length > 0) {
              html += '<p class="mb-1 text-info mt-2"><strong>Has URL but not cached:</strong> ' + mc.length + '</p><ul class="small mb-0">';
              mc.slice(0, 10).forEach(function(m) { html += '<li>' + (m.name || '') + ' (id ' + (m.id || '') + ')</li>'; });
              if (mc.length > 10) html += '<li>... and ' + (mc.length - 10) + ' more</li>';
              html += '</ul>';
            }
            return html;
          }
          var shipsBody = document.getElementById('auditShipsBody');
          var captainsBody = document.getElementById('auditCaptainsBody');
          if (shipsBody) shipsBody.innerHTML = renderEntityBody(audit.ships);
          if (captainsBody) captainsBody.innerHTML = renderEntityBody(audit.captains);
        })
        .catch(function() {});
    }

    function refreshEditImage(entity, entityId) {
      var v = Date.now();
      var imgUrl = (entity === 'ship' ? '/gallery/image/' : '/gallery/captain/') + entityId + '?v=' + v;
      if (currentEdit.card) {
        var thumb = currentEdit.card.querySelector('.edit-thumb');
        if (thumb) thumb.src = imgUrl;
      }
      editCurrentImg.src = imgUrl;
      editSearchFrame.src = 'about:blank';
      editImagePane.style.display = 'block';
      editSearchPane.style.display = 'none';
      refreshAudit();
      var inst = bootstrap.Modal.getInstance(editModal);
      if (inst) inst.hide();
    }
    window.addEventListener('message', function(e) {
      if (!e.data || (e.data.type !== 'imageSelected' && e.data.type !== 'imageUploaded')) return;
      var items = bulkModeSelection.length > 0 ? bulkModeSelection : [currentEdit];
      if (items.length === 0 || !items[0].entity) return;
      if (bulkModeSelection.length === 0 && String(e.data.entityId) !== String(currentEdit.id)) return;
      var url = e.data.url;
      var isUpload = e.data.type === 'imageUploaded';
      if (isUpload && bulkModeSelection.length > 0) {
        var first = bulkModeSelection[0];
        url = window.location.origin + (first.entity === 'ship' ? '/gallery/image/' : '/gallery/captain/') + first.id + '?v=' + Date.now();
        var t0 = first.card && first.card.querySelector('.edit-thumb');
        if (t0) t0.src = (first.entity === 'ship' ? '/gallery/image/' : '/gallery/captain/') + first.id + '?v=' + Date.now();
      }
      if (items.length === 1 && !isUpload) {
        var it = items[0];
        fetch('/api/images/' + it.entity + '/' + it.id + '/from-url', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ url: url }) })
          .then(function(r) {
            if (!r.ok) return r.json().then(function(j) { throw new Error(j.error || j.message || 'Set image failed'); });
            return r.json().catch(function() { return {}; });
          })
          .then(function() { refreshEditImage(it.entity, it.id); })
          .catch(function(err) { alert('Set image failed: ' + err.message); });
        return;
      }
      if (items.length === 1 && isUpload) {
        refreshEditImage(items[0].entity, items[0].id);
        bulkModeSelection = [];
        return;
      }
      var statusEl = document.getElementById('bulkStatus');
      if (statusEl) statusEl.textContent = 'Applying to ' + items.length + ' items...';
      var done = 0, failed = 0;
      function applyNext() {
        if (done + failed >= items.length) {
          editSearchFrame.src = 'about:blank';
          editImagePane.style.display = 'block';
          editSearchPane.style.display = 'none';
          bulkModeSelection.forEach(function(it) {
            var thumb = it.card && it.card.querySelector('.edit-thumb');
            if (thumb) thumb.src = (it.entity === 'ship' ? '/gallery/image/' : '/gallery/captain/') + it.id + '?v=' + Date.now();
          });
          document.querySelectorAll('.edit-card.selected .entity-chk').forEach(function(c) { c.checked = false; });
          document.querySelectorAll('.edit-card.selected').forEach(function(c) { c.classList.remove('selected'); });
          updateBulkBar();
          bulkModeSelection = [];
          refreshAudit();
          var inst = bootstrap.Modal.getInstance(editModal);
          if (inst) inst.hide();
          if (statusEl) statusEl.textContent = 'Done. Updated ' + done + (failed ? ', failed ' + failed : '') + '.';
          return;
        }
        var it = items[done + failed];
        fetch('/api/images/' + it.entity + '/' + it.id + '/from-url', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ url: url }) })
          .then(function(r) {
            if (!r.ok) return r.json().then(function(j) { throw new Error(j.error || j.message); });
            return r.json();
          })
          .then(function() {
            done++;
            var thumb = it.card && it.card.querySelector('.edit-thumb');
            if (thumb) thumb.src = (it.entity === 'ship' ? '/gallery/image/' : '/gallery/captain/') + it.id + '?v=' + Date.now();
            applyNext();
          })
          .catch(function(err) { failed++; applyNext(); });
      }
      applyNext();
    });

    if (editModal) {
      editModal.addEventListener('hidden.bs.modal', function() {
        editSearchFrame.src = 'about:blank';
        editImagePane.style.display = 'block';
        editSearchPane.style.display = 'none';
        document.getElementById('editMultiNav').style.display = 'none';
        multiEditItems = [];
        var db = document.getElementById('editDeleteBtn');
        if (db) { db.disabled = false; db.textContent = 'Delete'; }
      });
    }
