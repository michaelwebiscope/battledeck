<!DOCTYPE html>
<html lang="en">
<head>
  <script>
    (function(){
      function checkAdmin() {
        if (localStorage.getItem('adminMode') !== 'true') location.replace('/');
      }
      checkAdmin();
      window.addEventListener('adminModeChanged', function(e) {
        if (!e.detail || !e.detail.enabled) location.replace('/');
      });
    })();
  </script>
  <%- include('partials/head') %>
  <style>
    .audit-page .card, .audit-page .card-header, .audit-page .card-body { color: var(--text); }
    .edit-card {
      width: 140px; border-radius: 10px; overflow: hidden;
      background: white; border: 2px solid rgba(12, 74, 110, 0.2);
      box-shadow: 0 2px 8px rgba(12, 74, 110, 0.1);
      cursor: grab; transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
    }
    .edit-card:hover { transform: translateY(-4px); box-shadow: 0 8px 20px rgba(12, 74, 110, 0.18); }
    .edit-card.dragging {
      cursor: grabbing;
      position: relative;
      transform: scale(1.06) translateY(-14px) rotate(-1deg);
      box-shadow: 0 16px 32px rgba(0,0,0,0.25), 0 0 0 1px rgba(2, 132, 199, 0.3);
      z-index: 100;
      transition: transform 0.15s ease-out, box-shadow 0.15s ease-out;
    }
    .edit-card.drag-over { outline: 2px dashed var(--blue); outline-offset: 4px; }
    .edit-card.selected { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.4); }
    .edit-card .img-wrap { width: 100%; height: 90px; overflow: hidden; border-radius: 8px 8px 0 0; background: #e9ecef; }
    .edit-card .edit-thumb { width: 100%; height: 100%; object-fit: cover; display: block; vertical-align: top; }
    .edit-info { padding: 8px 10px; background: #f8fafc; }
    .edit-name { font-size: 0.85rem; font-weight: 500; color: var(--blue-deep); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .edit-actions { display: flex; gap: 6px; align-items: center; margin-top: 6px; }
    .edit-card .entity-chk { margin-right: 4px; cursor: pointer; }
    .edit-card .btn { font-size: 0.75rem; }
    .bulk-bar {
      padding: 14px; background: linear-gradient(135deg, rgba(12, 74, 110, 0.08) 0%, rgba(6, 182, 212, 0.06) 100%);
      border-radius: 12px; border: 1px solid rgba(12, 74, 110, 0.2); margin-bottom: 12px;
    }
    .bulk-bar .form-control { max-width: 320px; display: inline-block; }
    .bulk-bar input[type="file"] { display: none; }
    .bulk-bar strong, .bulk-bar label { color: var(--text); }
    .image-sources-details .list-group-item { color: var(--text); background: white; }
    #imageSourcesList .list-group-item { background: #f8fafc; color: var(--blue-deep); }
    .modal-content.bg-dark { background: linear-gradient(135deg, var(--blue-deep) 0%, var(--blue) 100%) !important; }
    .modal-content.bg-dark .form-control { background: rgba(255,255,255,0.1); color: white; border-color: rgba(255,255,255,0.3); }
    .modal-content.bg-dark .form-control::placeholder { color: rgba(255,255,255,0.5); }
    .modal-content.bg-dark .form-label { color: rgba(255,255,255,0.9); }
    #editImagePane .multi-edit-nav { display: flex; gap: 8px; align-items: center; margin-bottom: 12px; }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell audit-page">
    <div class="container py-4">
      <%
        var shipType = typeof entityTypes !== 'undefined' && entityTypes.ship ? entityTypes.ship : { pluralName: 'Ships' };
        var captainType = typeof entityTypes !== 'undefined' && entityTypes.captain ? entityTypes.captain : { pluralName: 'Captains' };
      %>
      <h1 class="mb-4">Image Audit</h1>
      <p class="text-muted mb-4">Index of <%= (shipType.pluralName || 'ships').toLowerCase() %> and <%= (captainType.pluralName || 'captains').toLowerCase() %>: which have ImageUrl, which have cached ImageData in the database, and which are missing. <strong>Populate</strong> uses the Java ImagePopulator stream to fetch and store images (Pexels → Pixabay → Unsplash → Google, or Wikipedia-only mode). All operations are manual to save API calls. Use <strong>Wikipedia</strong> in the Search provider to manually pick a Wikipedia page and fetch its image.</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <% if (audit) { %>
        <div class="row g-4 mb-4" id="auditSection">
          <div class="col-md-6">
            <div class="card">
              <div class="card-header"><%= shipType.pluralName || 'Ships' %></div>
              <div class="card-body" id="auditShipsBody">
                <p class="mb-1"><strong>Total:</strong> <span id="auditShipsTotal"><%= audit.ships?.total ?? 0 %></span></p>
                <p class="mb-1"><strong>With ImageUrl:</strong> <span id="auditShipsWithUrl"><%= audit.ships?.withImageUrl ?? 0 %></span></p>
                <p class="mb-1"><strong>With ImageData (cached):</strong> <span id="auditShipsWithData"><%= audit.ships?.withImageData ?? 0 %></span></p>
                <% if (audit.ships?.missingUrl && audit.ships.missingUrl.length > 0) { %>
                  <p class="mb-1 text-warning"><strong>Missing ImageUrl:</strong> <span id="auditShipsMissingUrlCount"><%= audit.ships.missingUrl.length %></span></p>
                  <ul class="small mb-0" id="auditShipsMissingUrlList">
                    <% audit.ships.missingUrl.slice(0, 10).forEach(function(m) { %><li><%= m.name %> (id <%= m.id %>)</li><% }); %>
                    <% if (audit.ships.missingUrl.length > 10) { %><li>... and <%= audit.ships.missingUrl.length - 10 %> more</li><% } %>
                  </ul>
                <% } %>
                <% if (audit.ships?.missingCachedData && audit.ships.missingCachedData.length > 0) { %>
                  <p class="mb-1 text-info mt-2"><strong>Has URL but not cached:</strong> <span id="auditShipsMissingCachedCount"><%= audit.ships.missingCachedData.length %></span></p>
                  <ul class="small mb-0" id="auditShipsMissingCachedList">
                    <% audit.ships.missingCachedData.slice(0, 10).forEach(function(m) { %><li><%= m.name %> (id <%= m.id %>)</li><% }); %>
                    <% if (audit.ships.missingCachedData.length > 10) { %><li>... and <%= audit.ships.missingCachedData.length - 10 %> more</li><% } %>
                  </ul>
                <% } %>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card">
              <div class="card-header"><%= captainType.pluralName || 'Captains' %></div>
              <div class="card-body" id="auditCaptainsBody">
                <p class="mb-1"><strong>Total:</strong> <span id="auditCaptainsTotal"><%= audit.captains?.total ?? 0 %></span></p>
                <p class="mb-1"><strong>With ImageUrl:</strong> <span id="auditCaptainsWithUrl"><%= audit.captains?.withImageUrl ?? 0 %></span></p>
                <p class="mb-1"><strong>With ImageData (cached):</strong> <span id="auditCaptainsWithData"><%= audit.captains?.withImageData ?? 0 %></span></p>
                <% if (audit.captains?.missingUrl && audit.captains.missingUrl.length > 0) { %>
                  <p class="mb-1 text-warning"><strong>Missing ImageUrl:</strong> <span id="auditCaptainsMissingUrlCount"><%= audit.captains.missingUrl.length %></span></p>
                  <ul class="small mb-0" id="auditCaptainsMissingUrlList">
                    <% audit.captains.missingUrl.slice(0, 10).forEach(function(m) { %><li><%= m.name %> (id <%= m.id %>)</li><% }); %>
                    <% if (audit.captains.missingUrl.length > 10) { %><li>... and <%= audit.captains.missingUrl.length - 10 %> more</li><% } %>
                  </ul>
                <% } %>
                <% if (audit.captains?.missingCachedData && audit.captains.missingCachedData.length > 0) { %>
                  <p class="mb-1 text-info mt-2"><strong>Has URL but not cached:</strong> <span id="auditCaptainsMissingCachedCount"><%= audit.captains.missingCachedData.length %></span></p>
                  <ul class="small mb-0" id="auditCaptainsMissingCachedList">
                    <% audit.captains.missingCachedData.slice(0, 10).forEach(function(m) { %><li><%= m.name %> (id <%= m.id %>)</li><% }); %>
                    <% if (audit.captains.missingCachedData.length > 10) { %><li>... and <%= audit.captains.missingCachedData.length - 10 %> more</li><% } %>
                  </ul>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        <div class="mb-4">
          <details class="mb-3" id="imageSourcesDetails" open>
            <summary class="text-muted small" style="cursor: pointer">Image Sources: order, retry count, API keys, custom APIs</summary>
            <div class="mt-2">
              <p class="small text-muted mb-2">Drag to reorder. Set retries and API keys per source. Delete with ×. Add custom APIs with +.</p>
              <ul id="imageSourcesList" class="list-group list-group-flush mb-2" style="max-height: 360px; overflow-y: auto;"></ul>
              <button type="button" id="addCustomSourceBtn" class="btn btn-sm btn-modern">+ Add Custom API</button>
              <button type="button" id="saveSourcesBtn" class="btn btn-sm btn-modern ms-2">Save Sources</button>
              <span id="sourcesSaveStatus" class="ms-2 small"></span>
            </div>
          </details>
          <button id="populateBtn" class="btn btn-modern">Populate All Images (Java stream → store)</button>
          <button id="populateWikipediaBtn" class="btn btn-modern ms-2" title="Trigger the Java ImagePopulator: API calls Java listener to fetch ship images from Wikipedia and upload to API">Populate from Wikipedia (Java)</button>
          <button id="testTerminalBtn" class="btn btn-outline-secondary ms-2" title="Test that the terminal updates in real-time">Test Terminal</button>
          <button id="testKeysBtn" class="btn btn-outline-secondary ms-2" title="Validate API keys and show failures">Test Keys</button>
          <span id="populateStatus" class="ms-3"></span>
        </div>
        <div class="mb-4">
          <label class="mb-0 align-middle">
            <input type="checkbox" id="disableDotNetFetchChk" class="form-check-input me-1" <%= imageFetchMode && imageFetchMode.disableDotNetImageFetch ? 'checked' : '' %>>
            Java-only image mode (disable .NET URL image fetching across website)
          </label>
          <span id="fetchModeStatus" class="ms-2 small text-muted"></span>
        </div>
        <div class="mb-4">
          <button id="verifyBtn" class="btn btn-outline-dark">Verify Images (check which fail to load)</button>
          <span id="verifyStatus" class="ms-3"></span>
        </div>
        <div class="mb-4">
          <h5 class="mb-3">Edit Images</h5>
          <p class="text-muted small mb-3">Select multiple items (Shift+click for range), then add an image (URL, upload, or search) to apply to all. Drag cards to reorder. Or click Edit for a single item.</p>
          <div id="bulkBar" class="bulk-bar" style="display: none;">
            <span class="me-2"><strong id="bulkCount">0</strong> selected</span>
            <button type="button" class="btn btn-sm btn-link text-muted p-0 me-2" id="bulkDeselectAll">Deselect all</button>
            <button type="button" class="btn btn-sm btn-modern me-2" id="bulkEditSelectedBtn">Edit selected</button>
            <button type="button" class="btn btn-sm btn-outline-primary me-2" id="bulkPopulateBtn" title="Populate cached images for selected items using the Java ImagePopulator">Populate</button>
            <button type="button" class="btn btn-sm btn-outline-danger me-2" id="bulkForcePopulateBtn" title="Force refresh: delete cached image first, then populate">Force populate</button>
            <input type="text" id="bulkUrlInput" class="form-control form-control-sm me-2" placeholder="Paste image URL">
            <button type="button" class="btn btn-sm btn-modern me-2" id="bulkApplyUrlBtn">Apply URL to selected</button>
            <label class="btn btn-sm btn-outline-primary me-2 mb-0" for="bulkUploadInput" style="cursor:pointer">Upload & apply</label>
            <input type="file" id="bulkUploadInput" accept="image/*">
            <button type="button" class="btn btn-sm btn-outline-primary" id="bulkSearchBtn">Search & apply</button>
            <span id="bulkStatus" class="ms-2 small"></span>
          </div>
          <div class="row g-3">
            <div class="col-12">
              <h6 class="text-muted mb-2"><%= shipType.pluralName || 'Ships' %></h6>
              <div class="d-flex flex-wrap gap-2" id="shipsEditGrid">
                <% (ships || []).forEach(function(s) { %>
                  <div class="edit-card" data-entity="ship" data-id="<%= s.id || s.Id %>" data-name="<%= s.name || s.Name %>">
                    <div class="img-wrap">
                      <img src="/gallery/image/<%= s.id || s.Id %>?v=<%= (s.imageVersion != null ? s.imageVersion : s.ImageVersion) || 0 %>" alt="" class="edit-thumb" loading="lazy" onerror="this.onerror=null;this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22140%22 height=%2290%22 viewBox=%220 0 140 90%22%3E%3Crect fill=%22%236c757d%22 width=%22140%22 height=%2290%22/%3E%3Ctext fill=%22%23fff%22 x=%2270%22 y=%2245%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 font-size=%2210%22%3ENo image%3C/text%3E%3C/svg%3E';">
                    </div>
                    <div class="edit-info">
                      <span class="edit-name"><%= s.name || s.Name %></span>
                      <div class="edit-actions mt-1">
                        <input type="checkbox" class="entity-chk form-check-input" title="Select for bulk edit">
                        <button type="button" class="btn btn-sm btn-outline-primary edit-btn">Edit</button>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            </div>
            <div class="col-12">
              <h6 class="text-muted mb-2"><%= captainType.pluralName || 'Captains' %></h6>
              <div class="d-flex flex-wrap gap-2" id="captainsEditGrid">
                <% (captains || []).forEach(function(c) { %>
                  <div class="edit-card" data-entity="captain" data-id="<%= c.id || c.Id %>" data-name="<%= c.name || c.Name %>">
                    <div class="img-wrap">
                      <img src="/gallery/captain/<%= c.id || c.Id %>?v=<%= (c.imageVersion != null ? c.imageVersion : c.ImageVersion) || 0 %>" alt="" class="edit-thumb" loading="lazy" onerror="this.onerror=null;this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22140%22 height=%2290%22 viewBox=%220 0 140 90%22%3E%3Crect fill=%22%236c757d%22 width=%22140%22 height=%2290%22/%3E%3Ctext fill=%22%23fff%22 x=%2270%22 y=%2245%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 font-size=%2210%22%3ENo image%3C/text%3E%3C/svg%3E';">
                    </div>
                    <div class="edit-info">
                      <span class="edit-name"><%= c.name || c.Name %></span>
                      <div class="edit-actions mt-1">
                        <input type="checkbox" class="entity-chk form-check-input" title="Select for bulk edit">
                        <button type="button" class="btn btn-sm btn-outline-primary edit-btn">Edit</button>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
        </div>
        <div id="terminalOutput" class="card mb-4" style="display: none;">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span>Terminal Output</span>
            <div>
              <button type="button" class="btn btn-sm btn-outline-light me-1" id="terminalCopy">Copy</button>
              <button type="button" class="btn btn-sm btn-outline-light" id="terminalClear">Clear</button>
            </div>
          </div>
          <div class="card-body p-0">
            <pre id="terminalPre" class="mb-0 p-3 bg-dark text-light font-monospace small" style="max-height: 70vh; overflow-y: auto; white-space: pre-wrap; word-break: break-all;"><span id="terminalContent"></span></pre>
          </div>
        </div>
        <div id="verifyResults" class="card mb-4" style="display: none;">
          <div class="card-header">Verification Results</div>
          <div class="card-body">
            <p class="mb-1"><strong>Total ships:</strong> <span id="verifyTotal">0</span></p>
            <p class="mb-1"><strong>With working images:</strong> <span id="verifyWithImages" class="text-success">0</span></p>
            <p class="mb-2"><strong>Missing / broken images:</strong> <span id="verifyMissing" class="text-danger">0</span></p>
            <ul id="verifyMissingList" class="small mb-0 list-unstyled"></ul>
          </div>
        </div>
      <% } else { %>
        <div class="alert alert-warning">No audit data. Ensure the API is running.</div>
      <% } %>

      <div id="customSourceModal" class="modal fade" tabindex="-1">
        <div class="modal-dialog modal-lg">
          <div class="modal-content bg-dark text-light">
            <div class="modal-header">
              <h5 class="modal-title">Add Custom API Source</h5>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="mb-2">
                <label class="form-label small">Name</label>
                <input type="text" id="customSourceName" class="form-control form-control-sm" placeholder="My API">
              </div>
              <div class="mb-2">
                <label class="form-label small">Base URL</label>
                <input type="text" id="customSourceBaseUrl" class="form-control form-control-sm" placeholder="https://api.example.com/search">
              </div>
              <div class="mb-2">
                <label class="form-label small">Query parameter name</label>
                <input type="text" id="customSourceQueryParam" class="form-control form-control-sm" placeholder="q" value="q">
              </div>
              <div class="mb-2">
                <label class="form-label small">Auth type</label>
                <select id="customSourceAuthType" class="form-select form-select-sm">
                  <option value="none">None</option>
                  <option value="header">Header</option>
                  <option value="query">Query param</option>
                </select>
              </div>
              <div class="mb-2" id="customAuthHeaderRow" style="display:none">
                <label class="form-label small">Auth header name</label>
                <input type="text" id="customSourceAuthHeaderName" class="form-control form-control-sm" placeholder="Authorization">
              </div>
              <div class="mb-2" id="customAuthQueryRow" style="display:none">
                <label class="form-label small">Auth query param name</label>
                <input type="text" id="customSourceAuthQueryParam" class="form-control form-control-sm" placeholder="key">
              </div>
              <div class="mb-2" id="customAuthKeyRefRow" style="display:none">
                <label class="form-label small">Auth value from key (e.g. CUSTOM_API_KEY)</label>
                <input type="text" id="customSourceAuthValueFromKey" class="form-control form-control-sm" placeholder="CUSTOM_API_KEY">
              </div>
              <div class="mb-2">
                <label class="form-label small">Response path to results array (e.g. photos, hits, data.results)</label>
                <input type="text" id="customSourceResponsePath" class="form-control form-control-sm" placeholder="photos">
              </div>
              <div class="mb-2">
                <label class="form-label small">Image URL path in each item (e.g. src.large, urls.regular)</label>
                <input type="text" id="customSourceImageUrlPath" class="form-control form-control-sm" placeholder="src.large">
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="button" id="customSourceSaveBtn" class="btn btn-modern">Add Source</button>
            </div>
          </div>
        </div>
      </div>
      <div id="editImageModal" class="modal fade" tabindex="-1">
        <div class="modal-dialog modal-lg">
          <div class="modal-content bg-dark text-light">
            <div class="modal-header">
              <h5 class="modal-title" id="editModalTitle">Edit Image</h5>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div id="editImagePane">
                <div id="editMultiNav" class="multi-edit-nav" style="display: none;">
                  <button type="button" class="btn btn-sm btn-outline-light" id="editPrevBtn">← Prev</button>
                  <span id="editMultiProgress" class="text-light">1 of 3</span>
                  <button type="button" class="btn btn-sm btn-outline-light" id="editNextBtn">Next →</button>
                </div>
                <div class="mb-3">
                  <img id="editCurrentImg" src="" alt="" class="img-fluid rounded" style="max-height: 200px;">
                </div>
                <div class="d-flex gap-2">
                  <button type="button" class="btn btn-outline-danger" id="editDeleteBtn">Delete</button>
                  <button type="button" class="btn btn-modern" id="editSearchBtn">Search</button>
                </div>
              </div>
              <div id="editSearchPane" style="display: none;">
                <button type="button" class="btn btn-outline-secondary btn-sm mb-2" id="editSearchBackBtn">← Back</button>
                <iframe id="editSearchFrame" src="" style="width:100%; height: 400px; border: 1px solid #444; border-radius: 6px;"></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <% if (audit) { %>
  <script>
    var imageSources = <%- JSON.stringify(Array.isArray(imageSources) ? imageSources : []) %>;
    var imageFetchMode = <%- JSON.stringify(imageFetchMode && imageFetchMode.disableDotNetImageFetch === true ? { disableDotNetImageFetch: true } : { disableDotNetImageFetch: false }) %>;

    function getKeyInputsForSource(s) {
      var html = '';
      if (s.providerType === 'Google') {
        html += '<input type="password" class="form-control form-control-sm source-key-input" style="width:100px" data-key="GOOGLE_API_KEY" placeholder="API key" autocomplete="off">';
        html += '<input type="password" class="form-control form-control-sm source-key-input" style="width:90px" data-key="GOOGLE_CSE_ID" placeholder="CSE ID" autocomplete="off">';
      } else if (s.authKeyRef) {
        var ph = (s.authKeyRef || '').replace(/_/g, ' ').toLowerCase();
        html += '<input type="password" class="form-control form-control-sm source-key-input" style="width:120px" data-key="' + s.authKeyRef + '" placeholder="' + ph + '" autocomplete="off">';
      }
      return html;
    }

    function collectKeysFromSources() {
      var keys = { pexelsApiKey: null, pixabayApiKey: null, unsplashAccessKey: null, googleApiKey: null, googleCseId: null };
      var custom = {};
      document.querySelectorAll('.source-key-input').forEach(function(inp) {
        var k = inp.dataset.key;
        var v = inp.value?.trim();
        if (!v) return;
        if (k === 'PEXELS_API_KEY') keys.pexelsApiKey = v;
        else if (k === 'PIXABAY_API_KEY') keys.pixabayApiKey = v;
        else if (k === 'UNSPLASH_ACCESS_KEY') keys.unsplashAccessKey = v;
        else if (k === 'GOOGLE_API_KEY') keys.googleApiKey = v;
        else if (k === 'GOOGLE_CSE_ID') keys.googleCseId = v;
        else custom[k] = v;
      });
      return { keys: keys, customKeys: custom };
    }

    function renderImageSourcesList() {
      var list = document.getElementById('imageSourcesList');
      if (!list) return;
      list.innerHTML = '';
      var sorted = imageSources.slice().sort(function(a,b){ return (a.sortOrder||0) - (b.sortOrder||0); });
      sorted.forEach(function(s, i) {
        s.sortOrder = i;
        var li = document.createElement('li');
        li.className = 'list-group-item bg-dark text-light d-flex flex-wrap align-items-center gap-2 py-2';
        li.dataset.id = s.id;
        li.draggable = true;
        var keyInputs = getKeyInputsForSource(s);
        li.innerHTML = '<span class="drag-handle text-muted" style="cursor:grab">⋮⋮</span>' +
          '<span style="min-width:90px">' + (s.name || s.id) + '</span>' +
          '<label class="small mb-0">Retries:</label>' +
          '<input type="number" class="form-control form-control-sm" style="width:50px" min="1" max="5" value="' + (s.retryCount||2) + '" data-source-id="' + s.id + '" data-field="retryCount">' +
          (keyInputs ? '<span class="d-flex gap-1 align-items-center">' + keyInputs + '</span>' : '') +
          '<button type="button" class="btn btn-sm btn-outline-danger remove-source-btn ms-auto" data-id="' + s.id + '" title="Delete source">×</button>';
        list.appendChild(li);
      });
      list.querySelectorAll('input[data-field="retryCount"]').forEach(function(inp) {
        inp.onchange = function() {
          var src = imageSources.find(function(s){ return s.id === inp.dataset.sourceId; });
          if (src) src.retryCount = parseInt(inp.value, 10) || 2;
        };
      });
      list.querySelectorAll('.remove-source-btn').forEach(function(btn) {
        btn.onclick = function() {
          if (!confirm('Delete this source?')) return;
          imageSources = imageSources.filter(function(s){ return s.id !== btn.dataset.id; });
          renderImageSourcesList();
        };
      });
      list.querySelectorAll('li').forEach(function(li, idx) {
        li.ondragstart = function(e) { e.dataTransfer.setData('text/plain', idx); };
        li.ondragover = function(e) { e.preventDefault(); li.classList.add('border-primary'); };
        li.ondragleave = function() { li.classList.remove('border-primary'); };
        li.ondrop = function(e) {
          e.preventDefault();
          li.classList.remove('border-primary');
          var from = parseInt(e.dataTransfer.getData('text/plain'), 10);
          if (isNaN(from)) return;
          var arr = imageSources.slice().sort(function(a,b){ return (a.sortOrder||0) - (b.sortOrder||0); });
          var item = arr.splice(from, 1)[0];
          if (!item) return;
          arr.splice(idx, 0, item);
          arr.forEach(function(s, i){ s.sortOrder = i; });
          imageSources = arr;
          renderImageSourcesList();
        };
      });
    }

