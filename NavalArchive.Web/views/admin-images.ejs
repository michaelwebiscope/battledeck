    document.getElementById('populateBtn').onclick = function() {
      var btn = this, status = document.getElementById('populateStatus');
      btn.disabled = true;
      status.textContent = 'Starting Java stream populate...';
      var startTime = Date.now();
      showTerminal('[Populate] ' + new Date().toISOString() + '\n[Populate] Starting Java stream populate (no .NET sync).\n[Populate] This may take several minutes.', true);
      var body = { runSyncFirst: false, usePolling: true };
      var collected = collectKeysFromSources();
      Object.assign(body, collected.keys);
      if (Object.keys(collected.customKeys).length > 0) body.customKeys = collected.customKeys;
      var searchPrefixes = <%- JSON.stringify(typeof imageSearchPrefix !== 'undefined' && imageSearchPrefix ? imageSearchPrefix : { ship: 'battleship', captain: 'captain' }) %>;
      body.shipSearchPrefix = searchPrefixes.ship || 'battleship';
      body.captainSearchPrefix = searchPrefixes.captain || 'captain';
      if (imageSources && imageSources.length > 0) body.imageSources = imageSources;
      fetch('/admin/images/populate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.jobId) {
            runPollingFlow(d.jobId, status, btn, '[Populate] Step 1: Connecting to Java ImagePopulator stream...');
            return { stream: true };
          }
          return { stream: false, data: d };
        })
        .then(function(result) {
          if (result && result.stream) return;
          var d = result.data;
          var elapsed = ((Date.now() - startTime) / 1000).toFixed(1);
          var lines = (d.logLines || []).slice();
          if (lines.length === 0) {
            lines.push('[Populate] Sync phase: ' + (d.syncLog || 'completed'));
          }
          lines.push('');
          lines.push('[Populate] Step 2: Fetching and storing images...');
          (d.shipResults || []).forEach(function(r) {
            var tag = r.status === 'ok' ? 'OK' : 'Fail';
            var suffix = r.reason ? ' - ' + r.reason : '';
            var bytes = r.bytesStored ? ' (' + r.bytesStored + ' bytes)' : '';
            lines.push('  [Ship ' + r.index + '/' + r.total + '] ' + tag + ': ' + r.name + ' (id ' + r.id + ')' + bytes + suffix);
          });
          if ((d.captainResults || []).length > 0) {
            lines.push('');
            lines.push('[Captains]');
            (d.captainResults || []).forEach(function(r) {
              var tag = r.status === 'ok' ? 'OK' : 'Fail';
              var suffix = r.reason ? ' - ' + r.reason : '';
              var bytes = r.bytesStored ? ' (' + r.bytesStored + ' bytes)' : '';
              lines.push('  [Captain ' + r.index + '/' + r.total + '] ' + tag + ': ' + r.name + ' (id ' + r.id + ')' + bytes + suffix);
            });
          }
          lines.push('');
          lines.push('[Populate] Done in ' + elapsed + 's. Stored ' + (d.shipsStored || 0) + ' ships, ' + (d.captainsStored || 0) + ' captains.');
          lines.push('[Populate] Refresh the page to see updated audit stats.');
          showTerminal(lines);
          status.textContent = 'Done. Stored ' + (d.shipsStored || 0) + ' ships, ' + (d.captainsStored || 0) + ' captains.';
          btn.disabled = false;
        })
        .catch(function(e) {
          showTerminal('[Populate] Error: ' + e.message);
          status.textContent = 'Error: ' + e.message;
          btn.disabled = false;
        });
    };
