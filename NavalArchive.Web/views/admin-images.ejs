<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <h1 class="mb-4">Image Audit</h1>
      <p class="text-muted mb-4">Index of ships and captains: which have ImageUrl, which have cached ImageData in the database, and which are missing. Populate runs Wikipedia sync first (to get captain ImageUrls), then fetches images. Fallback order: Pexels → Pixabay → Unsplash → Google. Set <code>PEXELS_API_KEY</code>, <code>PIXABAY_API_KEY</code>, <code>UNSPLASH_ACCESS_KEY</code>, or <code>GOOGLE_API_KEY</code>+<code>GOOGLE_CSE_ID</code> on the API.</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <% if (audit) { %>
        <div class="row g-4 mb-4">
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">Ships</div>
              <div class="card-body">
                <p class="mb-1"><strong>Total:</strong> <%= audit.ships?.total ?? 0 %></p>
                <p class="mb-1"><strong>With ImageUrl:</strong> <%= audit.ships?.withImageUrl ?? 0 %></p>
                <p class="mb-1"><strong>With ImageData (cached):</strong> <%= audit.ships?.withImageData ?? 0 %></p>
                <% if (audit.ships?.missingUrl && audit.ships.missingUrl.length > 0) { %>
                  <p class="mb-1 text-warning"><strong>Missing ImageUrl:</strong> <%= audit.ships.missingUrl.length %></p>
                  <ul class="small mb-0">
                    <% audit.ships.missingUrl.slice(0, 10).forEach(function(m) { %>
                      <li><%= m.name %> (id <%= m.id %>)</li>
                    <% }); %>
                    <% if (audit.ships.missingUrl.length > 10) { %><li>... and <%= audit.ships.missingUrl.length - 10 %> more</li><% } %>
                  </ul>
                <% } %>
                <% if (audit.ships?.missingCachedData && audit.ships.missingCachedData.length > 0) { %>
                  <p class="mb-1 text-info mt-2"><strong>Has URL but not cached:</strong> <%= audit.ships.missingCachedData.length %></p>
                  <ul class="small mb-0">
                    <% audit.ships.missingCachedData.slice(0, 10).forEach(function(m) { %>
                      <li><%= m.name %> (id <%= m.id %>)</li>
                    <% }); %>
                    <% if (audit.ships.missingCachedData.length > 10) { %><li>... and <%= audit.ships.missingCachedData.length - 10 %> more</li><% } %>
                  </ul>
                <% } %>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">Captains</div>
              <div class="card-body">
                <p class="mb-1"><strong>Total:</strong> <%= audit.captains?.total ?? 0 %></p>
                <p class="mb-1"><strong>With ImageUrl:</strong> <%= audit.captains?.withImageUrl ?? 0 %></p>
                <p class="mb-1"><strong>With ImageData (cached):</strong> <%= audit.captains?.withImageData ?? 0 %></p>
                <% if (audit.captains?.missingUrl && audit.captains.missingUrl.length > 0) { %>
                  <p class="mb-1 text-warning"><strong>Missing ImageUrl:</strong> <%= audit.captains.missingUrl.length %></p>
                  <ul class="small mb-0">
                    <% audit.captains.missingUrl.slice(0, 10).forEach(function(m) { %>
                      <li><%= m.name %> (id <%= m.id %>)</li>
                    <% }); %>
                    <% if (audit.captains.missingUrl.length > 10) { %><li>... and <%= audit.captains.missingUrl.length - 10 %> more</li><% } %>
                  </ul>
                <% } %>
                <% if (audit.captains?.missingCachedData && audit.captains.missingCachedData.length > 0) { %>
                  <p class="mb-1 text-info mt-2"><strong>Has URL but not cached:</strong> <%= audit.captains.missingCachedData.length %></p>
                  <ul class="small mb-0">
                    <% audit.captains.missingCachedData.slice(0, 10).forEach(function(m) { %>
                      <li><%= m.name %> (id <%= m.id %>)</li>
                    <% }); %>
                    <% if (audit.captains.missingCachedData.length > 10) { %><li>... and <%= audit.captains.missingCachedData.length - 10 %> more</li><% } %>
                  </ul>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        <div class="mb-4">
          <button id="populateBtn" class="btn btn-modern">Populate All Images (sync + fetch → store)</button>
          <span id="populateStatus" class="ms-3"></span>
        </div>
        <div class="mb-4">
          <button id="verifyBtn" class="btn btn-outline-dark">Verify Images (check which fail to load)</button>
          <span id="verifyStatus" class="ms-3"></span>
        </div>
        <div id="terminalOutput" class="card mb-4" style="display: none;">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span>Terminal Output</span>
            <div>
              <button type="button" class="btn btn-sm btn-outline-light me-1" id="terminalCopy">Copy</button>
              <button type="button" class="btn btn-sm btn-outline-light" id="terminalClear">Clear</button>
            </div>
          </div>
          <div class="card-body p-0">
            <pre id="terminalPre" class="mb-0 p-3 bg-dark text-light font-monospace small" style="max-height: 400px; overflow-y: auto; white-space: pre-wrap; word-break: break-all;"><span id="terminalContent"></span></pre>
          </div>
        </div>
        <div id="verifyResults" class="card mb-4" style="display: none;">
          <div class="card-header">Verification Results</div>
          <div class="card-body">
            <p class="mb-1"><strong>Total ships:</strong> <span id="verifyTotal">0</span></p>
            <p class="mb-1"><strong>With working images:</strong> <span id="verifyWithImages" class="text-success">0</span></p>
            <p class="mb-2"><strong>Missing / broken images:</strong> <span id="verifyMissing" class="text-danger">0</span></p>
            <ul id="verifyMissingList" class="small mb-0 list-unstyled"></ul>
          </div>
        </div>
      <% } else { %>
        <div class="alert alert-warning">No audit data. Ensure the API is running.</div>
      <% } %>
    </div>
  </main>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <% if (audit) { %>
  <script>
    function showTerminal(lines, showPanel) {
      var pre = document.getElementById('terminalPre');
      var content = document.getElementById('terminalContent');
      var panel = document.getElementById('terminalOutput');
      content.textContent = Array.isArray(lines) ? lines.join('\n') : lines;
      panel.style.display = 'block';
      pre.scrollTop = pre.scrollHeight;
      if (showPanel !== false) panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    document.getElementById('terminalCopy').onclick = function() {
      var text = document.getElementById('terminalContent').textContent;
      navigator.clipboard.writeText(text).then(function() {
        this.textContent = 'Copied!';
        var btn = this;
        setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
      }.bind(this));
    };
    document.getElementById('terminalClear').onclick = function() {
      document.getElementById('terminalContent').textContent = '';
    };
    document.getElementById('populateBtn').onclick = function() {
      var btn = this, status = document.getElementById('populateStatus');
      btn.disabled = true;
      status.textContent = 'Syncing & populating...';
      var startTime = Date.now();
      showTerminal('[Populate] ' + new Date().toISOString() + '\n[Populate] Step 1: Running Wikipedia sync to fetch captain ImageUrls...\n[Populate] This may take several minutes.', true);
      fetch('/admin/images/populate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ runSyncFirst: true }) })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          var elapsed = ((Date.now() - startTime) / 1000).toFixed(1);
          var lines = (d.logLines || []).slice();
          if (lines.length === 0) {
            lines.push('[Populate] Sync phase: ' + (d.syncLog || 'completed'));
          }
          lines.push('');
          lines.push('[Populate] Step 2: Fetching and storing images...');
          (d.shipResults || []).forEach(function(r) {
            var tag = r.status === 'ok' ? 'OK' : 'Fail';
            var suffix = r.reason ? ' - ' + r.reason : '';
            var bytes = r.bytesStored ? ' (' + r.bytesStored + ' bytes)' : '';
            lines.push('  [Ship ' + r.index + '/' + r.total + '] ' + tag + ': ' + r.name + ' (id ' + r.id + ')' + bytes + suffix);
          });
          if ((d.captainResults || []).length > 0) {
            lines.push('');
            lines.push('[Captains]');
            (d.captainResults || []).forEach(function(r) {
              var tag = r.status === 'ok' ? 'OK' : 'Fail';
              var suffix = r.reason ? ' - ' + r.reason : '';
              var bytes = r.bytesStored ? ' (' + r.bytesStored + ' bytes)' : '';
              lines.push('  [Captain ' + r.index + '/' + r.total + '] ' + tag + ': ' + r.name + ' (id ' + r.id + ')' + bytes + suffix);
            });
          }
          lines.push('');
          lines.push('[Populate] Done in ' + elapsed + 's. Stored ' + (d.shipsStored || 0) + ' ships, ' + (d.captainsStored || 0) + ' captains.');
          lines.push('[Populate] Refresh the page to see updated audit stats.');
          showTerminal(lines);
          status.textContent = 'Done. Stored ' + (d.shipsStored || 0) + ' ships, ' + (d.captainsStored || 0) + ' captains.';
          btn.disabled = false;
        })
        .catch(function(e) {
          showTerminal('[Populate] Error: ' + e.message);
          status.textContent = 'Error: ' + e.message;
          btn.disabled = false;
        });
    };
    document.getElementById('verifyBtn').onclick = function() {
      var btn = this, status = document.getElementById('verifyStatus'), results = document.getElementById('verifyResults');
      btn.disabled = true;
      status.textContent = 'Verifying... (this may take ~1 min)';
      results.style.display = 'none';
      showTerminal('[Verify] Checking which ship images load...\n[Verify] Requesting each /gallery/image/:id...', true);
      fetch('/admin/images/verify')
        .then(function(r) { return r.json(); })
        .then(function(d) {
          var lines = ['[Verify] Total ships: ' + (d.total || 0)];
          lines.push('[Verify] With working images: ' + (d.withImages || 0));
          lines.push('[Verify] Missing / broken: ' + (d.missingCount || 0));
          if ((d.missing || []).length > 0) {
            lines.push('');
            (d.missing || []).forEach(function(m, i) {
              var reason = m.reason ? ' - ' + m.reason : '';
              lines.push('  [' + (i + 1) + '/' + d.missing.length + '] ' + (m.name || 'Ship ' + m.id) + ' (id ' + m.id + ')' + reason);
            });
          }
          lines.push('');
          lines.push('[Verify] Done.');
          showTerminal(lines);
          status.textContent = 'Done.';
          btn.disabled = false;
          document.getElementById('verifyTotal').textContent = d.total || 0;
          document.getElementById('verifyWithImages').textContent = d.withImages || 0;
          document.getElementById('verifyMissing').textContent = d.missingCount || 0;
          var list = document.getElementById('verifyMissingList');
          list.innerHTML = '';
          (d.missing || []).forEach(function(m) {
            var li = document.createElement('li');
            var reason = m.reason ? ' <span class="text-muted">(' + m.reason + ')</span>' : '';
            li.innerHTML = '<a href="/ships/' + m.id + '">' + (m.name || 'Ship ' + m.id) + '</a> (id ' + m.id + ')' + reason;
            list.appendChild(li);
          });
          results.style.display = 'block';
        })
        .catch(function(e) {
          showTerminal('[Verify] Error: ' + e.message);
          status.textContent = 'Error: ' + e.message;
          btn.disabled = false;
        });
    };
  </script>
  <% } %>
</body>
</html>
