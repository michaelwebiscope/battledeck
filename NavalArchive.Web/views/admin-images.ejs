<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <style>
    .edit-card { width: 140px; border-radius: 8px; overflow: hidden; background: #1a1a2e; border: 1px solid #333; }
    .edit-thumb { width: 100%; height: 90px; object-fit: cover; display: block; }
    .edit-info { padding: 6px 8px; }
    .edit-name { font-size: 0.8rem; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .edit-actions { display: flex; gap: 4px; }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <h1 class="mb-4">Image Audit</h1>
      <p class="text-muted mb-4">Index of ships and captains: which have ImageUrl, which have cached ImageData in the database, and which are missing. <strong>Sync</strong> fetches ship data and captain ImageUrls from Wikipedia only. <strong>Populate</strong> runs sync first, then fetches images (Pexels → Pixabay → Unsplash → Google). All operations are manual to save API calls. Use <strong>Wikipedia</strong> in the Search provider to manually pick a Wikipedia page and fetch its image.</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <% if (audit) { %>
        <div class="row g-4 mb-4" id="auditSection">
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">Ships</div>
              <div class="card-body" id="auditShipsBody">
                <p class="mb-1"><strong>Total:</strong> <span id="auditShipsTotal"><%= audit.ships?.total ?? 0 %></span></p>
                <p class="mb-1"><strong>With ImageUrl:</strong> <span id="auditShipsWithUrl"><%= audit.ships?.withImageUrl ?? 0 %></span></p>
                <p class="mb-1"><strong>With ImageData (cached):</strong> <span id="auditShipsWithData"><%= audit.ships?.withImageData ?? 0 %></span></p>
                <% if (audit.ships?.missingUrl && audit.ships.missingUrl.length > 0) { %>
                  <p class="mb-1 text-warning"><strong>Missing ImageUrl:</strong> <span id="auditShipsMissingUrlCount"><%= audit.ships.missingUrl.length %></span></p>
                  <ul class="small mb-0" id="auditShipsMissingUrlList">
                    <% audit.ships.missingUrl.slice(0, 10).forEach(function(m) { %><li><%= m.name %> (id <%= m.id %>)</li><% }); %>
                    <% if (audit.ships.missingUrl.length > 10) { %><li>... and <%= audit.ships.missingUrl.length - 10 %> more</li><% } %>
                  </ul>
                <% } %>
                <% if (audit.ships?.missingCachedData && audit.ships.missingCachedData.length > 0) { %>
                  <p class="mb-1 text-info mt-2"><strong>Has URL but not cached:</strong> <span id="auditShipsMissingCachedCount"><%= audit.ships.missingCachedData.length %></span></p>
                  <ul class="small mb-0" id="auditShipsMissingCachedList">
                    <% audit.ships.missingCachedData.slice(0, 10).forEach(function(m) { %><li><%= m.name %> (id <%= m.id %>)</li><% }); %>
                    <% if (audit.ships.missingCachedData.length > 10) { %><li>... and <%= audit.ships.missingCachedData.length - 10 %> more</li><% } %>
                  </ul>
                <% } %>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">Captains</div>
              <div class="card-body" id="auditCaptainsBody">
                <p class="mb-1"><strong>Total:</strong> <span id="auditCaptainsTotal"><%= audit.captains?.total ?? 0 %></span></p>
                <p class="mb-1"><strong>With ImageUrl:</strong> <span id="auditCaptainsWithUrl"><%= audit.captains?.withImageUrl ?? 0 %></span></p>
                <p class="mb-1"><strong>With ImageData (cached):</strong> <span id="auditCaptainsWithData"><%= audit.captains?.withImageData ?? 0 %></span></p>
                <% if (audit.captains?.missingUrl && audit.captains.missingUrl.length > 0) { %>
                  <p class="mb-1 text-warning"><strong>Missing ImageUrl:</strong> <span id="auditCaptainsMissingUrlCount"><%= audit.captains.missingUrl.length %></span></p>
                  <ul class="small mb-0" id="auditCaptainsMissingUrlList">
                    <% audit.captains.missingUrl.slice(0, 10).forEach(function(m) { %><li><%= m.name %> (id <%= m.id %>)</li><% }); %>
                    <% if (audit.captains.missingUrl.length > 10) { %><li>... and <%= audit.captains.missingUrl.length - 10 %> more</li><% } %>
                  </ul>
                <% } %>
                <% if (audit.captains?.missingCachedData && audit.captains.missingCachedData.length > 0) { %>
                  <p class="mb-1 text-info mt-2"><strong>Has URL but not cached:</strong> <span id="auditCaptainsMissingCachedCount"><%= audit.captains.missingCachedData.length %></span></p>
                  <ul class="small mb-0" id="auditCaptainsMissingCachedList">
                    <% audit.captains.missingCachedData.slice(0, 10).forEach(function(m) { %><li><%= m.name %> (id <%= m.id %>)</li><% }); %>
                    <% if (audit.captains.missingCachedData.length > 10) { %><li>... and <%= audit.captains.missingCachedData.length - 10 %> more</li><% } %>
                  </ul>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        <div class="mb-4">
          <details class="mb-3" id="imageSourcesDetails" open>
            <summary class="text-muted small" style="cursor: pointer">Image Sources: order, retry count, API keys, custom APIs</summary>
            <div class="mt-2">
              <p class="small text-muted mb-2">Drag to reorder. Set retries and API keys per source. Delete with ×. Add custom APIs with +.</p>
              <ul id="imageSourcesList" class="list-group list-group-flush mb-2" style="max-height: 360px; overflow-y: auto;"></ul>
              <button type="button" id="addCustomSourceBtn" class="btn btn-sm btn-modern">+ Add Custom API</button>
              <button type="button" id="saveSourcesBtn" class="btn btn-sm btn-modern ms-2">Save Sources</button>
              <span id="sourcesSaveStatus" class="ms-2 small"></span>
            </div>
          </details>
          <button id="syncBtn" class="btn btn-outline-secondary" title="Fetch ship data and captain ImageUrls from Wikipedia only (no image search)">Sync from Wikipedia</button>
          <button id="populateBtn" class="btn btn-modern">Populate All Images (sync + fetch → store)</button>
          <button id="testTerminalBtn" class="btn btn-outline-secondary ms-2" title="Test that the terminal updates in real-time">Test Terminal</button>
          <button id="testKeysBtn" class="btn btn-outline-secondary ms-2" title="Validate API keys and show failures">Test Keys</button>
          <span id="populateStatus" class="ms-3"></span>
        </div>
        <div class="mb-4">
          <button id="verifyBtn" class="btn btn-outline-dark">Verify Images (check which fail to load)</button>
          <span id="verifyStatus" class="ms-3"></span>
        </div>
        <div class="mb-4">
          <h5 class="mb-3">Edit Images</h5>
          <p class="text-muted small mb-3">Edit, delete, or search for a different image for each ship or captain.</p>
          <div class="row g-3">
            <div class="col-12">
              <h6 class="text-muted mb-2">Ships</h6>
              <div class="d-flex flex-wrap gap-2">
                <% (ships || []).forEach(function(s) { %>
                  <div class="edit-card" data-entity="ship" data-id="<%= s.id || s.Id %>" data-name="<%= s.name || s.Name %>">
                    <img src="/gallery/image/<%= s.id || s.Id %>?v=<%= s.imageVersion ?? s.ImageVersion ?? 0 %>" alt="" class="edit-thumb" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22120%22%3E%3Crect fill=%22%236c757d%22 width=%22200%22 height=%22120%22/%3E%3Ctext fill=%22%23fff%22 x=%22100%22 y=%2260%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 font-size=%2210%22%3ENo image%3C/text%3E%3C/svg%3E';">
                    <div class="edit-info">
                      <span class="edit-name"><%= s.name || s.Name %></span>
                      <div class="edit-actions mt-1">
                        <button type="button" class="btn btn-sm btn-outline-light edit-btn">Edit</button>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            </div>
            <div class="col-12">
              <h6 class="text-muted mb-2">Captains</h6>
              <div class="d-flex flex-wrap gap-2">
                <% (captains || []).forEach(function(c) { %>
                  <div class="edit-card" data-entity="captain" data-id="<%= c.id || c.Id %>" data-name="<%= c.name || c.Name %>">
                    <img src="/gallery/captain/<%= c.id || c.Id %>?v=<%= c.imageVersion ?? c.ImageVersion ?? 0 %>" alt="" class="edit-thumb" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22120%22%3E%3Crect fill=%22%236c757d%22 width=%22200%22 height=%22120%22/%3E%3Ctext fill=%22%23fff%22 x=%22100%22 y=%2260%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 font-size=%2210%22%3ENo image%3C/text%3E%3C/svg%3E';">
                    <div class="edit-info">
                      <span class="edit-name"><%= c.name || c.Name %></span>
                      <div class="edit-actions mt-1">
                        <button type="button" class="btn btn-sm btn-outline-light edit-btn">Edit</button>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
        </div>
        <div id="terminalOutput" class="card mb-4" style="display: none;">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span>Terminal Output</span>
            <div>
              <button type="button" class="btn btn-sm btn-outline-light me-1" id="terminalCopy">Copy</button>
              <button type="button" class="btn btn-sm btn-outline-light" id="terminalClear">Clear</button>
            </div>
          </div>
          <div class="card-body p-0">
            <pre id="terminalPre" class="mb-0 p-3 bg-dark text-light font-monospace small" style="max-height: 70vh; overflow-y: auto; white-space: pre-wrap; word-break: break-all;"><span id="terminalContent"></span></pre>
          </div>
        </div>
        <div id="verifyResults" class="card mb-4" style="display: none;">
          <div class="card-header">Verification Results</div>
          <div class="card-body">
            <p class="mb-1"><strong>Total ships:</strong> <span id="verifyTotal">0</span></p>
            <p class="mb-1"><strong>With working images:</strong> <span id="verifyWithImages" class="text-success">0</span></p>
            <p class="mb-2"><strong>Missing / broken images:</strong> <span id="verifyMissing" class="text-danger">0</span></p>
            <ul id="verifyMissingList" class="small mb-0 list-unstyled"></ul>
          </div>
        </div>
      <% } else { %>
        <div class="alert alert-warning">No audit data. Ensure the API is running.</div>
      <% } %>

      <div id="customSourceModal" class="modal fade" tabindex="-1">
        <div class="modal-dialog modal-lg">
          <div class="modal-content bg-dark text-light">
            <div class="modal-header">
              <h5 class="modal-title">Add Custom API Source</h5>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="mb-2">
                <label class="form-label small">Name</label>
                <input type="text" id="customSourceName" class="form-control form-control-sm" placeholder="My API">
              </div>
              <div class="mb-2">
                <label class="form-label small">Base URL</label>
                <input type="text" id="customSourceBaseUrl" class="form-control form-control-sm" placeholder="https://api.example.com/search">
              </div>
              <div class="mb-2">
                <label class="form-label small">Query parameter name</label>
                <input type="text" id="customSourceQueryParam" class="form-control form-control-sm" placeholder="q" value="q">
              </div>
              <div class="mb-2">
                <label class="form-label small">Auth type</label>
                <select id="customSourceAuthType" class="form-select form-select-sm">
                  <option value="none">None</option>
                  <option value="header">Header</option>
                  <option value="query">Query param</option>
                </select>
              </div>
              <div class="mb-2" id="customAuthHeaderRow" style="display:none">
                <label class="form-label small">Auth header name</label>
                <input type="text" id="customSourceAuthHeaderName" class="form-control form-control-sm" placeholder="Authorization">
              </div>
              <div class="mb-2" id="customAuthQueryRow" style="display:none">
                <label class="form-label small">Auth query param name</label>
                <input type="text" id="customSourceAuthQueryParam" class="form-control form-control-sm" placeholder="key">
              </div>
              <div class="mb-2" id="customAuthKeyRefRow" style="display:none">
                <label class="form-label small">Auth value from key (e.g. CUSTOM_API_KEY)</label>
                <input type="text" id="customSourceAuthValueFromKey" class="form-control form-control-sm" placeholder="CUSTOM_API_KEY">
              </div>
              <div class="mb-2">
                <label class="form-label small">Response path to results array (e.g. photos, hits, data.results)</label>
                <input type="text" id="customSourceResponsePath" class="form-control form-control-sm" placeholder="photos">
              </div>
              <div class="mb-2">
                <label class="form-label small">Image URL path in each item (e.g. src.large, urls.regular)</label>
                <input type="text" id="customSourceImageUrlPath" class="form-control form-control-sm" placeholder="src.large">
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="button" id="customSourceSaveBtn" class="btn btn-modern">Add Source</button>
            </div>
          </div>
        </div>
      </div>
      <div id="editImageModal" class="modal fade" tabindex="-1">
        <div class="modal-dialog modal-lg">
          <div class="modal-content bg-dark text-light">
            <div class="modal-header">
              <h5 class="modal-title" id="editModalTitle">Edit Image</h5>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div id="editImagePane">
                <div class="mb-3">
                  <img id="editCurrentImg" src="" alt="" class="img-fluid rounded" style="max-height: 200px;">
                </div>
                <div class="d-flex gap-2">
                  <button type="button" class="btn btn-outline-danger" id="editDeleteBtn">Delete</button>
                  <button type="button" class="btn btn-modern" id="editSearchBtn">Search</button>
                </div>
              </div>
              <div id="editSearchPane" style="display: none;">
                <button type="button" class="btn btn-outline-secondary btn-sm mb-2" id="editSearchBackBtn">← Back</button>
                <iframe id="editSearchFrame" src="" style="width:100%; height: 400px; border: 1px solid #444; border-radius: 6px;"></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <% if (audit) { %>
  <script>
    var imageSources = <%- JSON.stringify(Array.isArray(imageSources) ? imageSources : []) %>;

    function getKeyInputsForSource(s) {
      var html = '';
      if (s.providerType === 'Google') {
        html += '<input type="password" class="form-control form-control-sm source-key-input" style="width:100px" data-key="GOOGLE_API_KEY" placeholder="API key" autocomplete="off">';
        html += '<input type="password" class="form-control form-control-sm source-key-input" style="width:90px" data-key="GOOGLE_CSE_ID" placeholder="CSE ID" autocomplete="off">';
      } else if (s.authKeyRef) {
        var ph = (s.authKeyRef || '').replace(/_/g, ' ').toLowerCase();
        html += '<input type="password" class="form-control form-control-sm source-key-input" style="width:120px" data-key="' + s.authKeyRef + '" placeholder="' + ph + '" autocomplete="off">';
      }
      return html;
    }

    function collectKeysFromSources() {
      var keys = { pexelsApiKey: null, pixabayApiKey: null, unsplashAccessKey: null, googleApiKey: null, googleCseId: null };
      var custom = {};
      document.querySelectorAll('.source-key-input').forEach(function(inp) {
        var k = inp.dataset.key;
        var v = inp.value?.trim();
        if (!v) return;
        if (k === 'PEXELS_API_KEY') keys.pexelsApiKey = v;
        else if (k === 'PIXABAY_API_KEY') keys.pixabayApiKey = v;
        else if (k === 'UNSPLASH_ACCESS_KEY') keys.unsplashAccessKey = v;
        else if (k === 'GOOGLE_API_KEY') keys.googleApiKey = v;
        else if (k === 'GOOGLE_CSE_ID') keys.googleCseId = v;
        else custom[k] = v;
      });
      return { keys: keys, customKeys: custom };
    }

    function renderImageSourcesList() {
      var list = document.getElementById('imageSourcesList');
      if (!list) return;
      list.innerHTML = '';
      var sorted = imageSources.slice().sort(function(a,b){ return (a.sortOrder||0) - (b.sortOrder||0); });
      sorted.forEach(function(s, i) {
        s.sortOrder = i;
        var li = document.createElement('li');
        li.className = 'list-group-item bg-dark text-light d-flex flex-wrap align-items-center gap-2 py-2';
        li.dataset.id = s.id;
        li.draggable = true;
        var keyInputs = getKeyInputsForSource(s);
        li.innerHTML = '<span class="drag-handle text-muted" style="cursor:grab">⋮⋮</span>' +
          '<span style="min-width:90px">' + (s.name || s.id) + '</span>' +
          '<label class="small mb-0">Retries:</label>' +
          '<input type="number" class="form-control form-control-sm" style="width:50px" min="1" max="5" value="' + (s.retryCount||2) + '" data-source-id="' + s.id + '" data-field="retryCount">' +
          (keyInputs ? '<span class="d-flex gap-1 align-items-center">' + keyInputs + '</span>' : '') +
          '<button type="button" class="btn btn-sm btn-outline-danger remove-source-btn ms-auto" data-id="' + s.id + '" title="Delete source">×</button>';
        list.appendChild(li);
      });
      list.querySelectorAll('input[data-field="retryCount"]').forEach(function(inp) {
        inp.onchange = function() {
          var src = imageSources.find(function(s){ return s.id === inp.dataset.sourceId; });
          if (src) src.retryCount = parseInt(inp.value, 10) || 2;
        };
      });
      list.querySelectorAll('.remove-source-btn').forEach(function(btn) {
        btn.onclick = function() {
          if (!confirm('Delete this source?')) return;
          imageSources = imageSources.filter(function(s){ return s.id !== btn.dataset.id; });
          renderImageSourcesList();
        };
      });
      list.querySelectorAll('li').forEach(function(li, idx) {
        li.ondragstart = function(e) { e.dataTransfer.setData('text/plain', idx); };
        li.ondragover = function(e) { e.preventDefault(); li.classList.add('border-primary'); };
        li.ondragleave = function() { li.classList.remove('border-primary'); };
        li.ondrop = function(e) {
          e.preventDefault();
          li.classList.remove('border-primary');
          var from = parseInt(e.dataTransfer.getData('text/plain'), 10);
          if (isNaN(from)) return;
          var arr = imageSources.slice().sort(function(a,b){ return (a.sortOrder||0) - (b.sortOrder||0); });
          var item = arr.splice(from, 1)[0];
          if (!item) return;
          arr.splice(idx, 0, item);
          arr.forEach(function(s, i){ s.sortOrder = i; });
          imageSources = arr;
          renderImageSourcesList();
        };
      });
    }

    document.getElementById('customSourceAuthType').onchange = function() {
      var v = this.value;
      document.getElementById('customAuthHeaderRow').style.display = v === 'header' ? 'block' : 'none';
      document.getElementById('customAuthQueryRow').style.display = v === 'query' ? 'block' : 'none';
      document.getElementById('customAuthKeyRefRow').style.display = (v === 'header' || v === 'query') ? 'block' : 'none';
    };

    document.getElementById('addCustomSourceBtn').onclick = function() {
      document.getElementById('customSourceName').value = '';
      document.getElementById('customSourceBaseUrl').value = '';
      document.getElementById('customSourceQueryParam').value = 'q';
      document.getElementById('customSourceAuthType').value = 'none';
      document.getElementById('customSourceAuthHeaderName').value = 'Authorization';
      document.getElementById('customSourceAuthQueryParam').value = 'key';
      document.getElementById('customSourceAuthValueFromKey').value = 'CUSTOM_API_KEY';
      document.getElementById('customSourceResponsePath').value = 'photos';
      document.getElementById('customSourceImageUrlPath').value = 'src.large';
      document.getElementById('customAuthHeaderRow').style.display = 'none';
      document.getElementById('customAuthQueryRow').style.display = 'none';
      document.getElementById('customAuthKeyRefRow').style.display = 'none';
      new bootstrap.Modal(document.getElementById('customSourceModal')).show();
    };

    document.getElementById('customSourceSaveBtn').onclick = function() {
      var name = document.getElementById('customSourceName').value.trim() || 'Custom';
      var baseUrl = document.getElementById('customSourceBaseUrl').value.trim();
      var authType = document.getElementById('customSourceAuthType').value;
      if (!baseUrl) { alert('Base URL is required'); return; }
      var id = 'custom-' + Date.now();
      var src = {
        id: id, name: name, providerType: 'Custom', retryCount: 2, sortOrder: imageSources.length,
        enabled: true, authKeyRef: null, customConfig: {
          baseUrl: baseUrl,
          queryParam: document.getElementById('customSourceQueryParam').value.trim() || 'q',
          authType: authType,
          authHeaderName: authType === 'header' ? (document.getElementById('customSourceAuthHeaderName').value.trim() || 'Authorization') : null,
          authQueryParam: authType === 'query' ? (document.getElementById('customSourceAuthQueryParam').value.trim() || 'key') : null,
          authValueFromKey: (authType === 'header' || authType === 'query') ? (document.getElementById('customSourceAuthValueFromKey').value.trim() || 'CUSTOM_API_KEY') : null,
          responsePath: document.getElementById('customSourceResponsePath').value.trim() || 'results',
          imageUrlPath: document.getElementById('customSourceImageUrlPath').value.trim() || 'url'
        }
      };
      if (src.customConfig.authValueFromKey) src.authKeyRef = src.customConfig.authValueFromKey;
      imageSources.push(src);
      renderImageSourcesList();
      bootstrap.Modal.getInstance(document.getElementById('customSourceModal')).hide();
    };

    document.getElementById('saveSourcesBtn').onclick = function() {
      var btn = this, status = document.getElementById('sourcesSaveStatus');
      btn.disabled = true;
      status.textContent = 'Saving...';
      fetch('/admin/images/sources', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(imageSources) })
        .then(function(r) { return r.json(); })
        .then(function() { status.textContent = 'Saved.'; btn.disabled = false; setTimeout(function(){ status.textContent = ''; }, 2000); })
        .catch(function(e) { status.textContent = 'Error: ' + e.message; btn.disabled = false; });
    };

    if (document.getElementById('imageSourcesList')) renderImageSourcesList();

    function showTerminal(lines, showPanel) {
      var pre = document.getElementById('terminalPre');
      var content = document.getElementById('terminalContent');
      var panel = document.getElementById('terminalOutput');
      content.textContent = Array.isArray(lines) ? lines.join('\n') : lines;
      panel.style.display = 'block';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          pre.scrollTop = pre.scrollHeight;
        });
      });
      if (showPanel !== false) panel.scrollIntoView({ behavior: 'smooth', block: 'end' });
    }
    document.getElementById('terminalCopy').onclick = function() {
      var text = document.getElementById('terminalContent').textContent;
      navigator.clipboard.writeText(text).then(function() {
        this.textContent = 'Copied!';
        var btn = this;
        setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
      }.bind(this));
    };
    document.getElementById('terminalClear').onclick = function() {
      document.getElementById('terminalContent').textContent = '';
    };
    function runPollingFlow(jobId, statusEl, btnEl, startMsg) {
      var lines = ['[Populate] ' + new Date().toISOString(), startMsg, ''];
      var shipResults = [], captainResults = [], lastIdx = 0;
      var pollCount = 0;
      var maxPolls = 600;
      function appendLine(s) { lines.push(s); showTerminal(lines, false); }
      function poll() {
        if (++pollCount > maxPolls) {
          appendLine('[Error] Poll limit reached. Stopping.');
          statusEl.textContent = 'Stopped (timeout)';
          btnEl.disabled = false;
          return;
        }
        fetch('/admin/images/populate/status/' + jobId)
          .then(function(r) {
            if (!r.ok) throw new Error(r.status === 404 ? 'Job not found' : 'Status ' + r.status);
            return r.json();
          })
          .then(function(st) {
            for (var i = lastIdx; i < (st.events || []).length; i++) {
              var evt = st.events[i];
              var t = evt.type || evt.Type;
              var d = evt.data !== undefined ? evt.data : evt.Data;
              if (t === 'sync') {
                appendLine('[Sync] ' + (evt.message || evt.error || ''));
                appendLine('');
                appendLine('[Populate] Step 2: Checking API keys...');
              } else if (t === 'key' && d) {
                var p = d.provider || d.Provider || '?';
                var ok = d.ok !== false;
                var msg = d.message || d.Message || '';
                if (msg === 'nokey') appendLine('  [' + p + ']nokey');
                else appendLine(ok ? '  ' + p + ': OK' : '  [' + p + ']FAIL - ' + msg);
              } else if (t === 'info' && d) {
                appendLine('');
                appendLine('[Populate] Step 3: Fetching and storing images...');
                appendLine('  ' + d);
                if (typeof d === 'string' && /Processing 0 ships, 0 captains/.test(d)) appendLine('  (All images cached.)');
              } else if (t === 'progress' && d) {
                appendLine('    ' + d);
              } else if (t === 'error' && evt.error) {
                appendLine('[Error] ' + evt.error);
              } else if (t === 'ship' && d) {
                var x = d;
                var statusVal = x.status || x.Status;
                var tag = statusVal === 'ok' ? 'OK' : 'Fail';
                var suffix = (x.reason || x.Reason) ? ' - ' + (x.reason || x.Reason) : '';
                var bytes = (x.bytesStored || x.BytesStored) ? ' (' + (x.bytesStored || x.BytesStored) + ' bytes)' : '';
                appendLine('  [Ship ' + (x.index || x.Index) + '/' + (x.total || x.Total) + '] ' + tag + ': ' + (x.name || x.Name) + ' (id ' + (x.id || x.Id) + ')' + bytes + suffix);
                shipResults.push(x);
              } else if (t === 'captain' && d) {
                var x = d;
                if (captainResults.length === 0 && shipResults.length > 0) appendLine('');
                if (captainResults.length === 0) appendLine('[Captains]');
                var statusVal = x.status || x.Status;
                var tag = statusVal === 'ok' ? 'OK' : 'Fail';
                var suffix = (x.reason || x.Reason) ? ' - ' + (x.reason || x.Reason) : '';
                var bytes = (x.bytesStored || x.BytesStored) ? ' (' + (x.bytesStored || x.BytesStored) + ' bytes)' : '';
                appendLine('  [Captain ' + (x.index || x.Index) + '/' + (x.total || x.Total) + '] ' + tag + ': ' + (x.name || x.Name) + ' (id ' + (x.id || x.Id) + ')' + bytes + suffix);
                captainResults.push(x);
              } else if (t === 'done') {
                appendLine('');
                var sOk = shipResults.filter(function(x) { return (x.status || x.Status) === 'ok'; }).length;
                var cOk = captainResults.filter(function(x) { return (x.status || x.Status) === 'ok'; }).length;
                appendLine('[Populate] Done. Stored ' + sOk + ' ships, ' + cOk + ' captains.');
              }
            }
            lastIdx = (st.events || []).length;
            if (st.done) {
              appendLine('[Populate] Refresh the page to see updated audit stats.');
              showTerminal(lines);
              var s = shipResults.filter(function(x) { return (x.status || x.Status) === 'ok'; }).length;
              var c = captainResults.filter(function(x) { return (x.status || x.Status) === 'ok'; }).length;
              statusEl.textContent = 'Done. Stored ' + s + ' ships, ' + c + ' captains.';
              btnEl.disabled = false;
            } else {
              setTimeout(poll, 1200);
            }
          })
          .catch(function(e) {
            appendLine('[Error] Poll failed: ' + e.message);
            setTimeout(poll, 3000);
          });
      }
      poll();
    }
    document.getElementById('testKeysBtn').onclick = function() {
      var btn = this;
      btn.disabled = true;
      var collected = collectKeysFromSources();
      var body = Object.assign({}, collected.keys);
      if (Object.keys(collected.customKeys).length > 0) body.customKeys = collected.customKeys;
      showTerminal('[Test Keys] ' + new Date().toISOString() + '\n[Test Keys] Validating API keys...', true);
      fetch('/admin/images/test-keys', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
        .then(function(r) { return r.json(); })
        .then(function(results) {
          var lines = ['[Test Keys] ' + new Date().toISOString(), ''];
          if (Array.isArray(results)) {
            results.forEach(function(r) {
              var ok = r.ok !== false;
              var msg = (r.provider || r.Provider || '?') + ': ' + (ok ? 'OK' : 'FAIL - ' + (r.message || r.Message || ''));
              lines.push(ok ? '  ' + msg : '  [FAIL] ' + msg);
            });
          } else if (results.error) {
            lines.push('[Error] ' + results.error);
          } else {
            lines.push(JSON.stringify(results));
          }
          lines.push('');
          showTerminal(lines);
          btn.disabled = false;
        })
        .catch(function(e) {
          showTerminal('[Test Keys] Error: ' + e.message);
          btn.disabled = false;
        });
    };
    document.getElementById('testTerminalBtn').onclick = function() {
      var btn = this, status = document.getElementById('populateStatus');
      btn.disabled = true;
      status.textContent = 'Testing terminal...';
      showTerminal('[Test] ' + new Date().toISOString() + '\n[Test] Emitting fake progress... Watch the terminal update every ~1.2s.', true);
      fetch('/admin/images/populate/test-terminal', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.jobId) runPollingFlow(d.jobId, status, btn, '[Test] Step 1: Fake sync...');
          else { status.textContent = 'Error: no jobId'; btn.disabled = false; }
        })
        .catch(function(e) {
          showTerminal('[Test] Error: ' + e.message);
          status.textContent = 'Error: ' + e.message;
          btn.disabled = false;
        });
    };
    document.getElementById('syncBtn').onclick = function() {
      var btn = this, status = document.getElementById('populateStatus');
      btn.disabled = true;
      status.textContent = 'Syncing from Wikipedia...';
      fetch('/admin/sync?force=true', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          status.textContent = d.message || 'Sync done.';
          refreshAudit();
        })
        .catch(function(e) {
          status.textContent = 'Error: ' + e.message;
        })
        .finally(function() { btn.disabled = false; });
    };
    document.getElementById('populateBtn').onclick = function() {
      var btn = this, status = document.getElementById('populateStatus');
      btn.disabled = true;
      status.textContent = 'Syncing & populating...';
      var startTime = Date.now();
      showTerminal('[Populate] ' + new Date().toISOString() + '\n[Populate] Step 1: Running Wikipedia sync to fetch captain ImageUrls...\n[Populate] This may take several minutes.', true);
      var body = { runSyncFirst: true, usePolling: true };
      var collected = collectKeysFromSources();
      Object.assign(body, collected.keys);
      if (Object.keys(collected.customKeys).length > 0) body.customKeys = collected.customKeys;
      var searchPrefixes = <%- JSON.stringify(typeof imageSearchPrefix !== 'undefined' && imageSearchPrefix ? imageSearchPrefix : { ship: 'battleship', captain: 'captain' }) %>;
      body.shipSearchPrefix = searchPrefixes.ship || 'battleship';
      body.captainSearchPrefix = searchPrefixes.captain || 'captain';
      if (imageSources && imageSources.length > 0) body.imageSources = imageSources;
      fetch('/admin/images/populate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.jobId) {
            runPollingFlow(d.jobId, status, btn, '[Populate] Step 1: Running Wikipedia sync...');
            return { stream: true };
          }
          return { stream: false, data: d };
        })
        .then(function(result) {
          if (result && result.stream) return;
          var d = result.data;
          var elapsed = ((Date.now() - startTime) / 1000).toFixed(1);
          var lines = (d.logLines || []).slice();
          if (lines.length === 0) {
            lines.push('[Populate] Sync phase: ' + (d.syncLog || 'completed'));
          }
          lines.push('');
          lines.push('[Populate] Step 2: Fetching and storing images...');
          (d.shipResults || []).forEach(function(r) {
            var tag = r.status === 'ok' ? 'OK' : 'Fail';
            var suffix = r.reason ? ' - ' + r.reason : '';
            var bytes = r.bytesStored ? ' (' + r.bytesStored + ' bytes)' : '';
            lines.push('  [Ship ' + r.index + '/' + r.total + '] ' + tag + ': ' + r.name + ' (id ' + r.id + ')' + bytes + suffix);
          });
          if ((d.captainResults || []).length > 0) {
            lines.push('');
            lines.push('[Captains]');
            (d.captainResults || []).forEach(function(r) {
              var tag = r.status === 'ok' ? 'OK' : 'Fail';
              var suffix = r.reason ? ' - ' + r.reason : '';
              var bytes = r.bytesStored ? ' (' + r.bytesStored + ' bytes)' : '';
              lines.push('  [Captain ' + r.index + '/' + r.total + '] ' + tag + ': ' + r.name + ' (id ' + r.id + ')' + bytes + suffix);
            });
          }
          lines.push('');
          lines.push('[Populate] Done in ' + elapsed + 's. Stored ' + (d.shipsStored || 0) + ' ships, ' + (d.captainsStored || 0) + ' captains.');
          lines.push('[Populate] Refresh the page to see updated audit stats.');
          showTerminal(lines);
          status.textContent = 'Done. Stored ' + (d.shipsStored || 0) + ' ships, ' + (d.captainsStored || 0) + ' captains.';
          btn.disabled = false;
        })
        .catch(function(e) {
          showTerminal('[Populate] Error: ' + e.message);
          status.textContent = 'Error: ' + e.message;
          btn.disabled = false;
        });
    };
    document.getElementById('verifyBtn').onclick = function() {
      var btn = this, status = document.getElementById('verifyStatus'), results = document.getElementById('verifyResults');
      btn.disabled = true;
      status.textContent = 'Verifying... (this may take ~1 min)';
      results.style.display = 'none';
      showTerminal('[Verify] Checking which ship images load...\n[Verify] Requesting each /gallery/image/:id...', true);
      fetch('/admin/images/verify')
        .then(function(r) { return r.json(); })
        .then(function(d) {
          var lines = ['[Verify] Total ships: ' + (d.total || 0)];
          lines.push('[Verify] With working images: ' + (d.withImages || 0));
          lines.push('[Verify] Missing / broken: ' + (d.missingCount || 0));
          if ((d.missing || []).length > 0) {
            lines.push('');
            (d.missing || []).forEach(function(m, i) {
              var reason = m.reason ? ' - ' + m.reason : '';
              lines.push('  [' + (i + 1) + '/' + d.missing.length + '] ' + (m.name || 'Ship ' + m.id) + ' (id ' + m.id + ')' + reason);
            });
          }
          lines.push('');
          lines.push('[Verify] Done.');
          showTerminal(lines);
          status.textContent = 'Done.';
          btn.disabled = false;
          document.getElementById('verifyTotal').textContent = d.total || 0;
          document.getElementById('verifyWithImages').textContent = d.withImages || 0;
          document.getElementById('verifyMissing').textContent = d.missingCount || 0;
          var list = document.getElementById('verifyMissingList');
          list.innerHTML = '';
          (d.missing || []).forEach(function(m) {
            var li = document.createElement('li');
            var reason = m.reason ? ' <span class="text-muted">(' + m.reason + ')</span>' : '';
            li.innerHTML = '<a href="/ships/' + m.id + '">' + (m.name || 'Ship ' + m.id) + '</a> (id ' + m.id + ')' + reason;
            list.appendChild(li);
          });
          results.style.display = 'block';
        })
        .catch(function(e) {
          showTerminal('[Verify] Error: ' + e.message);
          status.textContent = 'Error: ' + e.message;
          btn.disabled = false;
        });
    };

    var editModal = document.getElementById('editImageModal');
    var editImagePane = document.getElementById('editImagePane');
    var editSearchPane = document.getElementById('editSearchPane');
    var editSearchFrame = document.getElementById('editSearchFrame');
    var editCurrentImg = document.getElementById('editCurrentImg');
    var editModalTitle = document.getElementById('editModalTitle');
    var currentEdit = { entity: null, id: null, card: null };

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.edit-btn');
      if (!btn) return;
      var card = btn.closest('.edit-card');
      if (!card) return;
      currentEdit.entity = card.dataset.entity;
      currentEdit.id = card.dataset.id;
      currentEdit.name = card.dataset.name;
      currentEdit.card = card;
      var img = card.querySelector('.edit-thumb');
      editCurrentImg.src = img.src;
      editModalTitle.textContent = 'Edit: ' + currentEdit.name;
      editImagePane.style.display = 'block';
      editSearchPane.style.display = 'none';
      new bootstrap.Modal(editModal).show();
    });

    var noImagePlaceholder = "data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22120%22%3E%3Crect fill=%22%236c757d%22 width=%22200%22 height=%22120%22/%3E%3Ctext fill=%22%23fff%22 x=%22100%22 y=%2260%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 font-size=%2210%22%3ENo image%3C/text%3E%3C/svg%3E";
    editModal.addEventListener('click', function(e) {
      if (!e.target.closest('#editDeleteBtn')) return;
      if (!currentEdit.entity || !currentEdit.id) return;
      if (!confirm('Delete cached image for ' + (currentEdit.name || 'this item') + '?')) return;
      var btn = document.getElementById('editDeleteBtn');
      if (btn) { btn.disabled = true; btn.textContent = 'Deleting...'; }
      var url = '/api/images/' + currentEdit.entity + '/' + currentEdit.id;
      fetch(url, { method: 'DELETE' })
        .then(function(r) {
          if (!r.ok) return r.json().then(function(j) { throw new Error(j.error || j.message || 'Delete failed'); });
          return r.json().catch(function() { return {}; });
        })
        .then(function() {
          var inst = bootstrap.Modal.getInstance(editModal);
          if (inst) inst.hide();
          if (currentEdit.card) {
            var thumb = currentEdit.card.querySelector('.edit-thumb');
            if (thumb) thumb.src = noImagePlaceholder;
          }
          editCurrentImg.src = noImagePlaceholder;
          refreshAudit();
        })
        .catch(function(e) {
          if (btn) { btn.disabled = false; btn.textContent = 'Delete'; }
          alert('Delete failed: ' + e.message);
        });
    });

    document.getElementById('editSearchBackBtn').onclick = function() {
      editSearchFrame.src = 'about:blank';
      editImagePane.style.display = 'block';
      editSearchPane.style.display = 'none';
    };

    document.getElementById('editSearchBtn').onclick = function() {
      if (!currentEdit.entity || !currentEdit.id) return;
      var collected = collectKeysFromSources();
      var keys = Object.assign({}, collected.keys, collected.customKeys);
      sessionStorage.setItem('adminImageKeys', JSON.stringify(keys));
      var searchPrefixes = <%- JSON.stringify(typeof imageSearchPrefix !== 'undefined' && imageSearchPrefix ? imageSearchPrefix : { ship: 'battleship', captain: 'captain' }) %>;
      var prefix = searchPrefixes[currentEdit.entity] || (currentEdit.entity === 'ship' ? 'battleship' : 'captain');
      var q = encodeURIComponent(currentEdit.name + ' ' + prefix);
      editSearchFrame.src = '/admin/images/search-frame?entity=' + currentEdit.entity + '&id=' + currentEdit.id + '&q=' + q;
      editImagePane.style.display = 'none';
      editSearchPane.style.display = 'block';
    };

    function refreshAudit() {
      fetch('/api/images/audit').then(function(r) { return r.json(); })
        .then(function(audit) {
          if (!audit) return;
          function renderEntityBody(ent) {
            if (!ent) return '';
            var html = '<p class="mb-1"><strong>Total:</strong> ' + (ent.total ?? 0) + '</p>';
            html += '<p class="mb-1"><strong>With ImageUrl:</strong> ' + (ent.withImageUrl ?? 0) + '</p>';
            html += '<p class="mb-1"><strong>With ImageData (cached):</strong> ' + (ent.withImageData ?? 0) + '</p>';
            var mu = ent.missingUrl || [];
            if (mu.length > 0) {
              html += '<p class="mb-1 text-warning"><strong>Missing ImageUrl:</strong> ' + mu.length + '</p><ul class="small mb-0">';
              mu.slice(0, 10).forEach(function(m) { html += '<li>' + (m.name || '') + ' (id ' + (m.id || '') + ')</li>'; });
              if (mu.length > 10) html += '<li>... and ' + (mu.length - 10) + ' more</li>';
              html += '</ul>';
            }
            var mc = ent.missingCachedData || [];
            if (mc.length > 0) {
              html += '<p class="mb-1 text-info mt-2"><strong>Has URL but not cached:</strong> ' + mc.length + '</p><ul class="small mb-0">';
              mc.slice(0, 10).forEach(function(m) { html += '<li>' + (m.name || '') + ' (id ' + (m.id || '') + ')</li>'; });
              if (mc.length > 10) html += '<li>... and ' + (mc.length - 10) + ' more</li>';
              html += '</ul>';
            }
            return html;
          }
          var shipsBody = document.getElementById('auditShipsBody');
          var captainsBody = document.getElementById('auditCaptainsBody');
          if (shipsBody) shipsBody.innerHTML = renderEntityBody(audit.ships);
          if (captainsBody) captainsBody.innerHTML = renderEntityBody(audit.captains);
        })
        .catch(function() {});
    }

    window.addEventListener('message', function(e) {
      if (!e.data || e.data.type !== 'imageSelected' || String(e.data.entityId) !== String(currentEdit.id)) return;
      var entity = e.data.entity;
      var entityId = e.data.entityId;
      var url = e.data.url;
      fetch('/api/images/' + entity + '/' + entityId + '/from-url', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url: url })
      })
        .then(function(r) {
          if (!r.ok) return r.json().then(function(j) { throw new Error(j.error || j.message || 'Set image failed'); });
          return r.json().catch(function() { return {}; });
        })
        .then(function() {
          var v = Date.now();
          var imgUrl = (entity === 'ship' ? '/gallery/image/' : '/gallery/captain/') + entityId + '?v=' + v;
          if (currentEdit.card) {
            var thumb = currentEdit.card.querySelector('.edit-thumb');
            if (thumb) thumb.src = imgUrl;
          }
          editCurrentImg.src = imgUrl;
          editSearchFrame.src = 'about:blank';
          editImagePane.style.display = 'block';
          editSearchPane.style.display = 'none';
          refreshAudit();
          var inst = bootstrap.Modal.getInstance(editModal);
          if (inst) inst.hide();
        })
        .catch(function(err) { alert('Set image failed: ' + err.message); });
    });

    if (editModal) {
      editModal.addEventListener('hidden.bs.modal', function() {
        editSearchFrame.src = 'about:blank';
        editImagePane.style.display = 'block';
        editSearchPane.style.display = 'none';
        var db = document.getElementById('editDeleteBtn');
        if (db) { db.disabled = false; db.textContent = 'Delete'; }
      });
    }
  </script>
  <% } %>
</body>
</html>
