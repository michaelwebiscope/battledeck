    function runPollingFlow(jobId, statusEl, btnEl, startMsg) {
      var lines = ['[Populate] ' + new Date().toISOString(), startMsg, ''];
      var shipResults = [], captainResults = [], lastIdx = 0;
      var pollCount = 0;
      var maxPolls = 600;
      function appendLine(s) { lines.push(s); showTerminal(lines, false); }
      function poll() {
        if (++pollCount > maxPolls) {
          appendLine('[Error] Poll limit reached. Stopping.');
          statusEl.textContent = 'Stopped (timeout)';
          btnEl.disabled = false;
          return;
        }
        fetch('/admin/images/populate/status/' + jobId)
          .then(function(r) {
            if (!r.ok) throw new Error(r.status === 404 ? 'Job not found' : 'Status ' + r.status);
            return r.json();
          })
          .then(function(st) {
            for (var i = lastIdx; i < (st.events || []).length; i++) {
              var evt = st.events[i];
              var t = evt.type || evt.Type;
              var d = evt.data !== undefined ? evt.data : evt.Data;
              if (t === 'sync') {
                appendLine('[Sync] ' + (evt.message || evt.error || ''));
                appendLine('');
                appendLine('[Populate] Step 2: Checking API keys...');
              } else if (t === 'key' && d) {
                var p = d.provider || d.Provider || '?';
                var ok = d.ok !== false;
                var msg = d.message || d.Message || '';
                if (msg === 'nokey') appendLine('  [' + p + ']nokey');
                else appendLine(ok ? '  ' + p + ': OK' : '  [' + p + ']FAIL - ' + msg);
              } else if (t === 'info' && d) {
                appendLine('');
                appendLine('[Populate] Step 3: Fetching and storing images...');
                appendLine('  ' + d);
                if (typeof d === 'string' && /Processing 0 ships, 0 captains/.test(d)) appendLine('  (All images cached.)');
              } else if (t === 'progress' && d) {
                appendLine('    ' + d);
              } else if (t === 'error' && evt.error) {
                appendLine('[Error] ' + evt.error);
              } else if (t === 'ship' && d) {
                var x = d;
                var statusVal = x.status || x.Status;
                var tag = statusVal === 'ok' ? 'OK' : 'Fail';
                var suffix = (x.reason || x.Reason) ? ' - ' + (x.reason || x.Reason) : '';
                var bytes = (x.bytesStored || x.BytesStored) ? ' (' + (x.bytesStored || x.BytesStored) + ' bytes)' : '';
                appendLine('  [Ship ' + (x.index || x.Index) + '/' + (x.total || x.Total) + '] ' + tag + ': ' + (x.name || x.Name) + ' (id ' + (x.id || x.Id) + ')' + bytes + suffix);
                shipResults.push(x);
              } else if (t === 'captain' && d) {
                var x = d;
                if (captainResults.length === 0 && shipResults.length > 0) appendLine('');
                if (captainResults.length === 0) appendLine('[Captains]');
                var statusVal = x.status || x.Status;
                var tag = statusVal === 'ok' ? 'OK' : 'Fail';
                var suffix = (x.reason || x.Reason) ? ' - ' + (x.reason || x.Reason) : '';
                var bytes = (x.bytesStored || x.BytesStored) ? ' (' + (x.bytesStored || x.BytesStored) + ' bytes)' : '';
                appendLine('  [Captain ' + (x.index || x.Index) + '/' + (x.total || x.Total) + '] ' + tag + ': ' + (x.name || x.Name) + ' (id ' + (x.id || x.Id) + ')' + bytes + suffix);
                captainResults.push(x);
              } else if (t === 'done') {
                appendLine('');
                var sOk = shipResults.filter(function(x) { return (x.status || x.Status) === 'ok'; }).length;
                var cOk = captainResults.filter(function(x) { return (x.status || x.Status) === 'ok'; }).length;
                appendLine('[Populate] Done. Stored ' + sOk + ' ships, ' + cOk + ' captains.');
              }
            }
            lastIdx = (st.events || []).length;
            if (st.done) {
              appendLine('[Populate] Refresh the page to see updated audit stats.');
              var s = shipResults.filter(function(x) { return (x.status || x.Status) === 'ok'; }).length;
              var c = captainResults.filter(function(x) { return (x.status || x.Status) === 'ok'; }).length;
              showTerminal(lines);
              statusEl.textContent = 'Done. Stored ' + s + ' ships, ' + c + ' captains.';
              btnEl.disabled = false;
            } else {
              setTimeout(poll, 1200);
            }
          })
          .catch(function(e) {
            appendLine('[Error] Poll failed: ' + e.message);
            setTimeout(poll, 3000);
          });
      }
      poll();
    }
