<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <style>
    .card-popup {
      position: fixed;
      top: 72px;
      right: 0;
      width: 320px;
      max-height: calc(100vh - 80px);
      background: linear-gradient(135deg, var(--blue-deep) 0%, var(--blue) 100%);
      color: white;
      border-radius: 12px 0 0 12px;
      box-shadow: -4px 4px 24px rgba(12, 74, 110, 0.3);
      z-index: 900;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease, width 0.3s ease;
      overflow: hidden;
    }
    .card-popup.minimized {
      width: 48px;
      transform: translateX(0);
    }
    .card-popup.minimized .card-popup-body,
    .card-popup.minimized .card-popup-title { display: none; }
    .card-popup.minimized .card-popup-tab {
      display: flex;
      writing-mode: vertical-rl;
      text-orientation: mixed;
      transform: rotate(180deg);
      padding: 12px 8px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
    }
    .card-popup-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.2);
      flex-shrink: 0;
    }
    .card-popup-title { font-weight: 600; font-size: 1rem; }
    .card-popup-tab { display: none; }
    .card-popup-minimize {
      background: rgba(255,255,255,0.2);
      border: none;
      color: white;
      width: 32px;
      height: 32px;
      border-radius: 6px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      line-height: 1;
    }
    .card-popup-minimize:hover { background: rgba(255,255,255,0.3); }
    .card-popup-body {
      padding: 16px;
      overflow-y: auto;
      flex: 1;
    }
    .card-popup .member-card {
      background: rgba(255,255,255,0.12);
      border-radius: 10px;
      padding: 16px;
      margin-bottom: 12px;
      border: 1px solid rgba(255,255,255,0.2);
    }
    .card-popup .member-card .card-id { font-family: monospace; font-size: 1rem; font-weight: 600; letter-spacing: 0.05em; }
    .card-popup .member-card .card-name { font-size: 0.95rem; opacity: 0.95; margin-top: 4px; }
    .card-popup .member-card .card-tier { font-size: 0.8rem; opacity: 0.8; margin-top: 2px; }
    .card-popup .btn-go { width: 100%; margin-top: 12px; background: white; color: var(--blue-deep); font-weight: 600; border: none; }
    .card-popup .btn-go:hover { background: var(--cyan-light); color: var(--blue-deep); }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <h1 class="mb-4">Add Member</h1>
      <p class="lead text-muted mb-4">Create a member and auto-issue a card. Chain: App → API → Card</p>
      <div class="row">
        <div class="col-lg-6">
          <div class="card">
            <div class="card-body">
              <form id="memberForm">
                <div class="mb-3">
                  <label class="form-label">Name</label>
                  <input type="text" name="name" class="form-control" placeholder="Member name" required>
                </div>
                <div class="mb-3">
                  <label class="form-label">Tier</label>
                  <select name="tier" class="form-select">
                    <option value="Standard">Standard</option>
                    <option value="Patron">Patron</option>
                    <option value="Fleet">Fleet Admiral</option>
                  </select>
                </div>
                <button type="submit" class="btn btn-dark">Add Member</button>
              </form>
              <div id="result" class="mt-3" style="display:none;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <div id="cardPopup" class="card-popup" style="display: none;">
    <div class="card-popup-header">
      <span class="card-popup-title">My Card</span>
      <span class="card-popup-tab" role="button" tabindex="0" title="Click to expand">My Card</span>
      <button type="button" class="card-popup-minimize" id="cardPopupMinimize" title="Minimize">−</button>
    </div>
    <div class="card-popup-body">
      <div id="cardPopupContent"></div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (function() {
      var popup = document.getElementById('cardPopup');
      var content = document.getElementById('cardPopupContent');
      var minimizeBtn = document.getElementById('cardPopupMinimize');

      function showCardPopup(data) {
        content.innerHTML = '<div class="member-card">' +
          '<div class="card-id">' + (data.cardId || '') + '</div>' +
          '<div class="card-name">' + (data.name || '') + '</div>' +
          '<div class="card-tier">' + (data.tier || 'Standard') + '</div>' +
          '<a href="/cart?cardId=' + encodeURIComponent(data.cardId || '') + '" class="btn btn-go">Go to card</a>' +
          '</div>';
        popup.style.display = 'flex';
        popup.classList.remove('minimized');
        minimizeBtn.textContent = '−';
        minimizeBtn.title = 'Minimize';
      }

      minimizeBtn.addEventListener('click', function() {
        popup.classList.toggle('minimized');
        minimizeBtn.textContent = popup.classList.contains('minimized') ? '+' : '−';
        minimizeBtn.title = popup.classList.contains('minimized') ? 'Expand' : 'Minimize';
      });

      var tab = popup.querySelector('.card-popup-tab');
      tab.addEventListener('click', function() {
        if (popup.classList.contains('minimized')) {
          popup.classList.remove('minimized');
          minimizeBtn.textContent = '−';
          minimizeBtn.title = 'Minimize';
        }
      });
      tab.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          tab.click();
        }
      });

      document.getElementById('memberForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const name = document.querySelector('[name="name"]').value;
        const tier = document.querySelector('[name="tier"]').value;
        const resultEl = document.getElementById('result');
        resultEl.style.display = 'block';
        resultEl.innerHTML = '<span class="text-muted">Creating member...</span>';
        try {
          const res = await fetch('/api/members', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, tier })
          });
          const data = await res.json();
          if (res.ok) {
            resultEl.innerHTML = '<div class="alert alert-success">✓ ' + data.message + '<br><a href="/cart?cardId=' + data.cardId + '">Add to cart</a> | <a href="/checkout?cardId=' + data.cardId + '">Checkout</a></div>';
            showCardPopup({ cardId: data.cardId, name: data.name, tier: data.tier });
          } else {
            resultEl.innerHTML = '<div class="alert alert-danger">' + (data.error || 'Failed') + '</div>';
          }
        } catch (err) {
          resultEl.innerHTML = '<div class="alert alert-danger">API unavailable.</div>';
        }
      });
    })();
  </script>
</body>
</html>
