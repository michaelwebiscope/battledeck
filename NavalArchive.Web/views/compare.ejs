<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <%
        var shipType = typeof entityTypes !== 'undefined' && entityTypes.ship ? entityTypes.ship : { listTitle: 'Fleet Roster', displayName: 'Ship', pluralName: 'Ships' };
        var compareTitle = 'Compare ' + (shipType.pluralName || 'Items');
        var selectLabel = 'Select two ' + (shipType.pluralName ? shipType.pluralName.toLowerCase() : 'items') + ' to compare';
        var chooseLabel = 'Choose Different ' + (shipType.pluralName || 'Items');
      %>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/">Home</a></li>
          <li class="breadcrumb-item"><a href="/fleet"><%= shipType.listTitle %></a></li>
          <li class="breadcrumb-item active">Compare</li>
        </ol>
      </nav>
      <h1 class="mb-4"><%= compareTitle %></h1>
      <% if (!ship1 || !ship2) { %>
        <div class="card mb-4">
          <div class="card-body">
            <h5 class="card-title"><%= selectLabel %></h5>
            <form action="/compare" method="GET" class="row g-2">
              <div class="col-md-5">
                <select name="id1" class="form-select" required>
                  <option value=""><%= shipType.displayName %> 1...</option>
                  <% (ships || []).forEach(function(s) { %>
                    <option value="<%= s.id %>" <%= (preselectedId == s.id) ? 'selected' : '' %>><%= s.name %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-5">
                <select name="id2" class="form-select" required>
                  <option value=""><%= shipType.displayName %> 2...</option>
                  <% (ships || []).forEach(function(s) { %>
                    <option value="<%= s.id %>" <%= (preselectedId == s.id) ? 'disabled' : '' %>><%= s.name %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-2">
                <button type="submit" class="btn btn-dark w-100">Compare</button>
              </div>
            </form>
          </div>
        </div>
        <% if (ship1) { %>
        <div class="alert alert-info">Select a second <%= shipType.displayName.toLowerCase() %> above to compare with <strong><%= ship1.name %></strong>.</div>
        <% } %>
      <% } %>
      <% if (ship1 && ship2) {
        var e1 = toEntity(ship1, 'ship');
        var e2 = toEntity(ship2, 'ship');
      %>
      <div class="row g-4">
        <div class="col-md-6">
          <%- include('partials/entity-card', { entity: e1, size: 'md', cols: 'col-12', showSubtitle: true, showDescription: 200 }) %>
        </div>
        <div class="col-md-6">
          <%- include('partials/entity-card', { entity: e2, size: 'md', cols: 'col-12', showSubtitle: true, showDescription: 200 }) %>
        </div>
      </div>
      <div class="mt-4">
        <a href="/compare" class="btn btn-outline-dark"><%= chooseLabel %></a>
      </div>
      <% } %>
    </div>
  </main>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
