<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <style>
    .key-display {
      font-family: monospace;
      font-size: 0.85rem;
      background: #f0f9ff;
      border: 1px solid #bae6fd;
      border-radius: 8px;
      padding: 0.75rem 1rem;
      word-break: break-all;
      color: #0c4a6e;
    }
    .balance-badge {
      font-size: 2rem;
      font-weight: 700;
      color: #0284c7;
    }
    .tx-row { border-bottom: 1px solid #f0f9ff; padding: 0.5rem 0; }
    .tx-row:last-child { border-bottom: none; }
    .badge-approved { background: #dcfce7; color: #15803d; border-radius: 6px; padding: 2px 8px; font-size: 0.78rem; font-weight: 600; }
    .badge-pending  { background: #fef9c3; color: #a16207; border-radius: 6px; padding: 2px 8px; font-size: 0.78rem; font-weight: 600; }
    .badge-declined { background: #fee2e2; color: #b91c1c; border-radius: 6px; padding: 2px 8px; font-size: 0.78rem; font-weight: 600; }
    .step-num { width: 28px; height: 28px; border-radius: 50%; background: var(--blue); color: white; display: inline-flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; flex-shrink: 0; }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <h1 class="mb-1">Payment Account</h1>
      <p class="text-muted mb-4">Create a wallet account, add funds, and pay from your balance on <a href="/donate">Donate</a> and <a href="/checkout">Checkout</a>.</p>

      <div class="row g-4">
        <!-- LEFT: Create or load account -->
        <div class="col-lg-5">

          <!-- Create Account -->
          <div class="card mb-4" id="createCard">
            <div class="card-header d-flex align-items-center gap-2">
              <span class="step-num">1</span> Create Account
            </div>
            <div class="card-body">
              <form id="registerForm">
                <div class="mb-3">
                  <label class="form-label fw-semibold">Name</label>
                  <input type="text" id="regName" class="form-control" placeholder="e.g. Admiral Nelson" required>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-semibold">ID <span class="text-muted fw-normal">(unique identifier)</span></label>
                  <input type="text" id="regEmail" class="form-control" placeholder="e.g. nelson@navy.uk" required>
                </div>
                <button type="submit" class="btn btn-modern w-100">Generate Account</button>
              </form>
              <div id="registerResult" class="mt-3"></div>
            </div>
          </div>

          <!-- Load existing account -->
          <div class="card mb-4">
            <div class="card-header d-flex align-items-center gap-2">
              <span class="step-num">2</span> Load Existing Account
            </div>
            <div class="card-body">
              <div class="mb-3">
                <label class="form-label fw-semibold">API Key</label>
                <input type="text" id="apiKeyInput" class="form-control font-monospace" placeholder="sk_live_..." autocomplete="off">
              </div>
              <button class="btn btn-modern w-100" onclick="loadAccount()">Load Account</button>
              <div id="loadResult" class="mt-3"></div>
            </div>
          </div>

        </div>

        <!-- RIGHT: Account dashboard (hidden until loaded) -->
        <div class="col-lg-7" id="dashboard" style="display:none;">

          <!-- Balance card -->
          <div class="card mb-4">
            <div class="card-body text-center py-4">
              <div class="text-muted mb-1">Account Balance</div>
              <div class="balance-badge" id="balanceDisplay">$0.00</div>
              <div class="text-muted small mt-1" id="accountLabel"></div>
            </div>
          </div>

          <div class="row g-3 mb-4">
            <!-- Add Funds -->
            <div class="col-md-6">
              <div class="card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                  <span class="step-num">3</span> Add Funds
                </div>
                <div class="card-body">
                  <div class="mb-3">
                    <label class="form-label fw-semibold">Amount (USD)</label>
                    <input type="number" id="fundAmount" class="form-control" value="100" min="1" step="1">
                  </div>
                  <button class="btn btn-modern w-100" onclick="addFunds()">Top Up</button>
                  <div id="fundResult" class="mt-2"></div>
                </div>
              </div>
            </div>

            <!-- Make Payment -->
            <div class="col-md-6">
              <div class="card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                  <span class="step-num">4</span> Make Payment
                </div>
                <div class="card-body">
                  <div class="mb-2">
                    <label class="form-label fw-semibold">Amount (USD)</label>
                    <input type="number" id="payAmount" class="form-control" value="25" min="0.01" step="0.01">
                  </div>
                  <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <input type="text" id="payDesc" class="form-control" value="Museum donation">
                  </div>
                  <button class="btn btn-modern w-100" onclick="makePayment()">Pay from Balance</button>
                  <div id="payResult" class="mt-2"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Transaction history -->
          <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between">
              <span>Transaction History</span>
              <button class="btn btn-sm btn-outline-secondary" onclick="loadHistory()">
                <i class="bi bi-arrow-clockwise"></i> Refresh
              </button>
            </div>
            <div class="card-body p-0" id="historyList">
              <div class="p-3 text-muted text-center small">No transactions yet</div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function escapeHtml(s) {
      var d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }
    let currentApiKey = localStorage.getItem('paymentAccountKey') || '';
    if (currentApiKey) {
      document.getElementById('apiKeyInput').value = currentApiKey;
      loadAccount();
    }

    // ── Register ──────────────────────────────────────────────────────────────
    document.getElementById('registerForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = document.getElementById('regName').value.trim();
      const email = document.getElementById('regEmail').value.trim();
      const el = document.getElementById('registerResult');
      el.innerHTML = '<span class="text-muted">Creating account...</span>';
      try {
        const res = await fetch('/api/accounts/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email })
        });
        const data = await res.json();
        if (!res.ok) {
          el.innerHTML = `<div class="alert alert-danger py-2">${data.error || 'Registration failed'}</div>`;
          return;
        }
        // Store key, show it once
        currentApiKey = data.apiKey;
        localStorage.setItem('paymentAccountKey', currentApiKey);
        document.getElementById('apiKeyInput').value = currentApiKey;
        el.innerHTML = `
          <div class="alert alert-success py-2 mb-2">✓ Account created!</div>
          <div class="mb-1 fw-semibold small">Your API Key <span class="text-danger">(save this — shown once)</span>:</div>
          <div class="key-display mb-2" id="newApiKeyDisplay">${escapeHtml(String(data.apiKey || ''))}</div>
          <button class="btn btn-sm btn-outline-secondary" id="copyKeyBtn" type="button">
            <i class="bi bi-clipboard"></i> Copy Key
          </button>`;
        document.getElementById('copyKeyBtn').onclick = function() {
          var key = document.getElementById('newApiKeyDisplay').textContent;
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(key).then(function() { this.textContent = 'Copied!'; }.bind(this));
          } else { this.textContent = 'Copied!'; }
        };
        loadDashboard(data);
      } catch (err) {
        el.innerHTML = '<div class="alert alert-danger py-2">Account service unavailable</div>';
      }
    });

    // ── Load existing account ─────────────────────────────────────────────────
    async function loadAccount() {
      const key = document.getElementById('apiKeyInput').value.trim();
      if (!key) return;
      const el = document.getElementById('loadResult');
      el.innerHTML = '<span class="text-muted small">Loading...</span>';
      try {
        const res = await fetch('/api/accounts/me', {
          headers: { 'X-API-Key': key }
        });
        const data = await res.json();
        if (!res.ok) {
          el.innerHTML = `<div class="alert alert-danger py-2 small">${data.error || 'Invalid key'}</div>`;
          return;
        }
        currentApiKey = key;
        localStorage.setItem('paymentAccountKey', key);
        el.innerHTML = `<div class="alert alert-success py-2 small">✓ Loaded: ${data.name}</div>`;
        loadDashboard(data);
      } catch (err) {
        el.innerHTML = '<div class="alert alert-danger py-2 small">Account service unavailable</div>';
      }
    }

    // ── Dashboard ─────────────────────────────────────────────────────────────
    function loadDashboard(data) {
      document.getElementById('dashboard').style.display = '';
      updateBalance(data.balance || 0, data.name, data.accountId);
      loadHistory();
    }

    function updateBalance(balance, name, accountId) {
      document.getElementById('balanceDisplay').textContent = '$' + balance.toFixed(2);
      document.getElementById('accountLabel').textContent = (name || '') + (accountId ? '  ·  ' + accountId : '');
    }

    // ── Add Funds ─────────────────────────────────────────────────────────────
    async function addFunds() {
      const amount = parseFloat(document.getElementById('fundAmount').value);
      const el = document.getElementById('fundResult');
      if (!amount || amount <= 0) { el.innerHTML = '<div class="text-danger small">Enter a valid amount</div>'; return; }
      el.innerHTML = '<span class="text-muted small">Processing...</span>';
      try {
        const res = await fetch('/api/accounts/funds', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-API-Key': currentApiKey },
          body: JSON.stringify({ amount })
        });
        const data = await res.json();
        if (!res.ok) {
          el.innerHTML = `<div class="text-danger small">${data.error || 'Failed'}</div>`;
          return;
        }
        el.innerHTML = `<div class="text-success small">✓ +$${amount.toFixed(2)} added</div>`;
        document.getElementById('balanceDisplay').textContent = '$' + (data.balance != null ? Number(data.balance).toFixed(2) : '0.00');
      } catch (err) {
        el.innerHTML = '<div class="text-danger small">Service unavailable</div>';
      }
    }

    // ── Make Payment ──────────────────────────────────────────────────────────
    async function makePayment() {
      const amount = parseFloat(document.getElementById('payAmount').value);
      const description = document.getElementById('payDesc').value || 'Payment';
      const el = document.getElementById('payResult');
      if (!amount || amount <= 0) { el.innerHTML = '<div class="text-danger small">Enter a valid amount</div>'; return; }
      el.innerHTML = '<span class="text-muted small">Processing...</span>';
      try {
        const res = await fetch('/api/payments/simulate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-API-Key': currentApiKey },
          body: JSON.stringify({ amount, currency: 'USD', description })
        });
        const data = await res.json();
        if (res.status === 402) {
          el.innerHTML = `<div class="text-danger small">Insufficient funds — add more balance first</div>`;
          return;
        }
        if (!res.ok) {
          el.innerHTML = `<div class="text-danger small">${data.error || 'Payment failed'}</div>`;
          return;
        }
        var msg = (res.status === 202 || data.status === 'queued') ? (data.message || 'Payment queued') : (data.message || 'Payment approved');
        el.innerHTML = `<div class="text-success small">✓ ${msg}${data.transactionId ? ' (' + data.transactionId + ')' : ''}</div>`;
        // Refresh balance + history after a short delay (queue processes async)
        setTimeout(() => { loadAccount(); loadHistory(); }, 1500);
      } catch (err) {
        el.innerHTML = '<div class="text-danger small">Payment service unavailable</div>';
      }
    }

    // ── History ───────────────────────────────────────────────────────────────
    async function loadHistory() {
      const el = document.getElementById('historyList');
      try {
        const res = await fetch('/api/accounts/history', {
          headers: { 'X-API-Key': currentApiKey }
        });
        if (!res.ok) { el.innerHTML = '<div class="p-3 text-muted small">No history available</div>'; return; }
        const items = await res.json();
        if (!items || items.length === 0) {
          el.innerHTML = '<div class="p-3 text-muted text-center small">No transactions yet</div>';
          return;
        }
        el.innerHTML = items.map(t => `
          <div class="tx-row px-3 d-flex align-items-center justify-content-between">
            <div>
              <div class="fw-semibold small">${t.description || 'Payment'}</div>
              <div class="text-muted" style="font-size:0.75rem">${t.transactionId} · ${new Date(t.createdAt).toLocaleString()}</div>
            </div>
            <div class="text-end">
              <div class="fw-bold">$${parseFloat(t.amount).toFixed(2)}</div>
              <span class="${t.status === 'completed' || t.approved ? 'badge-approved' : t.status === 'queued' ? 'badge-pending' : 'badge-declined'}">
                ${t.status === 'completed' || t.approved ? 'approved' : t.status || 'pending'}
              </span>
            </div>
          </div>`).join('');
      } catch (err) {
        el.innerHTML = '<div class="p-3 text-muted small">Could not load history</div>';
      }
    }
  </script>
</body>
</html>
