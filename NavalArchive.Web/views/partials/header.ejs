<header class="app-topbar" id="appTopbar">
  <div class="topbar-inner">
    <a href="/" class="topbar-brand">
      <div class="topbar-brand-icon">⚓</div>
      <span>Naval Archive</span>
    </a>
    <nav class="topbar-nav">
      <% (navItems || []).forEach(function(item) { %>
      <% if (item.items) { %>
      <div class="topbar-dropdown" onclick="if(window.innerWidth<=991) this.classList.toggle('expanded')">
        <button type="button" class="topbar-dropdown-trigger" aria-haspopup="true" aria-expanded="false">
          <i class="bi bi-<%= item.label === 'Explore' ? 'compass' : item.label === 'Support' ? 'heart' : item.label === 'Member' ? 'person' : item.label === 'Cart' ? 'cart' : 'folder2-open' %>"></i>
          <span><%= item.label %></span>
        </button>
        <div class="topbar-dropdown-menu" role="menu">
          <% item.items.forEach(function(sub) { %>
          <a href="<%= sub.href %>" role="menuitem" class="<%= (currentPath === sub.href || (sub.href !== '/' && currentPath.startsWith(sub.href))) ? ' active' : '' %>">
            <i class="bi bi-<%= sub.href.includes('fleet') ? 'ship' : sub.href.includes('captains') ? 'person' : sub.href.includes('timeline') ? 'calendar' : sub.href.includes('gallery') ? 'images' : sub.href.includes('stats') ? 'bar-chart' : sub.href.includes('logs') ? 'journal' : sub.href.includes('classes') ? 'collection' : sub.href.includes('compare') ? 'arrow-left-right' : 'folder' %>"></i>
            <%= sub.label %>
          </a>
          <% }); %>
        </div>
      </div>
      <% } else if (item.href) { %>
      <a class="topbar-link<%= (currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))) ? ' active' : '' %>" href="<%= item.href %>">
        <i class="bi bi-<%= item.href === '/' ? 'house-door' : item.href.includes('simulation') ? 'controller' : item.href.includes('donate') ? 'heart' : item.href.includes('cart') ? 'cart' : 'link-45deg' %>"></i>
        <span><%= item.label %></span>
      </a>
      <% } %>
      <% }); %>
    </nav>
    <div class="topbar-right">
      <a href="/admin/images" class="topbar-link admin-only text-decoration-none">
        <i class="bi bi-images"></i>
        <span>Audit</span>
      </a>
      <a href="/admin/add-from-url" class="topbar-link admin-only text-decoration-none">
        <i class="bi bi-plus-circle"></i>
        <span>Add from URL</span>
      </a>
      <label class="topbar-admin" title="Admin mode" style="cursor: pointer;">
        <input class="form-check-input" type="checkbox" id="adminModeToggle">
        <i class="bi bi-shield-lock"></i>
        <span>Admin</span>
      </label>
      <button class="topbar-toggle" type="button" aria-label="Toggle menu" onclick="document.getElementById('appTopbar').classList.toggle('expanded')">
        <i class="bi bi-list"></i>
      </button>
    </div>
  </div>
</header>
<div class="main-content">
<script>
(function(){
  var key = 'adminMode';
  var toggle = document.getElementById('adminModeToggle');
  if (!toggle) return;
  if (localStorage.getItem(key) === 'true') {
    document.body.classList.add('admin-mode');
    toggle.checked = true;
  }
  toggle.addEventListener('change', function() {
    if (toggle.checked) {
      localStorage.setItem(key, 'true');
      document.body.classList.add('admin-mode');
    } else {
      localStorage.removeItem(key);
      document.body.classList.remove('admin-mode');
    }
    window.dispatchEvent(new CustomEvent('adminModeChanged', { detail: { enabled: toggle.checked } }));
  });
})();
</script>
