<header class="app-topbar" id="appTopbar">
  <div class="topbar-inner">
    <a href="/" class="topbar-brand">
      <div class="topbar-brand-icon">⚓</div>
      <span>Naval Archive</span>
    </a>
    <nav class="topbar-nav">
      <% (navItems || []).forEach(function(item) { %>
      <% if (item.items) { %>
      <div class="topbar-dropdown" onclick="if(window.innerWidth<=991) this.classList.toggle('expanded')">
        <button type="button" class="topbar-dropdown-trigger" aria-haspopup="true" aria-expanded="false">
          <i class="bi bi-<%= item.label === 'Explore' ? 'compass' : item.label === 'Support' ? 'heart' : item.label === 'Member' ? 'person' : item.label === 'Cart' ? 'cart' : 'folder2-open' %>"></i>
          <span><%= item.label %></span>
        </button>
        <div class="topbar-dropdown-menu" role="menu">
          <% item.items.forEach(function(sub) { %>
          <a href="<%= sub.href %>" role="menuitem" class="<%= (currentPath === sub.href || (sub.href !== '/' && currentPath.startsWith(sub.href))) ? ' active' : '' %>">
            <i class="bi bi-<%= sub.href.includes('fleet') ? 'ship' : sub.href.includes('captains') ? 'person' : sub.href.includes('timeline') ? 'calendar' : sub.href.includes('gallery') ? 'images' : sub.href.includes('stats') ? 'bar-chart' : sub.href.includes('logs') ? 'journal' : sub.href.includes('classes') ? 'collection' : sub.href.includes('compare') ? 'arrow-left-right' : sub.href.includes('login') ? 'box-arrow-in-right' : sub.href.includes('donate') ? 'heart' : sub.href.includes('payment-account') ? 'wallet2' : 'folder' %>"></i>
            <%= sub.label %>
          </a>
          <% }); %>
        </div>
      </div>
      <% } else if (item.href) { %>
      <a class="topbar-link<%= (currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))) ? ' active' : '' %>" href="<%= item.href %>">
        <i class="bi bi-<%= item.href === '/' ? 'house-door' : item.href.includes('simulation') ? 'controller' : item.href.includes('donate') ? 'heart' : item.href.includes('members') ? 'person' : item.href.includes('cart') ? 'cart' : 'link-45deg' %>"></i>
        <span><%= item.label %></span>
      </a>
      <% } %>
      <% }); %>
    </nav>
    <div class="topbar-right">
      <div id="accountStatus" style="display:none; align-items:center; gap:6px; font-size:0.8rem; white-space:nowrap;">
        <i class="bi bi-person-circle"></i>
        <a href="/payment-account" id="accountStatusName" style="max-width:120px; overflow:hidden; text-overflow:ellipsis; color:inherit; text-decoration:none; cursor:pointer;" title="Account – top up, view balance &amp; ID"></a>
        <button onclick="signOutAccount()" style="background:none;border:1px solid currentColor;border-radius:4px;padding:1px 7px;font-size:0.75rem;cursor:pointer;opacity:0.8;" title="Sign out">Sign out</button>
      </div>
      <a href="/admin/images" class="topbar-link admin-only text-decoration-none">
        <i class="bi bi-images"></i>
        <span>Audit</span>
      </a>
      <a href="/admin/add-from-url" class="topbar-link admin-only text-decoration-none">
        <i class="bi bi-plus-circle"></i>
        <span>Add from URL</span>
      </a>
      <button class="topbar-toggle" type="button" aria-label="Toggle menu" onclick="document.getElementById('appTopbar').classList.toggle('expanded')">
        <i class="bi bi-list"></i>
      </button>
    </div>
  </div>
</header>
<div class="main-content">
<script>
(function(){
  var name = localStorage.getItem('paymentAccountName');
  var acctKey = localStorage.getItem('paymentAccountKey');
  if (name && acctKey) {
    var el = document.getElementById('accountStatus');
    var nameEl = document.getElementById('accountStatusName');
    if (el && nameEl) { nameEl.textContent = name; el.style.display = 'flex'; }
  }
})();
function signOutAccount() {
  localStorage.removeItem('paymentAccountKey');
  localStorage.removeItem('paymentAccountName');
  var el = document.getElementById('accountStatus');
  if (el) el.style.display = 'none';
}
</script>
