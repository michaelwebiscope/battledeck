<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>WW2 Naval History Archive</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-start: #0c1222;
    --bg-end: #171f34;
    --surface: #f4f7fb;
    --text: #1a2332;
    --muted: #64748b;
    --brand: #4f7cff;
    --brand-2: #7b61ff;
    --navy-dark: #121b2f;
    --glass: rgba(255, 255, 255, 0.72);
  }
  body {
    font-family: 'Source Sans 3', sans-serif;
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background:
      radial-gradient(1200px 500px at 12% -10%, rgba(123, 97, 255, 0.20), transparent 65%),
      radial-gradient(1000px 500px at 95% 0%, rgba(79, 124, 255, 0.20), transparent 65%),
      linear-gradient(180deg, var(--bg-start), var(--bg-end));
  }
  h1, h2, h3, .display-4, .display-5 {
    font-family: 'Cormorant Garamond', serif;
    color: var(--text);
    letter-spacing: 0.01em;
  }
  .navbar-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.35rem;
  }
  .navbar {
    background: rgba(9, 14, 25, 0.78) !important;
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .navbar-toggler {
    color: rgba(255, 255, 255, 0.9);
    border-radius: 12px;
  }
  .navbar-toggler:focus { box-shadow: 0 0 0 0.15rem rgba(123, 97, 255, 0.45); }
  #navMain { background: transparent; }
  #navMain .nav-link {
    color: rgba(245, 248, 255, 0.9);
    border-radius: 10px;
    padding: 0.55rem 0.9rem;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  #navMain .nav-link:hover, #navMain .nav-link.active {
    color: #fff;
    background: rgba(123, 97, 255, 0.24);
    transform: translateX(2px);
  }
  main { flex: 1; }
  .app-shell {
    background: var(--surface);
    border-radius: 20px 20px 0 0;
    margin-top: 1rem;
    margin-left: 0.5rem;
    margin-right: 0.5rem;
    padding: 1.5rem 0 2rem;
    box-shadow: 0 20px 55px rgba(0, 0, 0, 0.22);
    min-height: 60vh;
  }
  main.app-shell.py-0 { padding: 0; margin-left: 0; margin-right: 0; }
  .card {
    border: 1px solid rgba(22, 34, 57, 0.08);
    border-radius: 16px;
    box-shadow: 0 12px 35px rgba(10, 18, 36, 0.08);
  }
  .card-header {
    background: var(--navy-dark);
    color: white;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
  }
  .glass-panel {
    background: var(--glass);
    border: 1px solid rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(10px);
  }
  .btn-modern {
    border: 0;
    color: #fff;
    background: linear-gradient(135deg, var(--brand), var(--brand-2));
    box-shadow: 0 10px 22px rgba(79, 124, 255, 0.35);
  }
  .btn-modern:hover {
    color: #fff;
    filter: brightness(1.06);
  }
  .img-placeholder {
    background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%);
    color: rgba(255,255,255,0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    text-align: center;
  }
</style>
