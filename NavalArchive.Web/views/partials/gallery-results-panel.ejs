<%
  var pg = typeof entityTypes !== 'undefined' && entityTypes.pages && entityTypes.pages.gallery ? entityTypes.pages.gallery : {};
  var emptyMsg = pg.emptyMessage || 'No images available. Ensure the API is running.';
%>
<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-warning"><%= error %></div>
<% } %>
<div class="row g-4">
  <% if (ships && ships.length > 0) { %>
    <% ships.forEach(function(ship) {
      var entity = toEntity(ship, 'ship');
      entity.subtitle = [ship.class ? ship.class.type : '', ship.yearCommissioned].filter(Boolean).join(' · ');
    %>
      <%- include('entity-card', { entity: entity, size: 'sm', variant: 'gallery', cols: 'col-md-4 col-lg-3', showSubtitle: true }) %>
    <% }); %>
  <% } else { %>
    <div class="col-12 text-center text-muted py-5"><%= emptyMsg %></div>
  <% } %>
</div>
<% if (typeof total !== 'undefined' && total > (pageSize || 100)) { %>
<%
  var _pageBase = typeof pageBasePath !== 'undefined' && pageBasePath ? pageBasePath : '/gallery';
  var _q = [];
  if (typeof searchQuery !== 'undefined' && searchQuery) _q.push('q=' + encodeURIComponent(searchQuery));
  if (typeof activeFilters !== 'undefined' && activeFilters && Object.keys(activeFilters).length) {
    _q.push('df=' + encodeURIComponent(JSON.stringify(activeFilters)));
  }
  var _qs = _q.length ? ('&' + _q.join('&')) : '';
  var totalPages = Math.ceil(total / (pageSize || 100));
  var _pagAria = typeof paginationAriaLabel !== 'undefined' && paginationAriaLabel ? paginationAriaLabel : 'Gallery pagination';
%>
<nav class="mt-3" data-dlf-pagination="1" aria-label="<%= _pagAria %>">
  <ul class="pagination justify-content-center mb-0">
    <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
      <a class="page-link" href="<%= page <= 1 ? '#' : _pageBase + '?page=' + (page - 1) + _qs %>">Previous</a>
    </li>
    <li class="page-item disabled"><span class="page-link">Page <%= page %> of <%= totalPages %> (<%= total %> images)</span></li>
    <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
      <a class="page-link" href="<%= page >= totalPages ? '#' : _pageBase + '?page=' + (page + 1) + _qs %>">Next</a>
    </li>
  </ul>
</nav>
<% } %>
