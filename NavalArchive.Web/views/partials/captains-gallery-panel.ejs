<%
  var captainType = typeof entityTypes !== 'undefined' && entityTypes.captain ? entityTypes.captain : {};
  var emptyMessage = captainType.emptyMessage || 'None found.';
%>
<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-warning"><%= error %></div>
<% } %>
<div class="row g-4 captains-grid">
  <% if (captains && captains.length > 0) { %>
    <% captains.forEach(function(c) {
      var capId = c.id || c.Id;
      var capName = (c.name || c.Name || 'Unnamed').replace(/"/g, '&quot;');
    %>
      <div class="col-6 col-sm-4 col-md-3 col-lg-2 captain-card-wrap">
        <a href="#" class="captain-name d-block captain-view-link" data-id="<%= capId %>" title="<%= capName %>"><%= c.name || c.Name || 'Unnamed' %></a>
        <div class="captain-edit-card edit-card" data-entity="captain" data-id="<%= capId %>" data-name="<%= capName %>">
          <div class="img-wrap">
            <img src="/gallery/captain/<%= capId %>?v=<%= (c.imageVersion != null ? c.imageVersion : c.ImageVersion) || 0 %>" alt="" class="edit-thumb" onerror="this.onerror=null;this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22160%22 viewBox=%220 0 200 160%22%3E%3Crect fill=%22%236c757d%22 width=%22200%22 height=%22160%22/%3E%3Ctext fill=%22%23fff%22 x=%22100%22 y=%2280%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 font-size=%2212%22%3ENo image%3C/text%3E%3C/svg%3E';">
          </div>
        </div>
      </div>
    <% }); %>
  <% } else { %>
    <div class="col-12 text-center text-muted py-5"><%= emptyMessage %></div>
  <% } %>
</div>
<% if (typeof total !== 'undefined' && total > (pageSize || 100)) { %>
<% var _pageBase = typeof pageBasePath !== 'undefined' && pageBasePath ? pageBasePath : '/captains'; var _fq = []; if (typeof searchQuery !== 'undefined' && searchQuery) _fq.push('q=' + encodeURIComponent(searchQuery)); if (typeof activeFilters !== 'undefined' && activeFilters && Object.keys(activeFilters).length) _fq.push('df=' + encodeURIComponent(JSON.stringify(activeFilters))); var _fqs = _fq.length ? ('&' + _fq.join('&')) : ''; var totalPages = Math.ceil(total / (pageSize || 100)); var _pagAria = typeof paginationAriaLabel !== 'undefined' && paginationAriaLabel ? paginationAriaLabel : 'Captains pagination'; %>
<nav class="mt-3" data-dlf-pagination="1" aria-label="<%= _pagAria %>">
  <ul class="pagination justify-content-center mb-0">
    <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
      <a class="page-link" href="<%= page <= 1 ? '#' : _pageBase + '?page=' + (page - 1) + _fqs %>">Previous</a>
    </li>
    <li class="page-item disabled"><span class="page-link">Page <%= page %> of <%= totalPages %> (<%= total %> <%= captainType.pluralName ? captainType.pluralName.toLowerCase() : 'captains' %>)</span></li>
    <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
      <a class="page-link" href="<%= page >= totalPages ? '#' : _pageBase + '?page=' + (page + 1) + _fqs %>">Next</a>
    </li>
  </ul>
</nav>
<% } %>
