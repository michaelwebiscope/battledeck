<%
  var classType = typeof entityTypes !== 'undefined' && entityTypes['class'] ? entityTypes['class'] : {};
  var emptyMessage = classType.emptyMessage || 'None found.';
  var countLabel = classType.countLabel || 'in class';
  var shipPlural = (typeof entityTypes !== 'undefined' && entityTypes.ship && entityTypes.ship.pluralName) ? entityTypes.ship.pluralName.toLowerCase() : 'ships';
  var pluralLower = classType.pluralName ? String(classType.pluralName).toLowerCase() : 'classes';
%>
<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-warning"><%= error %></div>
<% } %>
<div class="row g-4">
  <% if (classes && classes.length > 0) { %>
    <% (Array.isArray(classes) ? classes : []).forEach(function(c) {
      var cid = c.id ?? c.Id;
      var cname = c.name ?? c.Name ?? '';
      var ctype = c.type ?? c.Type ?? '-';
      var ccountry = c.country ?? c.Country ?? '-';
      var ccount = c.shipCount ?? c.ShipCount ?? 0;
    %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><%= cname %></h5>
            <p class="card-text text-muted mb-1"><%= ctype %> · <%= ccountry %></p>
            <p class="card-text small mb-2"><%= ccount %> <%= shipPlural %> <%= countLabel %></p>
            <a href="/classes/<%= cid %>" class="btn btn-outline-dark btn-sm">View <%= shipPlural %></a>
            <a href="/classes/<%= cid %>" class="btn btn-outline-secondary btn-sm admin-only ms-1">Edit</a>
          </div>
        </div>
      </div>
    <% }); %>
  <% } else { %>
    <div class="col-12 text-center text-muted py-5"><%= emptyMessage %></div>
  <% } %>
</div>
<% if (typeof total !== 'undefined' && total > (pageSize || 100)) { %>
<% var _pageBase = typeof pageBasePath !== 'undefined' && pageBasePath ? pageBasePath : '/classes'; var _fq = []; if (typeof searchQuery !== 'undefined' && searchQuery) _fq.push('q=' + encodeURIComponent(searchQuery)); if (typeof activeFilters !== 'undefined' && activeFilters && Object.keys(activeFilters).length) _fq.push('df=' + encodeURIComponent(JSON.stringify(activeFilters))); var _fqs = _fq.length ? ('&' + _fq.join('&')) : ''; var totalPages = Math.ceil(total / (pageSize || 100)); var _pagAria = typeof paginationAriaLabel !== 'undefined' && paginationAriaLabel ? paginationAriaLabel : 'Ship classes pagination'; %>
<nav class="mt-3" data-dlf-pagination="1" aria-label="<%= _pagAria %>">
  <ul class="pagination justify-content-center mb-0">
    <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
      <a class="page-link" href="<%= page <= 1 ? '#' : _pageBase + '?page=' + (page - 1) + _fqs %>">Previous</a>
    </li>
    <li class="page-item disabled"><span class="page-link">Page <%= page %> of <%= totalPages %> (<%= total %> <%= pluralLower %>)</span></li>
    <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
      <a class="page-link" href="<%= page >= totalPages ? '#' : _pageBase + '?page=' + (page + 1) + _fqs %>">Next</a>
    </li>
  </ul>
</nav>
<% } %>
