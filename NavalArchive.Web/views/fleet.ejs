<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <%- include('partials/dynamic-list-filters-head') %>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <%
        var shipType = typeof entityTypes !== 'undefined' && entityTypes.ship ? entityTypes.ship : {};
        var listTitle = shipType.listTitle || 'Fleet Roster';
        var listCardTitle = shipType.listCardTitle || 'Complete Registry';
        var searchPlaceholder = shipType.searchPlaceholder || 'Search by name or description...';
        var emptyMessage = shipType.emptyMessage || 'None loaded.';
        var listColumns = shipType.listColumns || [];
      %>
      <h1 class="mb-4"><%= listTitle %></h1>
      <%
        var _dlfNoFleet = '<p class="small text-muted mb-3">Dynamic filters are built from the ship list returned by the API (<code>/api/ships</code>). If you only see search, the API at <code>' + (typeof apiBase !== 'undefined' ? apiBase : '') + '</code> is not returning ships (unreachable, error, or empty).</p>';
      %>
      <%- include('partials/dynamic-list-filters', {
        dlfRuntimeDefault: Object.assign(
          {
            listId: 'fleet',
            pageBasePath: '/fleet',
            partialPath: '/fleet/partial',
            summaryAllLabel: 'Showing all ships',
            domPrefix: 'fleet',
            resultsPanelId: 'fleetResultsPanel',
            paginationAriaLabel: 'Fleet pagination'
          },
          typeof dynamicListRuntime !== 'undefined' && dynamicListRuntime ? dynamicListRuntime : {}
        ),
        dlfListId: 'fleet',
        dlfDomPrefix: 'fleet',
        dlfResultsPanelId: 'fleetResultsPanel',
        dlfSearchPlaceholder: searchPlaceholder,
        dlfFormAction: '/fleet',
        dlfSearchAriaLabel: 'Search fleet',
        dlfSearchInputTitle: 'Search fleet (results update as you type)',
        dlfHiddenRestoreEmpty: 'No fields match the current ship data.',
        dlfNoFiltersHtml: _dlfNoFleet
      }) %>
      <div id="fleetResultsPanel" class="fleet-results-panel">
      <%- include('partials/fleet-results-panel') %>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
  <style>#fleetBulkBar.fleet-bulk-hidden{display:none!important}</style>
  <div id="fleetBulkBar" class="admin-only fleet-bulk-hidden" style="position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); z-index: 1050; box-shadow: 0 4px 20px rgba(0,0,0,0.15); border-radius: 8px; padding: 12px 20px; background: #fff; border: 1px solid #dee2e6;">
    <span class="me-3"><strong id="fleetBulkCount">0</strong> selected</span>
    <button type="button" class="btn btn-sm btn-outline-secondary me-2" id="fleetBulkDeselect">Deselect all</button>
    <button type="button" class="btn btn-sm btn-outline-primary me-2" id="fleetBulkImages">Change images</button>
    <button type="button" class="btn btn-sm btn-outline-danger" id="fleetBulkDelete">Delete from database</button>
  </div>
  <%- include('partials/dynamic-list-filters-scripts') %>

  <div id="fleetBulkModal" class="modal fade" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Bulk actions</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body" id="fleetBulkModalBody">
          <div id="fleetBulkImagesPane">
            <p class="text-muted small">Apply the same image to all selected ships.</p>
            <div class="mb-3">
              <label class="form-label">Image URL</label>
              <input type="url" id="fleetBulkImageUrl" class="form-control" placeholder="https://...">
            </div>
            <div class="d-flex flex-wrap gap-2 align-items-center">
              <button type="button" class="btn btn-primary" id="fleetBulkApplyUrl">Apply URL</button>
              <button type="button" class="btn btn-outline-primary" id="fleetBulkSearchBtn">Search & apply</button>
              <span class="small" id="fleetBulkUrlStatus"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div id="fleetBulkSearchOverlay" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; z-index:9999; background:#fff;">
    <div class="position-absolute top-0 end-0 p-2">
      <button type="button" class="btn btn-sm btn-outline-secondary" id="fleetBulkSearchClose" title="Close">✕</button>
    </div>
    <iframe id="fleetBulkSearchFrame" style="width:100%; height:100%; border:none;" title="Search image"></iframe>
  </div>

  <script>
  (function() {
    var bulkBar = document.getElementById('fleetBulkBar');
    var bulkCount = document.getElementById('fleetBulkCount');
    var bulkModal = document.getElementById('fleetBulkModal');
    var bulkSearchOverlay = document.getElementById('fleetBulkSearchOverlay');
    var bulkSearchFrame = document.getElementById('fleetBulkSearchFrame');
    function getSelected() {
      var ids = [];
      document.querySelectorAll('.fleet-ship-chk:checked').forEach(function(c) { ids.push(parseInt(c.value, 10)); });
      return ids;
    }
    function getSelectedRows() {
      var rows = [];
      document.querySelectorAll('.fleet-ship-chk:checked').forEach(function(c) {
        var row = c.closest('tr');
        if (row) rows.push({ id: parseInt(c.value, 10), name: row.dataset.shipName || '', row: row });
      });
      return rows;
    }
    function updateBulkBar() {
      var ids = getSelected();
      if (bulkBar && bulkCount) {
        bulkCount.textContent = ids.length;
        bulkBar.classList.toggle('fleet-bulk-hidden', ids.length === 0);
      }
    }
    document.addEventListener('change', function(e) {
      var t = e.target;
      if (t && t.id === 'fleetSelectAll') {
        document.querySelectorAll('.fleet-ship-chk').forEach(function(c) { c.checked = t.checked; });
        updateBulkBar();
        return;
      }
      if (t && t.classList && t.classList.contains('fleet-ship-chk')) updateBulkBar();
    });
    document.getElementById('fleetBulkDeselect')?.addEventListener('click', function() {
      document.querySelectorAll('.fleet-ship-chk').forEach(function(c) { c.checked = false; });
      var sel = document.getElementById('fleetSelectAll');
      if (sel) sel.checked = false;
      updateBulkBar();
    });
    document.getElementById('fleetBulkDelete')?.addEventListener('click', function() {
      var rows = getSelectedRows();
      if (rows.length === 0) return;
      if (!confirm('Delete ' + rows.length + ' ship(s) from the database? This cannot be undone.')) return;
      var btn = this;
      btn.disabled = true;
      var done = 0, failed = 0;
      var errMsg = '';
      function deleteNext() {
        if (done + failed >= rows.length) {
          var deselect = document.getElementById('fleetBulkDeselect');
          if (deselect) deselect.click();
          btn.disabled = false;
          if (failed > 0) {
            alert('Delete failed for ' + failed + ' ship(s). ' + (errMsg ? errMsg : 'Check console. Restart the API if you see 405.'));
          }
          location.reload();
          return;
        }
        var r = rows[done + failed];
        fetch('/api/ships/' + r.id, { method: 'DELETE' })
          .then(function(res) {
            return res.json().catch(function() { return {}; }).then(function(data) {
              if (!res.ok) {
                errMsg = (data && data.error) ? data.error : ('HTTP ' + res.status);
                if (res.status === 405) errMsg = 'API may need restart (405 Method Not Allowed).';
                throw new Error(errMsg);
              }
              done++;
              deleteNext();
            });
          })
          .catch(function(e) {
            failed++;
            if (e && e.message) errMsg = e.message;
            deleteNext();
          });
      }
      deleteNext();
    });
    document.getElementById('fleetBulkImages')?.addEventListener('click', function() {
      var ids = getSelected();
      if (ids.length === 0) return;
      new bootstrap.Modal(bulkModal).show();
      document.getElementById('fleetBulkImageUrl').value = '';
      document.getElementById('fleetBulkUrlStatus').textContent = '';
    });
    document.getElementById('fleetBulkSearchClose')?.addEventListener('click', function() {
      bulkSearchOverlay.style.display = 'none';
      bulkSearchFrame.src = 'about:blank';
    });
    document.getElementById('fleetBulkSearchBtn')?.addEventListener('click', function() {
      var ids = getSelected();
      if (ids.length === 0) return;
      var firstId = ids[0];
      var row = document.querySelector('tr[data-ship-id="' + firstId + '"]');
      var name = row ? (row.dataset.shipName || '') : '';
      bulkSearchOverlay.style.display = 'block';
      bulkSearchFrame.src = '/admin/images/search-frame?entity=ship&id=' + firstId + '&q=' + encodeURIComponent(name + ' battleship');
      bootstrap.Modal.getInstance(bulkModal).hide();
    });
    document.getElementById('fleetBulkApplyUrl')?.addEventListener('click', function() {
      var url = document.getElementById('fleetBulkImageUrl').value.trim();
      if (!url) { document.getElementById('fleetBulkUrlStatus').textContent = 'Enter a URL'; return; }
      var ids = getSelected();
      var btn = this;
      var status = document.getElementById('fleetBulkUrlStatus');
      btn.disabled = true;
      status.textContent = 'Applying...';
      var done = 0, failed = 0;
      var lastError = '';
      function applyNext() {
        if (done + failed >= ids.length) {
          status.textContent = 'Done. ' + done + ' updated, ' + failed + ' failed.' + (lastError ? ' (' + lastError + ')' : '');
          btn.disabled = false;
          setTimeout(function() {
            bootstrap.Modal.getInstance(bulkModal).hide();
            location.reload();
          }, 1500);
          return;
        }
        var id = ids[done + failed];
        fetch('/api/images/ship/' + id + '/from-url', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url: url })
        }).then(function(res) {
          return res.json().catch(function() { return {}; }).then(function(data) {
            if (!res.ok) {
              lastError = (data && data.error) ? data.error : ('HTTP ' + res.status);
              throw new Error(lastError);
            }
            done++;
            status.textContent = done + '/' + ids.length + '...';
            applyNext();
          });
        }).catch(function(e) {
          failed++;
          if (e && e.message) lastError = e.message;
          applyNext();
        });
      }
      applyNext();
    });
    window.addEventListener('message', function(e) {
      if (!e.data || e.data.type !== 'imageSelected' || e.data.entity !== 'ship') return;
      var ids = getSelected();
      if (ids.length === 0 || bulkSearchOverlay.style.display !== 'block') return;
      var url = e.data.url;
      if (!url) return;
      bulkSearchOverlay.style.display = 'none';
      bulkSearchFrame.src = 'about:blank';
      var done = 0, failed = 0;
      function applyNext() {
        if (done + failed >= ids.length) {
          location.reload();
          return;
        }
        var id = ids[done + failed];
        fetch('/api/images/ship/' + id + '/from-url', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url: url })
        }).then(function(res) {
          if (!res.ok) throw new Error('Failed');
          done++;
          applyNext();
        }).catch(function() { failed++; applyNext(); });
      }
      applyNext();
    });
  })();
  </script>
</body>
</html>
