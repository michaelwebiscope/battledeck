<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <style>
    .key-input { font-family: monospace; }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <h1 class="mb-4">Account Login</h1>
      <p class="lead text-muted mb-4">Sign in with your Payment Account API key to use <strong>Pay from Account</strong> on Donate and Checkout.</p>

      <div id="loginFormCard" class="card mb-3" style="max-width: 28rem;">
        <div class="card-body">
          <form id="loginForm">
            <div class="mb-3">
              <label class="form-label fw-semibold">API Key</label>
              <input type="password" id="apiKeyInput" class="form-control key-input" placeholder="sk_live_..." autocomplete="off" autofocus>
              <div class="form-text">Create an account on <a href="/payment-account">Payment Account</a> if you don't have one.</div>
            </div>
            <button type="submit" class="btn btn-primary">Sign in</button>
            <div id="loginResult" class="mt-3"></div>
          </form>
        </div>
      </div>

      <div id="signedInCard" class="card mb-3" style="max-width: 28rem; display: none;">
        <div class="card-body">
          <p class="mb-2">You're signed in as <strong id="signedInName">—</strong></p>
          <p class="text-muted small mb-3">Balance: <span id="signedInBalance">$0.00</span></p>
          <button type="button" class="btn btn-outline-danger" id="signOutBtn">Sign out</button>
        </div>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const PAYMENT_KEY = 'paymentAccountKey';
    const returnUrl = new URLSearchParams(location.search).get('return') || '/payment-account';

    function getStoredKey() {
      return localStorage.getItem(PAYMENT_KEY) || '';
    }

    function setStoredKey(key) {
      if (key) localStorage.setItem(PAYMENT_KEY, key);
      else localStorage.removeItem(PAYMENT_KEY);
    }

    function showSignedIn(data) {
      document.getElementById('loginFormCard').style.display = 'none';
      var card = document.getElementById('signedInCard');
      card.style.display = 'block';
      document.getElementById('signedInName').textContent = data.name || 'Account';
      document.getElementById('signedInBalance').textContent = '$' + (data.balance != null ? Number(data.balance).toFixed(2) : '0.00');
    }

    function showLoginForm() {
      document.getElementById('signedInCard').style.display = 'none';
      document.getElementById('loginFormCard').style.display = 'block';
      document.getElementById('loginResult').innerHTML = '';
      document.getElementById('apiKeyInput').value = '';
    }

    // On load: if key exists, verify and show signed-in state or login form
    (function init() {
      var key = getStoredKey();
      if (!key) {
        showLoginForm();
        return;
      }
      document.getElementById('apiKeyInput').value = key;
      var resultEl = document.getElementById('loginResult');
      resultEl.innerHTML = '<span class="text-muted">Checking...</span>';
      fetch('/api/accounts/me', { headers: { 'X-API-Key': key } })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(o) {
          if (o.ok) {
            showSignedIn(o.data);
          } else {
            resultEl.innerHTML = '<div class="alert alert-warning py-2 small">Invalid or expired key. Sign in with a valid key below or <a href="#" id="clearKeyLink">clear and try again</a>.</div>';
            document.getElementById('clearKeyLink').addEventListener('click', function(e) {
              e.preventDefault();
              setStoredKey('');
              showLoginForm();
            });
          }
        })
        .catch(function() {
          resultEl.innerHTML = '<div class="alert alert-danger py-2 small">Account service unavailable.</div>';
        });
    })();

    document.getElementById('loginForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      var key = document.getElementById('apiKeyInput').value.trim();
      var resultEl = document.getElementById('loginResult');
      if (!key) {
        resultEl.innerHTML = '<div class="alert alert-warning py-2 small">Enter your API key.</div>';
        return;
      }
      resultEl.innerHTML = '<span class="text-muted">Signing in...</span>';
      try {
        var res = await fetch('/api/accounts/me', { headers: { 'X-API-Key': key } });
        var data = await res.json();
        if (!res.ok) {
          resultEl.innerHTML = '<div class="alert alert-danger py-2 small">' + (data.error || 'Invalid API key') + '</div>';
          return;
        }
        setStoredKey(key);
        if (data.name) localStorage.setItem('paymentAccountName', data.name);
        resultEl.innerHTML = '<div class="alert alert-success py-2 small">Signed in. Redirecting...</div>';
        setTimeout(function() { window.location.href = returnUrl; }, 800);
      } catch (err) {
        resultEl.innerHTML = '<div class="alert alert-danger py-2 small">Account service unavailable.</div>';
      }
    });

    document.getElementById('signOutBtn').addEventListener('click', function() {
      setStoredKey('');
      showLoginForm();
    });
  </script>
</body>
</html>
