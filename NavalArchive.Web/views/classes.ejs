<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <%- include('partials/dynamic-list-filters-head') %>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <%
        var classType = typeof entityTypes !== 'undefined' && entityTypes['class'] ? entityTypes['class'] : {};
        var listTitle = classType.listTitle || 'Ship Classes';
        var searchPlaceholder = classType.searchPlaceholder || 'Search by name, type, or country…';
        var rtc = typeof dynamicListRuntime !== 'undefined' && dynamicListRuntime ? dynamicListRuntime : {};
        var _clBase = typeof pageBasePath !== 'undefined' ? pageBasePath : rtc.pageBasePath || '/classes';
        var _dlfPartial = typeof partialPath !== 'undefined' ? partialPath : rtc.partialPath || '/classes/partial';
      %>
      <h1 class="mb-4"><%= listTitle %></h1>
      <%
        var _dlfNoClasses = '<p class="small text-muted mb-3">Filters are built from <code>/api/classes</code>. If you only see search, the API at <code>' + (typeof apiBase !== 'undefined' ? apiBase : '') + '</code> is not returning ship classes.</p>';
      %>
      <%- include('partials/dynamic-list-filters', {
        dlfRuntimeDefault: Object.assign({}, rtc, {
          listId: 'classes',
          pageBasePath: '/classes',
          partialPath: '/classes/partial',
          summaryAllLabel: 'Showing all ship classes',
          domPrefix: 'classesDlf',
          resultsPanelId: 'classesResultsPanel',
          paginationAriaLabel: 'Ship classes pagination',
          refreshMode: 'serverPartial',
          adapterName: '',
          adapterOptions: {}
        }),
        dlfListId: 'classes',
        dlfDomPrefix: 'classesDlf',
        dlfResultsPanelId: 'classesResultsPanel',
        dlfSearchPlaceholder: searchPlaceholder,
        dlfFormAction: _clBase,
        dlfSearchAriaLabel: 'Search ship classes',
        dlfSearchInputTitle: 'Search (results update as you type)',
        dlfNoFiltersHtml: _dlfNoClasses
      }) %>
      <div id="<%= rtc.resultsPanelId || 'classesResultsPanel' %>" class="classes-results-panel">
      <%- include('partials/classes-results-panel') %>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
  <%- include('partials/dynamic-list-filters-scripts') %>
</body>
</html>
