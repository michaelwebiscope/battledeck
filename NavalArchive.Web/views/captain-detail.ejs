<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell">
    <div class="container py-4">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/">Home</a></li>
          <li class="breadcrumb-item"><a href="/captains">Captains</a></li>
          <li class="breadcrumb-item active"><%= captain.name %></li>
        </ol>
      </nav>
      <%
        var captainEntity = toEntity(captain, 'captain');
      %>
      <%- include('partials/entity-detail', { entity: captainEntity, imageHeight: 280, editButtonId: 'captainEditBtn' }) %>
      <h3 class="mb-3 mt-4">Ships Commanded</h3>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead class="table-light">
                <tr>
                  <th>Ship</th>
                  <th>Year Commissioned</th>
                  <th></th>
                  <th class="admin-only"></th>
                </tr>
          </thead>
          <tbody>
            <% if (captain.ships && captain.ships.length > 0) { %>
              <% captain.ships.forEach(function(ship) { %>
                <tr>
                  <td><strong><%= ship.name %></strong></td>
                  <td><%= ship.yearCommissioned %></td>
                  <td><a href="/ships/<%= ship.id %>" class="btn btn-outline-dark btn-sm">Details</a></td>
                  <td class="admin-only"><a href="/ships/<%= ship.id %>" class="btn btn-outline-secondary btn-sm">Edit</a></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr><td colspan="4" class="text-center text-muted py-3">No ships on record.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <%- include('partials/image-lightbox') %>

  <div id="captainEditModal" class="modal fade" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Edit Captain</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div id="captainEditFormPane">
            <div class="mb-3">
              <label class="form-label">Name</label>
              <input type="text" class="form-control" id="captainEditName" value="<%= captain.name || '' %>">
            </div>
            <div class="mb-3">
              <label class="form-label">Rank</label>
              <input type="text" class="form-control" id="captainEditRank" value="<%= captain.rank || '' %>">
            </div>
            <div class="mb-3">
              <label class="form-label">Years of Service</label>
              <input type="number" class="form-control" id="captainEditYears" value="<%= captain.serviceYears %>">
            </div>
            <div class="mb-3">
              <button type="button" class="btn btn-outline-secondary" id="captainEditImageBtn">Change Image</button>
            </div>
            <button type="button" class="btn btn-modern" id="captainEditSaveBtn">Save</button>
          </div>
          <div id="captainEditSearchPane" style="display: none;">
            <button type="button" class="btn btn-outline-secondary btn-sm mb-2" id="captainEditSearchBack">← Back</button>
            <iframe id="captainEditSearchFrame" style="width:100%; height: 400px; border: 1px solid #ddd; border-radius: 6px;"></iframe>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
  (function() {
    var captainId = <%= captain.id %>;
    var modal = document.getElementById('captainEditModal');
    var formPane = document.getElementById('captainEditFormPane');
    var searchPane = document.getElementById('captainEditSearchPane');
    var frame = document.getElementById('captainEditSearchFrame');
    if (!modal) return;

    document.getElementById('captainEditBtn').addEventListener('click', function() {
      new bootstrap.Modal(modal).show();
    });

    document.getElementById('captainEditSaveBtn').addEventListener('click', function() {
      var name = document.getElementById('captainEditName').value.trim();
      var rank = document.getElementById('captainEditRank').value.trim();
      var years = parseInt(document.getElementById('captainEditYears').value, 10) || 0;
      fetch('/api/captains/' + captainId, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name, rank: rank, serviceYears: years })
      }).then(function(r) {
        if (!r.ok) return r.json().then(function(j) { throw new Error(j.error || j.message || 'Save failed'); });
        return r.json();
      }).then(function() {
        bootstrap.Modal.getInstance(modal).hide();
        location.reload();
      }).catch(function(err) { alert('Save failed: ' + err.message); });
    });

    document.getElementById('captainEditImageBtn').addEventListener('click', function() {
      formPane.style.display = 'none';
      searchPane.style.display = 'block';
      var q = encodeURIComponent((document.getElementById('captainEditName').value || 'admiral') + ' <%= (imageSearchPrefix && imageSearchPrefix.captain) || "captain" %>');
      frame.src = '/admin/images/search-frame?entity=captain&id=' + captainId + '&q=' + q;
    });

    document.getElementById('captainEditSearchBack').addEventListener('click', function() {
      frame.src = 'about:blank';
      searchPane.style.display = 'none';
      formPane.style.display = 'block';
    });

    window.addEventListener('message', function(e) {
      if (!e.data || e.data.type !== 'imageSelected' || String(e.data.entityId) !== String(captainId)) return;
      if (e.data.entity !== 'captain') return;
      fetch('/api/images/captain/' + captainId + '/from-url', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url: e.data.url })
      }).then(function(r) {
        if (!r.ok) return r.json().then(function(j) { throw new Error(j.error || j.message || 'Set image failed'); });
        frame.src = 'about:blank';
        searchPane.style.display = 'none';
        formPane.style.display = 'block';
        location.reload();
      }).catch(function(err) { alert('Set image failed: ' + err.message); });
    });
  })();
  </script>
</body>
</html>
