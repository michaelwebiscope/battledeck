            extracted = { name: '', image: '', description: '', rank: '', yearCommissioned: '', className: '', captainName: '' };
            if (data.suggested) {
              if (data.suggested.name) extracted.name = (data.suggested.name + '').trim();
              if (data.suggested.imageUrl) extracted.image = (data.suggested.imageUrl + '').trim();
