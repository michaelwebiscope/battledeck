<!DOCTYPE html>
<html lang="en">
<head>
  <script>
    (function(){ if (localStorage.getItem('adminMode') !== 'true') location.replace('/');
    window.addEventListener('adminModeChanged', function(e){ if (!e.detail || !e.detail.enabled) location.replace('/'); });
    })();
  </script>
  <%- include('partials/head') %>
  <style>
    .add-from-url-page { --field-bg: #f8fafc; }
    .url-bar { display: flex; gap: 12px; align-items: center; margin-bottom: 16px; flex-wrap: wrap; }
    .url-bar input { flex: 1; min-width: 200px; }
    .entity-tabs { display: flex; gap: 8px; margin-bottom: 16px; }
    .entity-tab { padding: 10px 20px; border-radius: 10px; border: 2px solid rgba(12,74,110,0.3); background: white; cursor: pointer; font-weight: 500; transition: all 0.2s; }
    .entity-tab:hover { border-color: var(--blue); background: rgba(2,132,199,0.08); }
    .entity-tab.active { border-color: var(--blue); background: var(--blue); color: white; }
    .add-from-url-toolbar { display: flex; flex-wrap: wrap; align-items: center; gap: 12px; margin-bottom: 16px; }
    .add-from-url-toolbar .url-input { flex: 1; min-width: 200px; }
    .split-layout { display: grid; grid-template-columns: 1fr 340px; gap: 20px; align-items: start; min-height: 0; }
    @media (max-width: 991px) { .split-layout { grid-template-columns: 1fr; } }
    .preview-frame { border: 2px solid rgba(12,74,110,0.3); border-radius: 12px; overflow: hidden; background: #fff; min-height: 480px; max-height: 70vh; position: relative; box-shadow: 0 4px 20px rgba(12,74,110,0.1); }
    .preview-frame #placeholder,
    .preview-frame #pageFrame { position: absolute; top: 0; left: 0; right: 0; bottom: 0; width: 100%; height: 100%; }
    .preview-frame #pageFrame { display: none; z-index: 1; }
    .preview-frame.mapping-mode { border-color: var(--cyan); box-shadow: 0 0 0 2px rgba(6,182,212,0.3); cursor: crosshair; }
    .preview-frame.mapping-mode::after { content: 'Click on an element in the preview to select it'; position: absolute; top: 12px; left: 50%; transform: translateX(-50%); background: var(--cyan); color: white; padding: 8px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 600; z-index: 10; pointer-events: none; white-space: nowrap; }
    .preview-frame iframe { width: 100%; height: 100%; min-height: 480px; border: none; display: block; }
    .extracted-panel { background: var(--field-bg); border-radius: 12px; padding: 20px; border: 1px solid rgba(12,74,110,0.15); }
    .extracted-panel h5 { margin-bottom: 16px; color: var(--blue-deep); }
    .field-row { margin-bottom: 14px; }
    .field-row label { display: block; font-size: 0.8rem; font-weight: 600; color: var(--muted); margin-bottom: 4px; }
    .field-row .value { padding: 10px 12px; background: white; border-radius: 8px; border: 1px solid rgba(12,74,110,0.2); min-height: 40px; font-size: 0.9rem; }
    .field-row .value img { max-width: 100%; max-height: 120px; border-radius: 6px; margin-top: 6px; }
    .field-row select.form-select { min-height: 38px; }
    .captain-checkboxes .form-check { margin-bottom: 4px; }
    .field-row .value:empty::before { content: '—'; color: #94a3b8; }
    .field-row input.mapping-from-page, .field-row textarea.mapping-from-page, .field-row select.mapping-from-page { border-color: var(--cyan); box-shadow: 0 0 0 2px rgba(6,182,212,0.3); }
    .save-bar { margin-top: 20px; padding-top: 16px; border-top: 1px solid rgba(12,74,110,0.15); }
    .save-bar .btn { padding: 12px 24px; font-weight: 600; }
    .status-msg { margin-top: 12px; font-size: 0.9rem; }
    .status-msg.success { color: #059669; }
    .status-msg.error { color: #dc2626; }
    .class-row-wrap { display: flex; gap: 8px; align-items: stretch; }
    .class-row-wrap .form-select { flex: 1; min-width: 0; }
    .add-class-wrap { position: relative; display: flex; align-items: stretch; }
    .add-class-btn { flex-shrink: 0; width: 34px; min-width: 34px; height: auto; min-height: 31px; padding: 0; border-radius: 6px; border: 2px solid var(--blue); background: white; color: var(--blue); font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; line-height: 1; }
    .add-class-btn:hover { background: var(--blue); color: white; }
    .add-class-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .add-class-popover { position: absolute; top: 100%; right: 0; margin-top: 6px; min-width: 260px; background: white; border: 1px solid rgba(12,74,110,0.2); border-radius: 10px; box-shadow: 0 8px 24px rgba(0,0,0,0.12); padding: 14px; z-index: 1050; display: none; }
    .add-class-popover.show { display: block; }
    .add-class-popover .form-label { font-size: 0.8rem; margin-bottom: 2px; }
    .add-class-popover .form-control { font-size: 0.9rem; padding: 6px 10px; }
    .add-class-popover .form-control.mapping-from-page { border-color: var(--cyan); box-shadow: 0 0 0 2px rgba(6,182,212,0.3); }
    .captain-name-row { display: flex; gap: 8px; align-items: stretch; }
    .captain-name-row .form-control { flex: 1; min-width: 0; }
    .add-captain-wrap { position: relative; display: flex; align-items: stretch; }
    .add-captain-btn { flex-shrink: 0; width: 34px; min-width: 34px; height: auto; min-height: 31px; padding: 0; border-radius: 6px; border: 2px solid var(--blue); background: white; color: var(--blue); font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; line-height: 1; }
    .add-captain-btn:hover { background: var(--blue); color: white; }
    .add-captain-popover { position: absolute; top: 100%; right: 0; margin-top: 6px; min-width: 260px; background: white; border: 1px solid rgba(12,74,110,0.2); border-radius: 10px; box-shadow: 0 8px 24px rgba(0,0,0,0.12); padding: 14px; z-index: 1050; display: none; }
    .add-captain-popover.show { display: block; }
    .add-captain-popover .form-label { font-size: 0.8rem; margin-bottom: 2px; }
    .add-captain-popover .form-control { font-size: 0.9rem; padding: 6px 10px; }
    .add-captain-popover .form-control.mapping-from-page { border-color: var(--cyan); box-shadow: 0 0 0 2px rgba(6,182,212,0.3); }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  <main class="app-shell add-from-url-page">
    <div class="container py-4">
      <h1 class="mb-2">Add from URL</h1>
      <p class="text-muted mb-3 small">Paste a URL, click Go, then <strong>click empty fields and click elements in the preview</strong> to extract data.</p>

      <div class="split-layout">
        <div class="preview-frame" id="previewFrame">
          <div id="placeholder" class="d-flex align-items-center justify-content-center text-muted p-5">
            Paste a URL and click Go to load the page.
          </div>
          <iframe id="pageFrame" title="Page preview"></iframe>
        </div>
        <div class="extracted-panel">
          <div class="add-from-url-toolbar mb-3">
            <input type="url" id="urlInput" class="form-control url-input" placeholder="https://en.wikipedia.org/wiki/..." value="">
            <button type="button" class="btn btn-modern" id="goBtn">Go</button>
          </div>
          <%
            var shipType = typeof entityTypes !== 'undefined' && entityTypes.ship ? entityTypes.ship : { displayName: 'Ship' };
            var captainType = typeof entityTypes !== 'undefined' && entityTypes.captain ? entityTypes.captain : { displayName: 'Captain' };
            var classType = typeof entityTypes !== 'undefined' && entityTypes.class ? entityTypes.class : { displayName: 'Class' };
          %>
          <div class="entity-tabs mb-2">
            <button type="button" class="entity-tab active" data-entity="ship">🚢 <%= shipType.displayName %></button>
            <button type="button" class="entity-tab" data-entity="captain">👤 <%= captainType.displayName %></button>
          </div>
          <h5>Extracted Data <small class="text-muted fw-normal">(click field then click on page to select)</small></h5>
          <div class="field-row">
            <label>Name</label>
            <input type="text" class="form-control form-control-sm" id="extName" placeholder="Click here, then click on page to select">
          </div>
          <div class="field-row field-row-ship">
            <label><%= (shipType.formFieldLabels && shipType.formFieldLabels.description) || 'Description' %></label>
            <textarea class="form-control form-control-sm" id="extDescription" rows="3" placeholder="Click here, then click on page to select"></textarea>
          </div>
          <div class="field-row field-row-ship">
            <label><%= (shipType.formFieldLabels && shipType.formFieldLabels.yearCommissioned) || 'Year Commissioned' %></label>
            <input type="text" class="form-control form-control-sm" id="extYearCommissioned" placeholder="Click here, then click on page to select">
          </div>
          <div class="field-row field-row-ship">
            <label><%= classType.displayName %> <small class="text-muted">(map from page or select)</small></label>
            <div class="class-row-wrap">
              <select id="extClass" class="form-select form-select-sm"></select>
              <div class="add-class-wrap">
                <button type="button" class="add-class-btn" id="addClassBtn" title="Add new class">+</button>
                <div id="addClassPopover" class="add-class-popover">
                  <div class="mb-2">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control form-control-sm" id="addClassName" placeholder="e.g. Farragut">
                  </div>
                  <div class="mb-2">
                    <label class="form-label">Type <small class="text-muted">(or click field then click on page)</small></label>
                    <input type="text" class="form-control form-control-sm" id="addClassType" list="addClassTypeList" placeholder="Click here, then click on page to select">
                    <datalist id="addClassTypeList">
                      <option value="Battleship"><option value="Aircraft Carrier"><option value="Destroyer">
                      <option value="Cruiser"><option value="Submarine"><option value="Frigate">
                    </datalist>
                  </div>
                  <div class="mb-2">
                    <label class="form-label">Country <small class="text-muted">(or click field then click on page)</small></label>
                    <input type="text" class="form-control form-control-sm" id="addClassCountry" list="addClassCountryList" placeholder="Click here, then click on page to select">
                    <datalist id="addClassCountryList">
                      <option value="USA"><option value="UK"><option value="Germany"><option value="Japan">
                    </datalist>
                  </div>
                  <div id="addClassStatus" class="small text-danger mb-2" style="display:none;"></div>
                  <div class="d-flex gap-2 justify-content-end">
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="addClassCancelBtn">Cancel</button>
                    <button type="button" class="btn btn-modern btn-sm" id="addClassSaveBtn">Add</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="field-row field-row-ship">
            <label><%= captainType.pluralName || 'Captains' %> <small class="text-muted">(map from page or select; first = primary)</small></label>
            <div id="extCaptains" class="captain-checkboxes border rounded p-2" style="max-height: 140px; overflow-y: auto;"></div>
            <label class="mt-2">Primary captain name <small class="text-muted">(edit if wrong)</small></label>
            <div class="captain-name-row">
              <input type="text" class="form-control form-control-sm" id="extCaptainName" placeholder="Click here, then click on page to select">
              <div class="add-captain-wrap">
                <button type="button" class="add-captain-btn" id="addCaptainBtn" title="Add new captain">+</button>
                <div id="addCaptainPopover" class="add-captain-popover">
                  <div class="mb-2">
                    <label class="form-label">Name <small class="text-muted">(or click field then click on page)</small></label>
                    <input type="text" class="form-control form-control-sm" id="addCaptainName" placeholder="Click here, then click on page to select">
                  </div>
                  <div class="mb-2">
                    <label class="form-label">Rank <small class="text-muted">(or click field then click on page)</small></label>
                    <input type="text" class="form-control form-control-sm" id="addCaptainRank" list="addCaptainRankList" placeholder="Click here, then click on page to select">
                    <datalist id="addCaptainRankList">
                      <option value="Admiral"><option value="Captain"><option value="Commander"><option value="Lt. Commander">
                      <option value="Lieutenant"><option value="T/Cdr"><option value="T/Lt.Cdr">
                    </datalist>
                  </div>
                  <div id="addCaptainStatus" class="small text-danger mb-2" style="display:none;"></div>
                  <div class="d-flex gap-2 justify-content-end">
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="addCaptainCancelBtn">Cancel</button>
                    <button type="button" class="btn btn-modern btn-sm" id="addCaptainSaveBtn">Add</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="field-row field-row-captain" style="display:none">
            <label>Rank</label>
            <input type="text" class="form-control form-control-sm" id="extRank" placeholder="Click here, then click on page to select">
          </div>
          <div class="field-row">
            <label>Image URL</label>
            <input type="url" class="form-control form-control-sm" id="extImageUrl" placeholder="Click here, then click on page to select">
            <div id="extImagePreview" class="mt-1" style="min-height: 24px;"></div>
          </div>
          <div class="save-bar">
            <button type="button" class="btn btn-modern" id="saveBtn" disabled>Save</button>
            <div id="statusMsg" class="status-msg"></div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (function() {
      var entity = 'ship';
      var currentMappingField = null;
      var addClassMappingField = null;
      var addCaptainMappingField = null;
      var extracted = { name: '', image: '', description: '', rank: '', yearCommissioned: '', className: '', captainName: '' };
      var classes = [];
      var captains = [];
      var pageClassNames = [];
      var pageCaptainNames = [];
      var hasLoadedPage = false;
      var urlInput = document.getElementById('urlInput');
      var goBtn = document.getElementById('goBtn');
      var pageFrame = document.getElementById('pageFrame');
      var placeholder = document.getElementById('placeholder');
      var previewFrame = document.getElementById('previewFrame');
      var saveBtn = document.getElementById('saveBtn');
      var statusMsg = document.getElementById('statusMsg');

      function updateEntityUI() {
        document.querySelectorAll('.entity-tab').forEach(function(t) {
          t.classList.toggle('active', t.dataset.entity === entity);
        });
        document.querySelectorAll('.field-row-ship').forEach(function(r) { r.style.display = entity === 'ship' ? '' : 'none'; });
        document.querySelectorAll('.field-row-captain').forEach(function(r) { r.style.display = entity === 'captain' ? '' : 'none'; });
      }

      function parseYear(text) {
        if (!text) return '';
        var m = (text + '').match(/\b(1[89][0-9]{2}|20[0-2][0-9])\b/);
        return m ? m[1] : '';
      }

      function hasEmptyRequiredFields() {
        var name = (document.getElementById('extName')?.value || '').trim();
        if (entity === 'ship') {
          var img = (document.getElementById('extImageUrl')?.value || '').trim();
          var desc = (document.getElementById('extDescription')?.value || '').trim();
          var year = (document.getElementById('extYearCommissioned')?.value || '').trim();
          var classVal = (document.getElementById('extClass')?.value || '').trim();
          if (classVal === 'map:frompage') classVal = '';
          var cap = (document.getElementById('extCaptainName')?.value || '').trim();
          return !name || !img || !desc || !year || !classVal || !cap;
        }
        var rank = (document.getElementById('extRank')?.value || '').trim();
        return !name || !rank;
      }

      function updateMappingStatus() {
        if (hasEmptyRequiredFields()) {
          statusMsg.textContent = 'Click empty fields, then click on the page to select.';
          statusMsg.className = 'status-msg';
        } else {
          statusMsg.textContent = '';
        }
      }

      function renderExtracted() {
        var nameEl = document.getElementById('extName');
        if (nameEl) nameEl.value = extracted.name || '';
        var descEl = document.getElementById('extDescription');
        if (descEl) descEl.value = extracted.description || '';
        var rankEl = document.getElementById('extRank');
        if (rankEl) rankEl.value = extracted.rank || '';
        var yearEl = document.getElementById('extYearCommissioned');
        if (yearEl) yearEl.value = extracted.yearCommissioned || '';
        var imgUrlEl = document.getElementById('extImageUrl');
        if (imgUrlEl) imgUrlEl.value = extracted.image || '';
        var imgPrev = document.getElementById('extImagePreview');
        if (imgPrev) {
          if (extracted.image) {
            imgPrev.innerHTML = '<img src="' + extracted.image.replace(/"/g, '&quot;') + '" alt="" class="rounded" style="max-height:80px" onerror="this.parentElement.innerHTML=\'<em>Failed to load</em>\'">';
          } else {
            imgPrev.innerHTML = '';
          }
        }
        if (extracted.className && !userHasChangedClass) {
          var cn = extracted.className.trim();
          if (cn && !pageClassNames.some(function(p) { return (p || '').toLowerCase() === cn.toLowerCase(); })) {
            pageClassNames.unshift(cn);
            refreshClassDropdown();
          }
          var classSel = document.getElementById('extClass');
          var pageVal = 'page:' + (cn || '').replace(/"/g, '&quot;');
          if (classSel && Array.from(classSel.options).some(function(o) { return o.value === pageVal; })) classSel.value = pageVal;
        }
        if (extracted.captainName) {
          var capn = extracted.captainName.trim();
          if (capn && !pageCaptainNames.some(function(p) { return (p || '').toLowerCase() === capn.toLowerCase(); })) {
            pageCaptainNames.unshift(capn);
            refreshCaptainCheckboxes();
          }
          var capNameEl = document.getElementById('extCaptainName');
          if (capNameEl) capNameEl.value = capn || '';
        }
        saveBtn.disabled = !(document.getElementById('extName')?.value || '').trim();
      }

      document.querySelectorAll('.entity-tab').forEach(function(t) {
        t.onclick = function() {
          entity = t.dataset.entity;
          updateEntityUI();
          updateMappingStatus();
        };
      });

      function startFieldMapping(field) {
        if (addClassMappingField) stopAddClassMapping();
        if (addCaptainMappingField) stopAddCaptainMapping();
        clearFieldMappingHighlight();
        currentMappingField = field;
        var el = null;
        if (field === 'name') el = document.getElementById('extName');
        else if (field === 'image') el = document.getElementById('extImageUrl');
        else if (field === 'description') el = document.getElementById('extDescription');
        else if (field === 'yearCommissioned') el = document.getElementById('extYearCommissioned');
        else if (field === 'class') el = document.getElementById('extClass');
        else if (field === 'captain') el = document.getElementById('extCaptainName');
        else if (field === 'rank') el = document.getElementById('extRank');
        if (el) el.classList.add('mapping-from-page');
        if (previewFrame) previewFrame.classList.add('mapping-mode');
        attachFrameClickHandler();
        statusMsg.textContent = 'Click on the page to select ' + field + '.';
        statusMsg.className = 'status-msg';
      }

      function clearFieldMappingHighlight() {
        currentMappingField = null;
        ['extName', 'extDescription', 'extYearCommissioned', 'extImageUrl', 'extClass', 'extCaptainName', 'extRank'].forEach(function(id) {
          var el = document.getElementById(id);
          if (el) el.classList.remove('mapping-from-page');
        });
        if (previewFrame) previewFrame.classList.remove('mapping-mode');
      }

      var userHasChangedClass = false;
      document.getElementById('extClass').addEventListener('change', function() {
        if (this.value === 'map:frompage') {
          startFieldMapping('class');
        } else {
          userHasChangedClass = true;
          updateMappingStatus();
        }
      });

      function setupFieldMappingHandlers() {
        var fields = [
          { id: 'extName', field: 'name' },
          { id: 'extImageUrl', field: 'image' },
          { id: 'extDescription', field: 'description' },
          { id: 'extYearCommissioned', field: 'yearCommissioned' },
          { id: 'extCaptainName', field: 'captain' },
          { id: 'extRank', field: 'rank' }
        ];
        fields.forEach(function(f) {
          var el = document.getElementById(f.id);
          if (!el) return;
          el.addEventListener('click', function() {
            if (entity === 'captain' && f.field !== 'rank' && f.field !== 'captain') return;
            if (entity === 'ship' && f.field === 'rank') return;
            startFieldMapping(f.field);
          });
          el.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') { clearFieldMappingHighlight(); statusMsg.textContent = ''; return; }
            if (currentMappingField === f.field) clearFieldMappingHighlight();
          });
        });
      }
      setupFieldMappingHandlers();

      window.addEventListener('message', function(e) {
        if (!e.data) return;
        if (e.data.type === 'suggestedData') {
          if (!hasLoadedPage) return;
          var d = e.data;
          if (d.name) extracted.name = (d.name || '').trim().slice(0, 200);
          if (d.imageUrl) extracted.image = (d.imageUrl || '').trim();
          if (d.description && entity === 'ship') extracted.description = (d.description || '').trim().slice(0, 2000);
          if (d.yearCommissioned && entity === 'ship') extracted.yearCommissioned = parseYear(d.yearCommissioned) || (d.yearCommissioned + '').trim();
          if (d.classNames && Array.isArray(d.classNames)) {
            pageClassNames = d.classNames;
            if (d.classNames.length && !extracted.className) extracted.className = d.classNames[0];
          }
          if (d.captainNames && Array.isArray(d.captainNames)) pageCaptainNames = d.captainNames;
          if (!userHasChangedClass) refreshClassDropdown();
          refreshCaptainCheckboxes();
          renderExtracted();
          updateMappingStatus();
          return;
        }
        if (e.data.type !== 'elementSelected') return;
        if (!currentMappingField && !addClassMappingField && !addCaptainMappingField) return;
        var d = e.data;
        var text = (d.text || '').trim().slice(0, 100);
        if (addClassMappingField === 'type') {
          document.getElementById('addClassType').value = text;
          document.getElementById('addClassType').classList.remove('mapping-from-page');
          addClassMappingField = null;
          if (previewFrame) previewFrame.classList.remove('mapping-mode');
          statusMsg.textContent = '';
          return;
        }
        if (addClassMappingField === 'country') {
          document.getElementById('addClassCountry').value = text;
          document.getElementById('addClassCountry').classList.remove('mapping-from-page');
          addClassMappingField = null;
          if (previewFrame) previewFrame.classList.remove('mapping-mode');
          statusMsg.textContent = '';
          return;
        }
        if (addCaptainMappingField === 'name') {
          document.getElementById('addCaptainName').value = text;
          document.getElementById('addCaptainName').classList.remove('mapping-from-page');
          addCaptainMappingField = null;
          if (previewFrame) previewFrame.classList.remove('mapping-mode');
          statusMsg.textContent = '';
          return;
        }
        if (addCaptainMappingField === 'rank') {
          document.getElementById('addCaptainRank').value = text;
          document.getElementById('addCaptainRank').classList.remove('mapping-from-page');
          addCaptainMappingField = null;
          if (previewFrame) previewFrame.classList.remove('mapping-mode');
          statusMsg.textContent = '';
          return;
        }
        var wasField = currentMappingField;
        if (wasField === 'name') {
          extracted.name = (d.text || '').trim().slice(0, 200);
        } else if (wasField === 'image') {
          extracted.image = (d.imageUrl || '').trim();
          if (!extracted.image && d.text && /^https?:\/\//.test(d.text)) extracted.image = d.text.trim();
        } else if (wasField === 'description') {
          extracted.description = (d.text || '').trim().slice(0, 2000);
        } else if (wasField === 'yearCommissioned') {
          extracted.yearCommissioned = parseYear(d.text || '');
        } else if (wasField === 'class') {
          extracted.className = (d.text || '').trim().slice(0, 100).replace(/\s+class$/i, '').replace(/-class$/i, '');
        } else if (wasField === 'captain') {
          extracted.captainName = (d.text || '').trim().slice(0, 100);
        } else if (wasField === 'rank') {
          extracted.rank = (d.text || '').trim().slice(0, 100);
        }
        clearFieldMappingHighlight();
        renderExtracted();
        updateMappingStatus();
      });

      function attachFrameClickHandler() {
        try {
          var doc = pageFrame.contentDocument || pageFrame.contentWindow?.document;
          if (!doc || (!currentMappingField && !addClassMappingField && !addCaptainMappingField)) return;
          var handler = function(e) {
            if (!currentMappingField && !addClassMappingField && !addCaptainMappingField) return;
            e.preventDefault();
            e.stopPropagation();
            var el = e.target;
            var text = (el.innerText || el.textContent || '').trim().slice(0, 500);
            var txt100 = text.slice(0, 100);
            if (addClassMappingField === 'type') {
              document.getElementById('addClassType').value = txt100;
              document.getElementById('addClassType').classList.remove('mapping-from-page');
              addClassMappingField = null;
              if (previewFrame) previewFrame.classList.remove('mapping-mode');
              statusMsg.textContent = '';
              return;
            }
            if (addClassMappingField === 'country') {
              document.getElementById('addClassCountry').value = txt100;
              document.getElementById('addClassCountry').classList.remove('mapping-from-page');
              addClassMappingField = null;
              if (previewFrame) previewFrame.classList.remove('mapping-mode');
              statusMsg.textContent = '';
              return;
            }
            if (addCaptainMappingField === 'name') {
              document.getElementById('addCaptainName').value = txt100;
              document.getElementById('addCaptainName').classList.remove('mapping-from-page');
              addCaptainMappingField = null;
              if (previewFrame) previewFrame.classList.remove('mapping-mode');
              statusMsg.textContent = '';
              return;
            }
            if (addCaptainMappingField === 'rank') {
              document.getElementById('addCaptainRank').value = txt100;
              document.getElementById('addCaptainRank').classList.remove('mapping-from-page');
              addCaptainMappingField = null;
              if (previewFrame) previewFrame.classList.remove('mapping-mode');
              statusMsg.textContent = '';
              return;
            }
            var img = el.tagName === 'IMG' ? (el.src || el.currentSrc) : '';
            if (!img && el.querySelector && el.querySelector('img')) { var q = el.querySelector('img'); img = q.src || q.currentSrc || ''; }
            if (!img && el.tagName === 'A' && /\.(jpg|jpeg|png|gif|webp)$/i.test(el.href)) img = el.href;
            if (!img && el.dataset && el.dataset.src) img = el.dataset.src;
            if (img && img.startsWith('//')) img = (doc.location.protocol || 'https:') + img;
            var wasField = currentMappingField;
            if (wasField === 'name') extracted.name = (text || '').trim().slice(0, 200);
            else if (wasField === 'image') { extracted.image = (img || '').trim(); if (!extracted.image && text && /^https?:\/\//.test(text)) extracted.image = text.trim(); }
            else if (wasField === 'description') extracted.description = (text || '').trim().slice(0, 2000);
            else if (wasField === 'yearCommissioned') extracted.yearCommissioned = parseYear(text || '');
            else if (wasField === 'class') extracted.className = (text || '').trim().slice(0, 100).replace(/\s+class$/i, '').replace(/-class$/i, '');
            else if (wasField === 'captain') extracted.captainName = (text || '').trim().slice(0, 100);
            else if (wasField === 'rank') extracted.rank = (text || '').trim().slice(0, 100);
            clearFieldMappingHighlight();
            renderExtracted();
            updateMappingStatus();
          };
          doc.removeEventListener('mousedown', doc._navalSelectHandler, true);
          doc.removeEventListener('click', doc._navalSelectPrevent, true);
          doc._navalSelectHandler = handler;
          doc._navalSelectPrevent = function(e) {
            if (currentMappingField || addClassMappingField || addCaptainMappingField) { e.preventDefault(); e.stopPropagation(); }
          };
          doc.addEventListener('mousedown', handler, true);
          doc.addEventListener('click', doc._navalSelectPrevent, true);
        } catch (err) { console.warn('Could not attach frame click handler:', err); }
      }

      goBtn.onclick = function() {
        var url = urlInput.value.trim();
        if (!url || !/^https?:\/\//i.test(url)) {
          statusMsg.textContent = 'Enter a valid URL.';
          statusMsg.className = 'status-msg error';
