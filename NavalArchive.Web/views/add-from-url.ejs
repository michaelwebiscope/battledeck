        statusEl.style.display = 'none';
        statusEl.textContent = '';
        saveBtn.disabled = true;
        fetch('/api/captains', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: name, rank: (rankInput.value || '').trim() || '' })
        })
          .then(function(r) {
            if (!r.ok) return r.json().then(function(d) { throw new Error(d.error || 'Failed to create captain'); });
            return r.json();
          })
          .then(function(data) {
            var newCap = { id: data.id, name: data.name, rank: data.rank || '' };
            captains.push(newCap);
            pageCaptainNames.unshift(data.name);
            refreshCaptainCheckboxes();
            document.getElementById('extCaptainName').value = data.name;
            hideAddCaptainPopover();
          })
          .catch(function(err) {
            statusEl.textContent = err.message || 'Failed to add captain.';
            statusEl.style.display = 'block';
          })
          .finally(function() { saveBtn.disabled = false; });
      });

      document.addEventListener('click', function(e) {
        var classPopover = document.getElementById('addClassPopover');
        var classBtn = document.getElementById('addClassBtn');
        if (classPopover && classPopover.classList.contains('show')) {
          if (!classPopover.contains(e.target) && !(classBtn && classBtn.contains(e.target))) hideAddClassPopover();
        }
        var capPopover = document.getElementById('addCaptainPopover');
        var capBtn = document.getElementById('addCaptainBtn');
        if (capPopover && capPopover.classList.contains('show')) {
          if (!capPopover.contains(e.target) && !(capBtn && capBtn.contains(e.target))) hideAddCaptainPopover();
        }
      });

      document.getElementById('addClassSaveBtn').addEventListener('click', function() {
        var nameInput = document.getElementById('addClassName');
        var typeInput = document.getElementById('addClassType');
        var countryInput = document.getElementById('addClassCountry');
        var statusEl = document.getElementById('addClassStatus');
        var saveBtn = document.getElementById('addClassSaveBtn');
        var name = (nameInput.value || '').trim();
        if (!name) {
          statusEl.textContent = 'Name is required.';
          statusEl.style.display = 'block';
          return;
        }
        statusEl.style.display = 'none';
        statusEl.textContent = '';
        saveBtn.disabled = true;
        fetch('/api/classes', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: name,
            type: (typeInput.value || '').trim() || 'Unknown',
            country: (countryInput.value || '').trim() || ''
          })
        })
          .then(function(r) {
            if (!r.ok) return r.json().then(function(d) { throw new Error(d.error || 'Failed to create class'); });
            return r.json();
          })
          .then(function(data) {
            var newClass = { id: data.id, name: data.name, type: data.type || 'Unknown', country: data.country || '' };
            classes.push(newClass);
            refreshClassDropdown();
            userHasChangedClass = true;
            var classSel = document.getElementById('extClass');
            if (classSel) classSel.value = String(newClass.id);
            hideAddClassPopover();
          })
          .catch(function(err) {
            statusEl.textContent = err.message || 'Failed to add class.';
            statusEl.style.display = 'block';
          })
          .finally(function() { saveBtn.disabled = false; });
      });

      ['addClassName', 'addClassType', 'addClassCountry'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('keydown', function(e) {
          if (e.key === 'Enter') {
            e.preventDefault();
            document.getElementById('addClassSaveBtn').click();
          }
        });
      });

      ['addCaptainName', 'addCaptainRank'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('keydown', function(e) {
          if (e.key === 'Enter') {
            e.preventDefault();
            document.getElementById('addCaptainSaveBtn').click();
          }
        });
      });

      loadClassesAndCaptains();
      updateEntityUI();
    })();
  </script>
</body>
</html>
