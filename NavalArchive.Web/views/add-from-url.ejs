      saveBtn.onclick = async function() {
        var vals = getExtractedFromInputs();
        if (!vals.name) return;
        saveBtn.disabled = true;
        statusMsg.textContent = 'Saving...';
        statusMsg.className = 'status-msg';
        var apiUrl = entity === 'ship' ? '/api/ships' : '/api/captains';
        var classVal = document.getElementById('extClass')?.value || '';
        var captainChecks = document.querySelectorAll('input[name="captainSel"]:checked');
        var captainVals = Array.from(captainChecks).map(function(c) { return c.value; });
        var primaryCaptainVal = captainVals[0] || '1';
        if (!classVal && pageClassNames.length > 0) {
          classVal = 'page:' + (pageClassNames[0] || '').trim();
        }
        if (!classVal) {
          statusMsg.textContent = 'Please select a class from the dropdown.';
          statusMsg.className = 'status-msg error';
          saveBtn.disabled = false;
          return;
        }
        var classId = null;
        var className = null;
        if (classVal.startsWith('page:')) {
          className = (classVal.slice(5) || '').trim();
          var classMatch = classes.find(function(c) {
            var cname = (c.name || '').toLowerCase();
            var pname = (className || '').toLowerCase().replace(/\s+class$/, '').replace(/-class$/, '');
            return cname === pname || cname.includes(pname) || pname.includes(cname) || cname.replace(/-/g, ' ') === pname.replace(/-/g, ' ');
          });
          if (classMatch) classId = classMatch.id || classMatch.Id;
        } else {
          classId = parseInt(classVal, 10) || null;
        }
        for (var ci = 0; ci < captainVals.length; ci++) {
          var cv = captainVals[ci];
          if (cv.startsWith('page:')) {
            var pageCapName = (cv.slice(5) || '').trim();
            var capMatch = captains.find(function(c) {
              var cn = (c.name || '').toLowerCase();
              var pn = pageCapName.toLowerCase();
              return cn === pn || cn.includes(pn) || pn.includes(cn);
            });
            if (!capMatch) {
              try {
                var createCapRes = await fetch('/api/captains', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ name: pageCapName, rank: '' })
                });
                var createCapData = await createCapRes.json();
                if (createCapRes.ok && createCapData && (createCapData.id || createCapData.Id)) {
                  captains.push({ id: createCapData.id ?? createCapData.Id, name: pageCapName });
                }
              } catch (_) {}
            }
          }
        }
        var captainId = 1;
        if (primaryCaptainVal.startsWith('page:')) {
          var pageCapName = (document.getElementById('extCaptainName')?.value || primaryCaptainVal.slice(5) || '').trim();
          var capMatch = captains.find(function(c) {
            var cn = (c.name || '').toLowerCase();
            var pn = pageCapName.toLowerCase();
            return cn === pn || cn.includes(pn) || pn.includes(cn);
          });
          if (capMatch) captainId = capMatch.id || capMatch.Id;
          else {
            try {
              var createCapRes = await fetch('/api/captains', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: pageCapName, rank: '' })
              });
              var createCapData = await createCapRes.json();
              if (createCapRes.ok && createCapData && (createCapData.id || createCapData.Id)) captainId = createCapData.id ?? createCapData.Id;
            } catch (_) {}
          }
        } else {
          captainId = parseInt(primaryCaptainVal, 10) || 1;
        }
        var yearCommissioned = parseInt(vals.yearCommissioned || '0', 10) || 0;
        var shipBody = { name: vals.name, description: vals.description, imageUrl: vals.image, yearCommissioned: yearCommissioned, captainId: captainId };
        if (classId != null) shipBody.classId = classId;
        if (className) shipBody.className = className;
        var body = entity === 'ship' ? shipBody : { name: vals.name, rank: vals.rank, imageUrl: vals.image };
        fetch(apiUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        }).then(function(r) {
          return r.json().then(function(data) {
            if (!r.ok) throw new Error(data?.error || data?.message || 'Request failed: ' + r.status);
            return data;
          });
        })
          .then(function(data) {
            if (!data || data.error) throw new Error(data?.error || 'Request failed');
            var id = data.id ?? data.Id ?? (data.ship && (data.ship.id ?? data.ship.Id)) ?? (data.captain && (data.captain.id ?? data.captain.Id));
            if (!id && vals.name) {
              var fallbackUrl = entity === 'ship' ? '/api/ships/search?q=' + encodeURIComponent(vals.name) : '/api/captains';
              return fetch(fallbackUrl).then(function(r2) { return r2.json(); })
                .then(function(searchData) {
                  var items = Array.isArray(searchData) ? searchData : (searchData?.items || []);
                  if (entity === 'captain') {
                    var match = items.find(function(c) { return (c.name || c.Name || '').trim() === vals.name.trim(); });
                    id = match && (match.id ?? match.Id);
                  } else if (items[0]) {
                    id = items[0].id ?? items[0].Id;
                  }
                  if (!id) throw new Error('Saved but could not find the new ' + entity + '. Try the Fleet or Captains page.');
                  return id;
                });
            }
            return id || Promise.reject(new Error('Saved but no ID returned.'));
          })
          .then(function(id) {
            if (!id) return;
            statusMsg.textContent = 'Saved! Redirecting...';
            statusMsg.className = 'status-msg success';
            if (entity === 'ship' && vals.image) {
              fetch('/api/images/ship/' + id + '/from-url', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url: vals.image })
              }).catch(function() {});
            } else if (entity === 'captain' && vals.image) {
              fetch('/api/images/captain/' + id + '/from-url', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url: vals.image })
              }).catch(function() {});
            }
            window.location.replace(entity === 'ship' ? '/ships/' + id : '/captains/' + id);
          })
          .catch(function(err) {
            statusMsg.textContent = 'Error: ' + err.message;
            statusMsg.className = 'status-msg error';
          })
          .finally(function() { saveBtn.disabled = false; });
      };

      function refreshClassDropdown() {
        var sel = document.getElementById('extClass');
        if (!sel) return;
        var prevVal = sel.value;
        if (prevVal === 'map:frompage') prevVal = '';
        var opts = ['<option value="">— Select class —</option>', '<option value="map:frompage">— Click here, then click on page to map —</option>'];
        var seen = {};
        var firstPageVal = null;
        var newValues = [''];
        pageClassNames.forEach(function(cn) {
          if (!cn || seen[cn]) return;
          seen[cn] = true;
          var val = 'page:' + (cn || '').replace(/"/g, '&quot;');
          if (!firstPageVal) firstPageVal = val;
          newValues.push(val);
          opts.push('<option value="' + val + '">' + (cn || '') + ' (from page)</option>');
        });
        classes.forEach(function(c) {
          var v = '' + (c.id || c.Id);
          newValues.push(v);
          opts.push('<option value="' + v + '">' + (c.name || '') + ' (' + (c.type || '') + ', ' + (c.country || '') + ')</option>');
        });
        sel.innerHTML = opts.join('');
        if (prevVal && newValues.indexOf(prevVal) >= 0) sel.value = prevVal;
        else if (firstPageVal) sel.value = firstPageVal;
      }

      function refreshCaptainCheckboxes() {
        var cont = document.getElementById('extCaptains');
        if (!cont) return;
        var items = [];
        var seenIds = {};
        pageCaptainNames.forEach(function(name) {
          var match = captains.find(function(c) { return (c.name || '').toLowerCase() === name.toLowerCase() || (c.name || '').toLowerCase().includes(name.toLowerCase()); });
          items.push({ name: name, id: match ? (match.id || match.Id) : null });
          if (match) seenIds[match.id || match.Id] = true;
        });
        captains.slice(0, 25).forEach(function(c) {
          var cid = c.id || c.Id;
          if (!seenIds[cid]) items.push({ name: (c.name || '') + (c.rank ? ' — ' + c.rank : ''), id: cid });
        });
        if (items.length === 0) {
          captains.slice(0, 25).forEach(function(c) {
            items.push({ name: (c.name || '') + (c.rank ? ' — ' + c.rank : ''), id: c.id || c.Id });
          });
        }
        cont.innerHTML = items.map(function(it, i) {
          var val = it.id ? it.id : ('page:' + (it.name || '').replace(/"/g, '&quot;'));
          var checked = i === 0 ? ' checked' : '';
          var label = (it.name || '') + (it.id ? ' ✓' : ' (from page)');
          return '<div class="form-check"><input class="form-check-input" type="checkbox" name="captainSel" value="' + val + '" id="cap' + i + '"' + checked + '><label class="form-check-label" for="cap' + i + '">' + label + '</label></div>';
        }).join('');
        cont.querySelectorAll('input[name="captainSel"]').forEach(function(cb) {
          cb.addEventListener('change', syncCaptainNameFromSelection);
        });
        syncCaptainNameFromSelection();
      }

      function syncCaptainNameFromSelection() {
        var captainChecks = document.querySelectorAll('input[name="captainSel"]:checked');
        var primaryVal = captainChecks[0] ? captainChecks[0].value : '';
        var capNameEl = document.getElementById('extCaptainName');
