$ErrorActionPreference = "Stop"
$apiBase = "http://localhost:5000"
$jar = (Get-ChildItem "{{ image_populator_path }}" -Filter "image-populator*.jar" -ErrorAction SilentlyContinue | Select-Object -First 1 -ExpandProperty FullName)
if (-not $jar) { throw "No image-populator jar found in {{ image_populator_path }}" }
$javaExe = $null
foreach ($base in @("C:\Program Files\Amazon Corretto", "C:\Program Files\Eclipse Adoptium")) {
  if (Test-Path $base) {
    $jdk = Get-ChildItem $base -Directory -ErrorAction SilentlyContinue | Where-Object { $_.Name -like "jdk*" } | Select-Object -First 1
    if ($jdk -and (Test-Path "$($jdk.FullName)\bin\java.exe")) {
      $javaExe = "$($jdk.FullName)\bin\java.exe"
      break
    }
  }
}
if (-not $javaExe) { $javaExe = "java" }
$env:IMAGE_POPULATOR_LISTEN = "true"
$env:SERVER_PORT = "{{ image_populator_port }}"
$env:API_URL = $apiBase
{# New Relic Java agent: nr-java-agent.yml deploys newrelic.jar + newrelic.yml beside it; without -javaagent nothing reports to NR. #}
$nrJar = Join-Path '{{ newrelic_java_agent_dir | default("C:\\ProgramData\\NewRelic\\java") }}' 'newrelic.jar'
if (Test-Path $nrJar) {
  & $javaExe "-javaagent:$nrJar" "-Dnewrelic.environment=production" -jar $jar
} else {
  & $javaExe -jar $jar
}
